    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T51" name="Contact Multidisciplinary Specialized Center - Step 3 Escalation">
      <bpmn:incoming>SF_GW_G16_YES_UT_T51</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T51_EE_1</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G17" name="Active Treatment in Progress?">
      <bpmn:incoming>SF_GW_G16_NO_GW_G17</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G17_ACTIVE_EE_1</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G17_INACTIVE_GW_G31</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_G31" name="Required Specialist Referral Level">
      <bpmn:incoming>SF_GW_G17_INACTIVE_GW_G31</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G31_GP_UT_T21b</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G31_PSYCH_UT_T47</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G31_PSYCHIAT_UT_T48</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T21b" name="Execute Active Monitoring - Annual Review">
      <bpmn:incoming>SF_GW_G31_GP_UT_T21b</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T21b_EE_1</bpmn:outgoing>
