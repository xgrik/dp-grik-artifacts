    <bpmn:userTask id="UT_T37" name="Deliver High-Intensity CBT - Cardiac Step 3 (In-Person)">
      <bpmn:incoming>SF_GW_G24_S3_UT_T37</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T37_EE_1c</bpmn:outgoing>
