<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  id="Definitions_1bdj0sq"
  targetNamespace="http://bpmn.io/schema/bpmn"
  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
  exporter="Camunda Modeler"
  exporterVersion="5.33.1"
  modeler:executionPlatform="Camunda Platform"
  modeler:executionPlatformVersion="7.22.0">

  <bpmn:process id="Process_1wlyh5l" isExecutable="true" name="Comprehensive Psychological Management of Patient with Somatic Disease">

    <!-- ==================== START EVENT ==================== -->
    <bpmn:startEvent id="SE_1" name="Patient with Somatic Disease Presents for Care">
      <bpmn:outgoing>SF_SE1_UT_T01</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ==================== PHASE 0: ENTRY AND SCREENING ==================== -->

    <bpmn:userTask id="UT_T01" name="Conduct Initial Patient Contact and Somatic Assessment">
      <bpmn:incoming>SF_SE1_UT_T01</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T01_UT_T02</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T02" name="Administer Psychological Screening Questionnaire (4 Questions)">
      <bpmn:incoming>SF_UT_T01_UT_T02</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T02_GW_G01</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G01" name="Screening Result: Concurrent Psychological Problems Detected?">
      <bpmn:incoming>SF_UT_T02_GW_G01</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G01_YES_UT_T03</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G01_NO_EE_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T03" name="Administer Depression Identification Questions (2 Questions)">
      <bpmn:incoming>SF_GW_G01_YES_UT_T03</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T03_GW_G03</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G03" name="Depression Identification Screen Positive?">
      <bpmn:incoming>SF_UT_T03_GW_G03</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G03_YES_GW_G02</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G03_NO_EE_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_G02" name="GP Competent to Assess Mental Status?">
      <bpmn:incoming>SF_GW_G03_YES_GW_G02</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G02_YES_UT_T04</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G02_NO_UT_T47</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T04" name="Administer Extended Depression Assessment (3 Additional Questions)">
      <bpmn:incoming>SF_GW_G02_YES_UT_T04</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T04_UT_T08</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ==================== PHASE 1: ASSESSMENT AND DIAGNOSIS ==================== -->

    <bpmn:userTask id="UT_T08" name="Take Detailed Patient Anamnesis">
      <bpmn:incoming>SF_UT_T04_UT_T08</bpmn:incoming>
      <bpmn:incoming>SF_UT_T47_UT_T08</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T08_UT_T05</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T05" name="Administer Standardized Psychometric Instruments (PHQ-9, GAD-7, BDI-II, HAMD, HAI)">
      <bpmn:incoming>SF_UT_T08_UT_T05</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T05_UT_T10</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T10" name="Assess Mental Status and Functional Impairment">
      <bpmn:incoming>SF_UT_T05_UT_T10</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T10_UT_T11</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T11" name="Assess Suicidal Risk">
      <bpmn:incoming>SF_UT_T10_UT_T11</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T11_GW_G06</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G06" name="Immediate Suicidal or Safety Risk Present?">
      <bpmn:incoming>SF_UT_T11_GW_G06</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G06_YES_UT_T49</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G06_NO_GW_G07</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T49" name="Issue Urgent Referral to Specialized Mental Health Services">
      <bpmn:incoming>SF_GW_G06_YES_UT_T49</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T49_EE_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G07" name="Degree of Suicidal Risk">
      <bpmn:incoming>SF_GW_G06_NO_GW_G07</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G07_HIGH_UT_T12</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G07_LOW_UT_T12b</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T12" name="Perform Differential Diagnosis (High Risk Path)">
      <bpmn:incoming>SF_GW_G07_HIGH_UT_T12</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T12_GW_G10</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T12b" name="Perform Differential Diagnosis (Standard Path)">
      <bpmn:incoming>SF_GW_G07_LOW_UT_T12b</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T12b_GW_G10</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G10" name="Differential Diagnosis Outcome">
      <bpmn:incoming>SF_UT_T12_GW_G10</bpmn:incoming>
      <bpmn:incoming>SF_UT_T12b_GW_G10</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G10_ADJUST_UT_T13</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G10_DEP_UT_T13</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G10_OTHER_UT_T48</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T13" name="Establish Comorbid Psychiatric Diagnosis">
      <bpmn:incoming>SF_GW_G10_ADJUST_UT_T13</bpmn:incoming>
      <bpmn:incoming>SF_GW_G10_DEP_UT_T13</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T13_GW_G11</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G11" name="Dual Diagnosis Required?">
      <bpmn:incoming>SF_UT_T13_GW_G11</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G11_YES_BRT_T14</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G11_NO_BRT_T14</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:businessRuleTask id="BRT_T14" name="Classify Depression Severity">
      <bpmn:incoming>SF_GW_G11_YES_BRT_T14</bpmn:incoming>
      <bpmn:incoming>SF_GW_G11_NO_BRT_T14</bpmn:incoming>
      <bpmn:outgoing>SF_BRT_T14_GW_G12</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="GW_G12" name="Specific Learning or Cognitive Disorders Present?">
      <bpmn:incoming>SF_BRT_T14_GW_G12</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G12_YES_UT_T15</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G12_NO_UT_T15b</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T15" name="Evaluate Need for Somatic Specialist Consultation (with Cognitive Disorder Adaptation)">
      <bpmn:incoming>SF_GW_G12_YES_UT_T15</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T15_GW_G09</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T15b" name="Evaluate Need for Somatic Specialist Consultation">
      <bpmn:incoming>SF_GW_G12_NO_UT_T15b</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T15b_GW_G09</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G09" name="Comorbid Anxiety Disorder Present?">
      <bpmn:incoming>SF_UT_T15_GW_G09</bpmn:incoming>
      <bpmn:incoming>SF_UT_T15b_GW_G09</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G09_DEP_ANXI_UT_T19</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G09_DEP_ONLY_UT_T19</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ==================== PHASE 2: TREATMENT PLANNING ==================== -->

    <bpmn:userTask id="UT_T19" name="Communicate Diagnosis to Patient">
      <bpmn:incoming>SF_GW_G09_DEP_ANXI_UT_T19</bpmn:incoming>
      <bpmn:incoming>SF_GW_G09_DEP_ONLY_UT_T19</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T19_UT_T18</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T18" name="Obtain Patient Informed Consent">
      <bpmn:incoming>SF_UT_T19_UT_T18</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T18_UT_T20</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T20" name="Provide Psychoeducation to Patient and Family">
      <bpmn:incoming>SF_UT_T18_UT_T20</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T20_GW_G28</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G28" name="Family or Caregiver Actively Involved?">
      <bpmn:incoming>SF_UT_T20_GW_G28</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G28_YES_UT_T56</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G28_NO_UT_T16</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T56" name="Provide Information to Family and Caregivers">
      <bpmn:incoming>SF_GW_G28_YES_UT_T56</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T56_UT_T57</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T57" name="Assess Caregiver Support Needs">
      <bpmn:incoming>SF_UT_T56_UT_T57</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T57_UT_T16</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T16" name="Formulate Individual Treatment Plan - Step 1">
      <bpmn:incoming>SF_GW_G28_NO_UT_T16</bpmn:incoming>
      <bpmn:incoming>SF_UT_T57_UT_T16</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T16_GW_G33</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G33" name="Standard Procedure Applicable?">
      <bpmn:incoming>SF_UT_T16_GW_G33</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G33_STD_GW_G08</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G33_ALT_UT_T55</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T55" name="Document Clinical Decision and Treatment Deviation">
      <bpmn:incoming>SF_GW_G33_ALT_UT_T55</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T55_GW_G08</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G08" name="Depression Severity Classification Outcome">
      <bpmn:incoming>SF_GW_G33_STD_GW_G08</bpmn:incoming>
      <bpmn:incoming>SF_UT_T55_GW_G08</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G08_SUBCLX_UT_T21</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G08_MILD_UT_T21</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G08_MOD_UT_T17</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G08_SEV_UT_T17</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ==================== PHASE 3: TREATMENT STEP 1 ==================== -->

    <bpmn:userTask id="UT_T21" name="Execute Active Monitoring (Watchful Waiting)">
      <bpmn:incoming>SF_GW_G08_SUBCLX_UT_T21</bpmn:incoming>
      <bpmn:incoming>SF_GW_G08_MILD_UT_T21</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T21_GW_G22</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G22" name="Patient Accepts Psychological Treatment?">
      <bpmn:incoming>SF_UT_T21_GW_G22</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G22_YES_GW_G25</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G22_NO_UT_T42</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_G25" name="Active Monitoring: Recovery Without Intervention Likely?">
      <bpmn:incoming>SF_GW_G22_YES_GW_G25</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G25_YES_UT_T41</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G25_NO_GW_G13</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_G13" name="Step 1 Treatment Response: Escalation to Step 2 Required?">
      <bpmn:incoming>SF_GW_G25_NO_GW_G13</bpmn:incoming>
      <bpmn:incoming>SF_UT_T41_GW_G13</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G13_ADEQUATE_UT_T41</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G13_ESCALATE_UT_T17</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T41" name="Schedule and Conduct Follow-Up Appointment">
      <bpmn:incoming>SF_GW_G25_YES_UT_T41</bpmn:incoming>
      <bpmn:incoming>SF_GW_G13_ADEQUATE_UT_T41</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T41_UT_T42</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T42" name="Monitor Symptom Progression Using Self-Rating Scales">
      <bpmn:incoming>SF_GW_G22_NO_UT_T42</bpmn:incoming>
      <bpmn:incoming>SF_UT_T41_UT_T42</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T42_UT_T43</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T43" name="Review Patient Self-Monitoring Records">
      <bpmn:incoming>SF_UT_T42_UT_T43</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T43_GW_G26</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G26" name="Symptom Worsening During Treatment Detected?">
      <bpmn:incoming>SF_UT_T43_GW_G26</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G26_WORSEN_GW_G06b</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G26_STABLE_GW_G13</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_G06b" name="Immediate Risk After Worsening?">
      <bpmn:incoming>SF_GW_G26_WORSEN_GW_G06b</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G06b_URGENT_UT_T49b</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G06b_NOURGENT_GW_G13</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T49b" name="Issue Urgent Referral to Specialized Mental Health Services (Worsening)">
      <bpmn:incoming>SF_GW_G06b_URGENT_UT_T49b</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T49b_EE_2b</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ==================== PHASE 3: TREATMENT STEP 2 ==================== -->

    <bpmn:userTask id="UT_T17" name="Formulate Multidisciplinary Treatment Plan - Steps 2-3">
      <bpmn:incoming>SF_GW_G08_MOD_UT_T17</bpmn:incoming>
      <bpmn:incoming>SF_GW_G08_SEV_UT_T17</bpmn:incoming>
      <bpmn:incoming>SF_GW_G13_ESCALATE_UT_T17</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T17_GW_G18</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G18" name="Pharmacotherapy Indicated at Step 2?">
      <bpmn:incoming>SF_UT_T17_GW_G18</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G18_YES_UT_T32</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G18_NO_GW_G21</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T32" name="Prescribe Pharmacotherapy (Antidepressants)">
      <bpmn:incoming>SF_GW_G18_YES_UT_T32</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T32_UT_T33</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T33" name="Administer Pharmacotherapy">
      <bpmn:incoming>SF_UT_T32_UT_T33</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T33_GW_G21</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G21" name="Patient Can Access In-Person Treatment?">
      <bpmn:incoming>SF_GW_G18_NO_GW_G21</bpmn:incoming>
      <bpmn:incoming>SF_UT_T33_GW_G21</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G21_YES_UT_T22</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G21_NO_UT_T24</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T22" name="Deliver Physical Activity Program">
      <bpmn:incoming>SF_GW_G21_YES_UT_T22</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T22_UT_T23</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T23" name="Deliver Group Mutual Support Program (Self-Help)">
      <bpmn:incoming>SF_UT_T22_UT_T23</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T23_GW_G14</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T24" name="Deliver Individual Guided CBT Self-Help Program">
      <bpmn:incoming>SF_GW_G21_NO_UT_T24</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T24_GW_G14</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G14" name="Step 2 Treatment Response: Escalation to Step 3 Required?">
      <bpmn:incoming>SF_UT_T23_GW_G14</bpmn:incoming>
      <bpmn:incoming>SF_UT_T24_GW_G14</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G14_ADEQUATE_UT_T44</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G14_ESCALATE_GW_G19</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ==================== PHASE 3: TREATMENT STEP 3 ==================== -->

    <bpmn:exclusiveGateway id="GW_G19" name="Group or Individual CBT at Step 3?">
      <bpmn:incoming>SF_GW_G14_ESCALATE_GW_G19</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G19_GROUP_UT_T26</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G19_MOD_UT_T27</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G19_SEV_UT_T28</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T26" name="Deliver Group CBT - High Intensity">
      <bpmn:incoming>SF_GW_G19_GROUP_UT_T26</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T26_GW_G20</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T27" name="Deliver Individual CBT - Moderate Depression">
      <bpmn:incoming>SF_GW_G19_MOD_UT_T27</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T27_GW_G20</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T28" name="Deliver Individual CBT - Severe Depression">
      <bpmn:incoming>SF_GW_G19_SEV_UT_T28</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T28_GW_G20</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G20" name="Couples Therapy Indicated?">
      <bpmn:incoming>SF_UT_T26_GW_G20</bpmn:incoming>
      <bpmn:incoming>SF_UT_T27_GW_G20</bpmn:incoming>
      <bpmn:incoming>SF_UT_T28_GW_G20</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G20_YES_UT_T31</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G20_NO_GW_G27</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T31" name="Deliver Couples / Pair Therapy">
      <bpmn:incoming>SF_GW_G20_YES_UT_T31</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T31_GW_G27</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G27" name="Post-CBT: Further Sessions Beneficial?">
      <bpmn:incoming>SF_GW_G20_NO_GW_G27</bpmn:incoming>
      <bpmn:incoming>SF_UT_T31_GW_G27</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G27_REMISSION_UT_T46</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G27_EXTEND_UT_T29</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G27_INSUF_GW_G15</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T29" name="Deliver Behavioral Activation Therapy">
      <bpmn:incoming>SF_GW_G27_EXTEND_UT_T29</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T29_UT_T30</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T30" name="Deliver Interpersonal Therapy (IPT)">
      <bpmn:incoming>SF_UT_T29_UT_T30</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T30_GW_G15</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G15" name="Severe Depression or Life Risk: Step 4 Required?">
      <bpmn:incoming>SF_GW_G27_INSUF_GW_G15</bpmn:incoming>
      <bpmn:incoming>SF_UT_T30_GW_G15</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G15_YES_UT_T39</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G15_NO_GW_G16</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ==================== PHASE 3: TREATMENT STEP 4 ==================== -->

    <bpmn:userTask id="UT_T39" name="Deliver Electroconvulsive Therapy (ECT)">
      <bpmn:incoming>SF_GW_G15_YES_UT_T39</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T39_UT_T40</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T40" name="Execute Crisis Intervention">
      <bpmn:incoming>SF_UT_T39_UT_T40</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T40_GW_G32</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G32" name="Hospitalization Required?">
      <bpmn:incoming>SF_UT_T40_GW_G32</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G32_YES_UT_T52</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G32_NO_GW_G29</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T52" name="Decide on and Execute Hospitalization">
