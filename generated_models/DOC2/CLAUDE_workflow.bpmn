      <bpmn:incoming>SF_UT_T52_GW_G29</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G29_YES_UT_T54</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G29_NO_GW_G30</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T54" name="Coordinate Care Between Primary and Secondary Services">
      <bpmn:incoming>SF_GW_G29_YES_UT_T54</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T54_GW_G30</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G30" name="Outpatient Psychological Care Required Post-Discharge?">
      <bpmn:incoming>SF_GW_G29_NO_GW_G30</bpmn:incoming>
      <bpmn:incoming>SF_UT_T54_GW_G30</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G30_YES_UT_T47b</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G30_NO_EE_3</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T47b" name="Issue Referral to Clinical Psychologist (Post-Discharge)">
      <bpmn:incoming>SF_GW_G30_YES_UT_T47b</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T47b_EE_3</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ==================== PHASE 4: MONITORING AND FOLLOW-UP ==================== -->

    <bpmn:userTask id="UT_T44" name="Conduct Quarterly Outcome Reassessment (Mood, Anxiety, Quality of Life)">
      <bpmn:incoming>SF_GW_G14_ADEQUATE_UT_T44</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T44_GW_G16</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T46" name="Conduct Post-Treatment Control Sessions (CBT Follow-Up)">
      <bpmn:incoming>SF_GW_G27_REMISSION_UT_T46</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T46_GW_G16</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G16" name="Treatment Duration Threshold Exceeded (3 Months)?">
