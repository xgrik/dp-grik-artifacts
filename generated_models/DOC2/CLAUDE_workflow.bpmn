      <bpmn:outgoing>SF_GW_G24_S2_UT_T36</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G24_S3_UT_T37</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G24_S4_UT_T38</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T36" name="Deliver Low-Intensity CBT - Cardiac Step 2 (Telephone)">
      <bpmn:incoming>SF_GW_G24_S2_UT_T36</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T36_EE_1c</bpmn:outgoing>
