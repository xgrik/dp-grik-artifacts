      <bpmn:outgoing>SF_UT_T47_GW_G04</bpmn:outgoing>
      <bpmn:outgoing>SF_UT_T47_UT_T08</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G04" name="Initiating Physician is Patient&#39;s Own GP?">
      <bpmn:incoming>SF_UT_T47_GW_G04</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G04_YES_EE_1</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G04_NO_UT_T50</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T50" name="Notify Patient&#39;s GP of Referral">
      <bpmn:incoming>SF_GW_G04_NO_UT_T50</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T50_EE_1</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T48" name="Issue Referral to Psychiatrist">
      <bpmn:incoming>SF_GW_G10_OTHER_UT_T48</bpmn:incoming>
      <bpmn:incoming>SF_GW_G31_PSYCHIAT_UT_T48</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T48_UT_T09</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T09" name="Conduct Psychiatric Examination">
      <bpmn:incoming>SF_UT_T48_UT_T09</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T09_EE_1</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ==================== E-HEALTH SUBPROCESS PATH ==================== -->

    <bpmn:userTask id="UT_T06" name="Complete Online Screening Questionnaire (E-Health Entry)">
      <bpmn:incoming>SF_SE_EH_UT_T06</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T06_ST_T07</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="ST_T07" name="Generate Personal Profile Chart (E-Health System)">
      <bpmn:incoming>SF_UT_T06_ST_T07</bpmn:incoming>
      <bpmn:outgoing>SF_ST_T07_GW_G05</bpmn:outgoing>
