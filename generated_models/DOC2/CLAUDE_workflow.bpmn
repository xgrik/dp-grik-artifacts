    <bpmn:exclusiveGateway id="GW_G05" name="E-Health Risk Profile Classification">
      <bpmn:incoming>SF_ST_T07_GW_G05</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G05_RISK_UT_T53</bpmn:outgoing>
      <bpmn:outgoing>SF_GW_G05_NORISK_EE_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="UT_T53" name="Execute Extended Screening - E-Health Elevated Risk">">
      <bpmn:incoming>SF_GW_G05_RISK_UT_T53</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T53_UT_T25</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T25" name="Deliver Computer-Based iCBT (Supervised by Clinical Psychologist)">
      <bpmn:incoming>SF_UT_T53_UT_T25</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T25_ST_T45</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="ST_T45" name="Execute Follow-Up Monitoring and Progress Visualization (E-Health System)">
      <bpmn:incoming>SF_UT_T25_ST_T45</bpmn:incoming>
      <bpmn:outgoing>SF_ST_T45_EE_4</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ==================== CARDIAC CBT SUBPROCESS PATH ==================== -->

    <bpmn:userTask id="UT_T34" name="Deliver Psychoeducation - CBT Cardiac Model Step 1">
      <bpmn:incoming>SF_SE_CAR_UT_T34</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T34_UT_T35</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UT_T35" name="Conduct Initial Psychological Assessment - Cardiac CBT Model">
      <bpmn:incoming>SF_UT_T34_UT_T35</bpmn:incoming>
      <bpmn:outgoing>SF_UT_T35_GW_G23</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_G23" name="Patient Suitable for Current Cardiac CBT Step?">
      <bpmn:incoming>SF_UT_T35_GW_G23</bpmn:incoming>
      <bpmn:outgoing>SF_GW_G23_YES_GW_G24</bpmn:outgoing>
