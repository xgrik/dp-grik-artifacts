    <bpmn:endEvent id="EE_2b" name="Process Terminated - Urgent Referral Issued (Worsening)">
      <bpmn:incoming>SF_UT_T49b_EE_2b</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EE_3" name="Process Completed - Hospitalization Pathway Concluded">
      <bpmn:incoming>SF_GW_G30_NO_EE_3</bpmn:incoming>
