    <bpmn:endEvent id="EE_4" name="Process Completed - E-Health Pathway Concluded">
      <bpmn:incoming>SF_GW_G05_NORISK_EE_4</bpmn:incoming>
      <bpmn:incoming>SF_ST_T45_EE_4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EE_5" name="Process Completed - No Psychological Comorbidity Detected">
      <bpmn:incoming>SF_GW_G01_NO_EE_5</bpmn:incoming>
      <bpmn:incoming>SF_GW_G03_NO_EE_5</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EE_1b" name="Process Completed - Cardiac Patient Referred to Alternative Service">
      <bpmn:incoming>SF_GW_G23_NO_EE_1b</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EE_1c" name="Process Completed - Cardiac CBT Pathway Concluded">
      <bpmn:incoming>SF_UT_T36_EE_1c</bpmn:incoming>
      <bpmn:incoming>SF_UT_T37_EE_1c</bpmn:incoming>
      <bpmn:incoming>SF_UT_T38_EE_1c</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Additional start events for sub-paths -->
    <bpmn:startEvent id="SE_EH" name="Patient Enters E-Health Care Pathway">
      <bpmn:outgoing>SF_SE_EH_UT_T06</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:startEvent id="SE_CAR" name="Cardiac Patient Enters CBT Pathway">
      <bpmn:outgoing>SF_SE_CAR_UT_T34</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ==================== SEQUENCE FLOWS ==================== -->

    <!-- Phase 0 flows -->
    <bpmn:sequenceFlow id="SF_SE1_UT_T01" sourceRef="SE_1" targetRef="UT_T01" />
    <bpmn:sequenceFlow id="SF_UT_T01_UT_T02" sourceRef="UT_T01" targetRef="UT_T02" />
    <bpmn:sequenceFlow id="SF_UT_T02_GW_G01" sourceRef="UT_T02" targetRef="GW_G01" />
    <bpmn:sequenceFlow id="SF_GW_G01_YES_UT_T03" name="Yes - At least one positive response" sourceRef="GW_G01" targetRef="UT_T03" />
    <bpmn:sequenceFlow id="SF_GW_G01_NO_EE_5" name="No - All responses negative" sourceRef="GW_G01" targetRef="EE_5" />
    <bpmn:sequenceFlow id="SF_UT_T03_GW_G03" sourceRef="UT_T03" targetRef="GW_G03" />
    <bpmn:sequenceFlow id="SF_GW_G03_YES_GW_G02" name="Yes - Positive on at least one question" sourceRef="GW_G03" targetRef="GW_G02" />
    <bpmn:sequenceFlow id="SF_GW_G03_NO_EE_5" name="No - Negative on both questions" sourceRef="GW_G03" targetRef="EE_5" />
    <bpmn:sequenceFlow id="SF_GW_G02_YES_UT_T04" name="Yes - GP competent to assess" sourceRef="GW_G02" targetRef="UT_T04" />
    <bpmn:sequenceFlow id="SF_GW_G02_NO_UT_T47" name="No - GP not competent; refer directly" sourceRef="GW_G02" targetRef="UT_T47" />
    <bpmn:sequenceFlow id="SF_UT_T04_UT_T08" sourceRef="UT_T04" targetRef="UT_T08" />

    <!-- Phase 1 flows -->
    <bpmn:sequenceFlow id="SF_UT_T47_UT_T08" sourceRef="UT_T47" targetRef="UT_T08" />
    <bpmn:sequenceFlow id="SF_UT_T08_UT_T05" sourceRef="UT_T08" targetRef="UT_T05" />
    <bpmn:sequenceFlow id="SF_UT_T05_UT_T10" sourceRef="UT_T05" targetRef="UT_T10" />
    <bpmn:sequenceFlow id="SF_UT_T10_UT_T11" sourceRef="UT_T10" targetRef="UT_T11" />
    <bpmn:sequenceFlow id="SF_UT_T11_GW_G06" sourceRef="UT_T11" targetRef="GW_G06" />
    <bpmn:sequenceFlow id="SF_GW_G06_YES_UT_T49" name="Yes - Immediate risk; urgent referral required" sourceRef="GW_G06" targetRef="UT_T49" />
    <bpmn:sequenceFlow id="SF_GW_G06_NO_GW_G07" name="No - No immediate risk; proceed to risk grading" sourceRef="GW_G06" targetRef="GW_G07" />
    <bpmn:sequenceFlow id="SF_UT_T49_EE_2" sourceRef="UT_T49" targetRef="EE_2" />
    <bpmn:sequenceFlow id="SF_GW_G07_HIGH_UT_T12" name="High suicidal risk - limit medication access and increase monitoring" sourceRef="GW_G07" targetRef="UT_T12" />
    <bpmn:sequenceFlow id="SF_GW_G07_LOW_UT_T12b" name="Low or moderate suicidal risk - continue standard assessment" sourceRef="GW_G07" targetRef="UT_T12b" />
    <bpmn:sequenceFlow id="SF_UT_T12_GW_G10" sourceRef="UT_T12" targetRef="GW_G10" />
    <bpmn:sequenceFlow id="SF_UT_T12b_GW_G10" sourceRef="UT_T12b" targetRef="GW_G10" />
    <bpmn:sequenceFlow id="SF_GW_G10_ADJUST_UT_T13" name="Adjustment disorder F43.2 - reaction to illness" sourceRef="GW_G10" targetRef="UT_T13" />
    <bpmn:sequenceFlow id="SF_GW_G10_DEP_UT_T13" name="Depressive disorder - threshold criteria met" sourceRef="GW_G10" targetRef="UT_T13" />
    <bpmn:sequenceFlow id="SF_GW_G10_OTHER_UT_T48" name="Other serious mental disorder - psychiatric referral required" sourceRef="GW_G10" targetRef="UT_T48" />
    <bpmn:sequenceFlow id="SF_UT_T13_GW_G11" sourceRef="UT_T13" targetRef="GW_G11" />
    <bpmn:sequenceFlow id="SF_GW_G11_YES_BRT_T14" name="Yes - Dual diagnosis warranted; both conditions treated independently" sourceRef="GW_G11" targetRef="BRT_T14" />
    <bpmn:sequenceFlow id="SF_GW_G11_NO_BRT_T14" name="No - Single primary diagnosis sufficient" sourceRef="GW_G11" targetRef="BRT_T14" />
    <bpmn:sequenceFlow id="SF_BRT_T14_GW_G12" sourceRef="BRT_T14" targetRef="GW_G12" />
    <bpmn:sequenceFlow id="SF_GW_G12_YES_UT_T15" name="Yes - Consult specialist and adapt intervention modality" sourceRef="GW_G12" targetRef="UT_T15" />
    <bpmn:sequenceFlow id="SF_GW_G12_NO_UT_T15b" name="No - Standard assessment approach applies" sourceRef="GW_G12" targetRef="UT_T15b" />
    <bpmn:sequenceFlow id="SF_UT_T15_GW_G09" sourceRef="UT_T15" targetRef="GW_G09" />
    <bpmn:sequenceFlow id="SF_UT_T15b_GW_G09" sourceRef="UT_T15b" targetRef="GW_G09" />
    <bpmn:sequenceFlow id="SF_GW_G09_DEP_ANXI_UT_T19" name="Anxiety disorder primary - prioritize anxiety treatment" sourceRef="GW_G09" targetRef="UT_T19" />
    <bpmn:sequenceFlow id="SF_GW_G09_DEP_ONLY_UT_T19" name="Depression only - standard depression treatment pathway" sourceRef="GW_G09" targetRef="UT_T19" />

    <!-- Phase 2 flows -->
    <bpmn:sequenceFlow id="SF_UT_T19_UT_T18" sourceRef="UT_T19" targetRef="UT_T18" />
    <bpmn:sequenceFlow id="SF_UT_T18_UT_T20" sourceRef="UT_T18" targetRef="UT_T20" />
    <bpmn:sequenceFlow id="SF_UT_T20_GW_G28" sourceRef="UT_T20" targetRef="GW_G28" />
    <bpmn:sequenceFlow id="SF_GW_G28_YES_UT_T56" name="Yes - Family or caregiver involved in patient support" sourceRef="GW_G28" targetRef="UT_T56" />
    <bpmn:sequenceFlow id="SF_GW_G28_NO_UT_T16" name="No - No family or caregiver involvement" sourceRef="GW_G28" targetRef="UT_T16" />
    <bpmn:sequenceFlow id="SF_UT_T56_UT_T57" sourceRef="UT_T56" targetRef="UT_T57" />
    <bpmn:sequenceFlow id="SF_UT_T57_UT_T16" sourceRef="UT_T57" targetRef="UT_T16" />
    <bpmn:sequenceFlow id="SF_UT_T16_GW_G33" sourceRef="UT_T16" targetRef="GW_G33" />
    <bpmn:sequenceFlow id="SF_GW_G33_STD_GW_G08" name="Standard procedure applicable - follow stepped-care pathway" sourceRef="GW_G33" targetRef="GW_G08" />
    <bpmn:sequenceFlow id="SF_GW_G33_ALT_UT_T55" name="Alternative approach required - document clinical deviation" sourceRef="GW_G33" targetRef="UT_T55" />
    <bpmn:sequenceFlow id="SF_UT_T55_GW_G08" sourceRef="UT_T55" targetRef="GW_G08" />
    <bpmn:sequenceFlow id="SF_GW_G08_SUBCLX_UT_T21" name="Subclinical symptoms - active monitoring at Step 1" sourceRef="GW_G08" targetRef="UT_T21" />
