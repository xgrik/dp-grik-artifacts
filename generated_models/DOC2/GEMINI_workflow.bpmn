<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_1bdj0sq" targetNamespace="http://bpmn.io/schema/bpmn" xmlns:modeler="http://camunda.org/schema/modeler/1.0" exporter="Camunda Modeler" exporterVersion="5.33.1" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.22.0">
  <bpmn:process id="Process_1wlyh5l" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Somatic Patient Identified">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    
    <bpmn:userTask id="UT_InitialScreening" name="Initial Screening for Psychosocial Symptoms">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:exclusiveGateway id="GW_ScreeningResult" name="Screening Result Check">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_NoSymptoms</bpmn:outgoing>
      <bpmn:outgoing>Flow_SymptomsSuspected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:endEvent id="EndEvent_NoSymptoms" name="Routine Monitoring">
      <bpmn:incoming>Flow_NoSymptoms</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:userTask id="UT_DiagnosticInterview" name="Diagnostic Interview and Anamnesis">
      <bpmn:incoming>Flow_SymptomsSuspected</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:exclusiveGateway id="GW_UrgencyCheck" name="Clinical Urgency Check">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Urgent</bpmn:outgoing>
      <bpmn:outgoing>Flow_Routine</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:endEvent id="EndEvent_Emergency" name="Immediate Psychiatric Referral">
      <bpmn:incoming>Flow_Urgent</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:userTask id="UT_PatientEducation" name="Patient Education and Clarification">
      <bpmn:incoming>Flow_Routine</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:userTask id="UT_GoalSetting" name="Goal Setting and Treatment Planning">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:userTask id="UT_ProgressMonitoring" name="Progress Monitoring and Evaluation">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:exclusiveGateway id="GW_EfficacyStage1" name="Efficacy Assessment (Stage 1)">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_S1Success</bpmn:outgoing>
      <bpmn:outgoing>Flow_S1Escalate</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:endEvent id="EndEvent_S1Success" name="Continue or Terminate Stage 1">
      <bpmn:incoming>Flow_S1Success</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:userTask id="UT_ClinicalPsychExam" name="Clinical-Psychological Examination">
      <bpmn:incoming>Flow_S1Escalate</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:exclusiveGateway id="GW_Suitability" name="Patient Suitability Assessment">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_NotSuitable</bpmn:outgoing>
      <bpmn:outgoing>Flow_Suitable</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:endEvent id="EndEvent_NotSuitable" name="Redirect to Other Services">
      <bpmn:incoming>Flow_NotSuitable</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:userTask id="UT_PsychiatricExam" name="Psychiatric Examination and Pharmacotherapy">
      <bpmn:incoming>Flow_Suitable</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:userTask id="UT_SpecificIntervention" name="Execution of Specific Intervention">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:exclusiveGateway id="GW_EfficacyStage2" name="Efficacy Assessment (Stage 2)">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_S2Success</bpmn:outgoing>
      <bpmn:outgoing>Flow_S2Escalate</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:endEvent id="EndEvent_S2Success" name="Condition Stabilized">
      <bpmn:incoming>Flow_S2Success</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:userTask id="UT_ReferralMultiCenter" name="Referral to Multidisciplinary Center">
      <bpmn:incoming>Flow_S2Escalate</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:endEvent id="EndEvent_Stage3" name="Stage 3 Care Initiated">
      <bpmn:incoming>Flow_10</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="UT_InitialScreening" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UT_InitialScreening" targetRef="GW_ScreeningResult" />
    <bpmn:sequenceFlow id="Flow_NoSymptoms" name="Symptoms &#60; 5" sourceRef="GW_ScreeningResult" targetRef="EndEvent_NoSymptoms" />
    <bpmn:sequenceFlow id="Flow_SymptomsSuspected" name="Symptoms &#62;= 5" sourceRef="GW_ScreeningResult" targetRef="UT_DiagnosticInterview" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="UT_DiagnosticInterview" targetRef="GW_UrgencyCheck" />
    <bpmn:sequenceFlow id="Flow_Urgent" name="Suicidal ideation or psychosis" sourceRef="GW_UrgencyCheck" targetRef="EndEvent_Emergency" />
    <bpmn:sequenceFlow id="Flow_Routine" name="Routine case" sourceRef="GW_UrgencyCheck" targetRef="UT_PatientEducation" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="UT_PatientEducation" targetRef="UT_GoalSetting" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="UT_GoalSetting" targetRef="UT_ProgressMonitoring" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="UT_ProgressMonitoring" targetRef="GW_EfficacyStage1" />
    <bpmn:sequenceFlow id="Flow_S1Success" name="Condition improved" sourceRef="GW_EfficacyStage1" targetRef="EndEvent_S1Success" />
    <bpmn:sequenceFlow id="Flow_S1Escalate" name="No improvement after 4-6 weeks" sourceRef="GW_EfficacyStage1" targetRef="UT_ClinicalPsychExam" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="UT_ClinicalPsychExam" targetRef="GW_Suitability" />
    <bpmn:sequenceFlow id="Flow_NotSuitable" name="Not suitable" sourceRef="GW_Suitability" targetRef="EndEvent_NotSuitable" />
    <bpmn:sequenceFlow id="Flow_Suitable" name="Suitable for intervention" sourceRef="GW_Suitability" targetRef="UT_PsychiatricExam" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="UT_PsychiatricExam" targetRef="UT_SpecificIntervention" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="UT_SpecificIntervention" targetRef="GW_EfficacyStage2" />
    <bpmn:sequenceFlow id="Flow_S2Success" name="Treatment goals met" sourceRef="GW_EfficacyStage2" targetRef="EndEvent_S2Success" />
    <bpmn:sequenceFlow id="Flow_S2Escalate" name="Chronic case / &#62;3 months" sourceRef="GW_EfficacyStage2" targetRef="UT_ReferralMultiCenter" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="UT_ReferralMultiCenter" targetRef="EndEvent_Stage3" />
  </bpmn:process>

