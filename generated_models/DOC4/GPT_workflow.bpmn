    <bpmn:sequenceFlow id="Flow_29" sourceRef="UserTask_TraumaPsychotherapy" targetRef="Gateway_PharmIndicated" />
    <bpmn:sequenceFlow id="Flow_31" name="Pharmacotherapy indicated" sourceRef="Gateway_PharmIndicated" targetRef="UserTask_PharmTreatment" />
    <bpmn:sequenceFlow id="Flow_32" name="No pharmacotherapy" sourceRef="Gateway_PharmIndicated" targetRef="ServiceTask_MonitorOutcomes" />
    <bpmn:sequenceFlow id="Flow_33" sourceRef="UserTask_PharmTreatment" targetRef="ServiceTask_MonitorOutcomes" />

    <bpmn:sequenceFlow id="Flow_34" sourceRef="ServiceTask_MonitorOutcomes" targetRef="UserTask_ReassessEffectiveness" />
    <bpmn:sequenceFlow id="Flow_35" sourceRef="UserTask_ReassessEffectiveness" targetRef="Gateway_TreatmentEffective" />
    <bpmn:sequenceFlow id="Flow_36" name="Effective" sourceRef="Gateway_TreatmentEffective" targetRef="Gateway_Remission" />
    <bpmn:sequenceFlow id="Flow_37" name="Not effective" sourceRef="Gateway_TreatmentEffective" targetRef="UserTask_DecideStrategy" />

    <bpmn:sequenceFlow id="Flow_38" name="Stabilization / remission achieved" sourceRef="Gateway_Remission" targetRef="UserTask_Discharge" />
    <bpmn:sequenceFlow id="Flow_39" name="Not yet stabilized" sourceRef="Gateway_Remission" targetRef="ServiceTask_MonitorOutcomes" />

    <bpmn:sequenceFlow id="Flow_40" sourceRef="UserTask_Discharge" targetRef="EndEvent_CareCompleted" />

