    <bpmn:sequenceFlow id="Flow_25" sourceRef="UserTask_ActiveMonitoring" targetRef="ServiceTask_MonitorOutcomes" />

    <bpmn:sequenceFlow id="Flow_26" sourceRef="UserTask_DecideStrategy" targetRef="Gateway_PsychotherapyIndicated" />
