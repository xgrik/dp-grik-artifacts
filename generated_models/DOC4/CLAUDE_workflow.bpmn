<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_07bsiln"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
                  exporter="Camunda Modeler"
                  exporterVersion="5.33.1"
                  modeler:executionPlatform="Camunda Platform"
                  modeler:executionPlatformVersion="7.22.0">

  <bpmn:process id="Process_1t103nq" isExecutable="true" name="PTSD Clinical Management Process">

    <!-- ==================== START EVENT ==================== -->
    <bpmn:startEvent id="StartEvent_1" name="Patient Contact / Post-Trauma Presentation">
      <bpmn:outgoing>Flow_start_g04</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ==================== G-04: MASS CASUALTY CONTEXT ==================== -->
    <bpmn:exclusiveGateway id="G04" name="Mass Casualty / Refugee Context?">
      <bpmn:incoming>Flow_start_g04</bpmn:incoming>
      <bpmn:outgoing>Flow_g04_yes_t04</bpmn:outgoing>
      <bpmn:outgoing>Flow_g04_no_t01</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-04: Mass Casualty Screening -->
    <bpmn:userTask id="T04" name="Conduct Mass Casualty / Refugee PTSD Screening">
      <bpmn:incoming>Flow_g04_yes_t04</bpmn:incoming>
      <bpmn:outgoing>Flow_t04_t01</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-01: Post-Trauma Risk Assessment -->
    <bpmn:userTask id="T01" name="Perform Initial Post-Trauma Risk Assessment">
      <bpmn:incoming>Flow_g04_no_t01</bpmn:incoming>
      <bpmn:incoming>Flow_t04_t01</bpmn:incoming>
      <bpmn:outgoing>Flow_t01_t06</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-06: Sensitive Trauma Inquiry -->
    <bpmn:userTask id="T06" name="Ask Sensitive Screening Questions About Traumatic Events">
      <bpmn:incoming>Flow_t01_t06</bpmn:incoming>
      <bpmn:outgoing>Flow_t06_t05</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-05: MACSCREEN -->
    <bpmn:userTask id="T05" name="Administer MACSCREEN Orientational Screening Questionnaire">
      <bpmn:incoming>Flow_t06_t05</bpmn:incoming>
      <bpmn:outgoing>Flow_t05_g01</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-01: Trauma Exposure Confirmed? -->
    <bpmn:exclusiveGateway id="G01" name="Trauma Exposure Confirmed?">
      <bpmn:incoming>Flow_t05_g01</bpmn:incoming>
      <bpmn:outgoing>Flow_g01_no_end1</bpmn:outgoing>
      <bpmn:outgoing>Flow_g01_yes_g02</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- End: No Trauma -->
    <bpmn:endEvent id="EndEvent_NoTrauma" name="No Trauma Exposure Identified - Exit PTSD Pathway">
      <bpmn:incoming>Flow_g01_no_end1</bpmn:incoming>
    </bpmn:endEvent>

    <!-- G-02: Re-experiencing Symptoms Present? -->
    <bpmn:exclusiveGateway id="G02" name="Re-Experiencing Symptoms Present?">
      <bpmn:incoming>Flow_g01_yes_g02</bpmn:incoming>
      <bpmn:outgoing>Flow_g02_no_g03</bpmn:outgoing>
      <bpmn:outgoing>Flow_g02_yes_t08</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- G-03: Mild Symptoms < 4 Weeks? -->
    <bpmn:exclusiveGateway id="G03" name="Symptoms Mild AND Present Less Than 4 Weeks?">
      <bpmn:incoming>Flow_g02_no_g03</bpmn:incoming>
      <bpmn:outgoing>Flow_g03_yes_t09</bpmn:outgoing>
      <bpmn:outgoing>Flow_g03_no_t08</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-09: Active Monitoring -->
    <bpmn:userTask id="T09" name="Implement Active Monitoring">
      <bpmn:incoming>Flow_g03_yes_t09</bpmn:incoming>
      <bpmn:outgoing>Flow_t09_t10</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-10: Immediate Practical Support -->
    <bpmn:userTask id="T10" name="Provide Immediate Practical, Social and Emotional Support">
      <bpmn:incoming>Flow_t09_t10</bpmn:incoming>
      <bpmn:incoming>Flow_t02_t10</bpmn:incoming>
      <bpmn:outgoing>Flow_t10_t02</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-02: Post-Trauma Screening -->
    <bpmn:userTask id="T02" name="Administer Post-Trauma Screening for Symptomatic Individuals">
      <bpmn:incoming>Flow_t10_t02</bpmn:incoming>
      <bpmn:outgoing>Flow_t02_g02b</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G02b: Re-check after monitoring -->
    <bpmn:exclusiveGateway id="G02b" name="Symptoms Developed or Worsened?">
      <bpmn:incoming>Flow_t02_g02b</bpmn:incoming>
      <bpmn:outgoing>Flow_g02b_yes_t08</bpmn:outgoing>
      <bpmn:outgoing>Flow_g02b_no_t03</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-03: Preventive KBT -->
    <bpmn:userTask id="T03" name="Deliver Trauma-Focused KBT for Prevention of Chronic PTSD">
      <bpmn:incoming>Flow_g02b_no_t03</bpmn:incoming>
      <bpmn:outgoing>Flow_t03_endprev</bpmn:outgoing>
    </bpmn:userTask>

    <!-- End: Prevention Complete -->
    <bpmn:endEvent id="EndEvent_Prevention" name="Preventive Intervention Completed - Monitor">
      <bpmn:incoming>Flow_t03_endprev</bpmn:incoming>
    </bpmn:endEvent>

    <!-- T-08: Specialist Referral -->
    <bpmn:userTask id="T08" name="Issue Referral to Specialist - Psychiatry or Clinical Psychology">
      <bpmn:incoming>Flow_g02_yes_t08</bpmn:incoming>
      <bpmn:incoming>Flow_g03_no_t08</bpmn:incoming>
      <bpmn:incoming>Flow_g02b_yes_t08</bpmn:incoming>
      <bpmn:outgoing>Flow_t08_t07</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-07: Hospital PTSD Identification -->
    <bpmn:userTask id="T07" name="Identify PTSD Indicators in Hospital Setting">
      <bpmn:incoming>Flow_t08_t07</bpmn:incoming>
      <bpmn:outgoing>Flow_t07_t11</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ==================== PHASE 3: DIAGNOSTIC WORKUP ==================== -->

    <!-- T-11: Psychiatric Examination -->
    <bpmn:userTask id="T11" name="Perform Psychiatric Examination">
      <bpmn:incoming>Flow_t07_t11</bpmn:incoming>
      <bpmn:outgoing>Flow_t11_t12</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-12: Somatic Examination -->
    <bpmn:userTask id="T12" name="Perform Somatic Examination to Exclude Organic Causes">
      <bpmn:incoming>Flow_t11_t12</bpmn:incoming>
      <bpmn:outgoing>Flow_t12_g10</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-10: Head Injury? -->
    <bpmn:exclusiveGateway id="G10" name="Head Injury or Physical Trauma Involved?">
      <bpmn:incoming>Flow_t12_g10</bpmn:incoming>
      <bpmn:outgoing>Flow_g10_yes_t12b</bpmn:outgoing>
      <bpmn:outgoing>Flow_g10_no_g06</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-12b: Neurological Examination -->
    <bpmn:userTask id="T12b" name="Perform Detailed Neurological and Somatic Examination">
      <bpmn:incoming>Flow_g10_yes_t12b</bpmn:incoming>
      <bpmn:outgoing>Flow_t12b_g06</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-06: Somatic Cause Excluded? -->
    <bpmn:exclusiveGateway id="G06" name="Somatic / Organic Cause Excluded?">
      <bpmn:incoming>Flow_g10_no_g06</bpmn:incoming>
      <bpmn:incoming>Flow_t12b_g06</bpmn:incoming>
      <bpmn:outgoing>Flow_g06_no_endsomatic</bpmn:outgoing>
      <bpmn:outgoing>Flow_g06_yes_t13</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- End: Organic Cause -->
    <bpmn:endEvent id="EndEvent_OrganicCause" name="Organic Cause Identified - Refer to Somatic Specialist">
      <bpmn:incoming>Flow_g06_no_endsomatic</bpmn:incoming>
    </bpmn:endEvent>

    <!-- T-13: Trauma Event History -->
    <bpmn:userTask id="T13" name="Compile Trauma Event History - Traumatic Events List">
      <bpmn:incoming>Flow_g06_yes_t13</bpmn:incoming>
      <bpmn:outgoing>Flow_t13_t14</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-14: LEC-5-SK -->
    <bpmn:userTask id="T14" name="Administer LEC-5-SK Trauma Checklist">
      <bpmn:incoming>Flow_t13_t14</bpmn:incoming>
      <bpmn:outgoing>Flow_t14_t15</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-15: PCL-5-SK -->
    <bpmn:userTask id="T15" name="Administer PCL-5-SK PTSD Symptom Scale">
      <bpmn:incoming>Flow_t14_t15</bpmn:incoming>
      <bpmn:outgoing>Flow_t15_t16</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-16: PHQ-9-SK -->
    <bpmn:userTask id="T16" name="Administer PHQ-9-SK Depression Screening Questionnaire">
      <bpmn:incoming>Flow_t15_t16</bpmn:incoming>
      <bpmn:outgoing>Flow_t16_t17</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-17: GAD-7-SK -->
    <bpmn:userTask id="T17" name="Administer GAD-7-SK Anxiety Screening Questionnaire">
      <bpmn:incoming>Flow_t16_t17</bpmn:incoming>
      <bpmn:outgoing>Flow_t17_t18</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-18: CORE-OM Baseline -->
    <bpmn:userTask id="T18" name="Administer CORE-OM Baseline Outcome Measurement">
      <bpmn:incoming>Flow_t17_t18</bpmn:incoming>
      <bpmn:outgoing>Flow_t18_g09</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-09: Complex Psychodiagnostics Indicated? -->
    <bpmn:exclusiveGateway id="G09" name="Complex Psychodiagnostic Examination Indicated?">
      <bpmn:incoming>Flow_t18_g09</bpmn:incoming>
      <bpmn:outgoing>Flow_g09_yes_t19</bpmn:outgoing>
      <bpmn:outgoing>Flow_g09_no_t20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-19: Complex Psychodiagnostics -->
    <bpmn:userTask id="T19" name="Perform Complex Psychodiagnostic Examination with Projective Methods">
      <bpmn:incoming>Flow_g09_yes_t19</bpmn:incoming>
      <bpmn:outgoing>Flow_t19_t20</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-20: Psychophysiological Examination -->
    <bpmn:userTask id="T20" name="Perform Psychophysiological Examination for Arousal Assessment">
      <bpmn:incoming>Flow_g09_no_t20</bpmn:incoming>
      <bpmn:incoming>Flow_t19_t20</bpmn:incoming>
      <bpmn:outgoing>Flow_t20_t25</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-25: Symptom Profile Assessment -->
    <bpmn:userTask id="T25" name="Assess Nature, Intensity and Duration of PTSD Symptoms">
      <bpmn:incoming>Flow_t20_t25</bpmn:incoming>
      <bpmn:outgoing>Flow_t25_t21</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-21: Differential Diagnosis -->
    <bpmn:userTask id="T21" name="Conduct Differential Diagnosis Assessment">
      <bpmn:incoming>Flow_t25_t21</bpmn:incoming>
      <bpmn:outgoing>Flow_t21_g07</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-07: Alternative Diagnosis Better? -->
    <bpmn:exclusiveGateway id="G07" name="Alternative Diagnosis Explains Symptoms Better?">
      <bpmn:incoming>Flow_t21_g07</bpmn:incoming>
      <bpmn:outgoing>Flow_g07_yes_endalt</bpmn:outgoing>
      <bpmn:outgoing>Flow_g07_no_t22</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- End: Alternative Diagnosis -->
    <bpmn:endEvent id="EndEvent_AltDx" name="Alternative Diagnosis Confirmed - Exit PTSD Pathway">
      <bpmn:incoming>Flow_g07_yes_endalt</bpmn:incoming>
    </bpmn:endEvent>

    <!-- T-22: Comorbidity Assessment -->
    <bpmn:userTask id="T22" name="Assess Comorbid Psychiatric Disorders">
      <bpmn:incoming>Flow_g07_no_t22</bpmn:incoming>
      <bpmn:outgoing>Flow_t22_t23</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-23: Risk Assessment -->
    <bpmn:userTask id="T23" name="Assess Suicide, Self-Harm and Aggression Risk">
      <bpmn:incoming>Flow_t22_t23</bpmn:incoming>
      <bpmn:outgoing>Flow_t23_t24</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-24: Confirm PTSD Diagnosis -->
    <bpmn:businessRuleTask id="T24" name="Confirm PTSD Diagnosis Against ICD-10 Criteria A-E">
      <bpmn:incoming>Flow_t23_t24</bpmn:incoming>
      <bpmn:outgoing>Flow_t24_g05</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <!-- G-05: Full ICD-10 Criteria Met? -->
    <bpmn:exclusiveGateway id="G05" name="Full ICD-10 PTSD Criteria A-E Satisfied?">
      <bpmn:incoming>Flow_t24_g05</bpmn:incoming>
      <bpmn:outgoing>Flow_g05_no_endnodiag</bpmn:outgoing>
      <bpmn:outgoing>Flow_g05_yes_t31</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- End: Criteria Not Met -->
    <bpmn:endEvent id="EndEvent_NoDiag" name="PTSD Criteria Not Met - Manage Under Appropriate Diagnosis">
      <bpmn:incoming>Flow_g05_no_endnodiag</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ==================== PHASE 4: TREATMENT PLANNING ==================== -->

    <!-- T-31: Language / Cultural Assessment -->
    <bpmn:userTask id="T31" name="Assess Language and Cultural Needs of Patient">
      <bpmn:incoming>Flow_g05_yes_t31</bpmn:incoming>
      <bpmn:outgoing>Flow_t31_g23</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-23: Language Barrier? -->
    <bpmn:exclusiveGateway id="G23" name="Language or Cultural Barrier Present?">
      <bpmn:incoming>Flow_t31_g23</bpmn:incoming>
      <bpmn:outgoing>Flow_g23_yes_t31b</bpmn:outgoing>
      <bpmn:outgoing>Flow_g23_no_t30</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-31b: Arrange Interpreter -->
    <bpmn:userTask id="T31b" name="Arrange Interpreter or Refer to Bicultural Therapist">
      <bpmn:incoming>Flow_g23_yes_t31b</bpmn:incoming>
      <bpmn:outgoing>Flow_t31b_t30</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-30: Psychoeducation -->
    <bpmn:userTask id="T30" name="Provide Psychoeducation to Patient and Family - Verbal and Written">
      <bpmn:incoming>Flow_g23_no_t30</bpmn:incoming>
      <bpmn:incoming>Flow_t31b_t30</bpmn:incoming>
      <bpmn:outgoing>Flow_t30_t26</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-26: Informed Consent -->
    <bpmn:userTask id="T26" name="Obtain Informed Consent for PTSD Treatment">
      <bpmn:incoming>Flow_t30_t26</bpmn:incoming>
      <bpmn:outgoing>Flow_t26_g12</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-12: Consent Given? -->
    <bpmn:exclusiveGateway id="G12" name="Patient Provides Informed Consent?">
      <bpmn:incoming>Flow_t26_g12</bpmn:incoming>
      <bpmn:outgoing>Flow_g12_no_endnoconsent</bpmn:outgoing>
      <bpmn:outgoing>Flow_g12_yes_t27</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- End: No Consent -->
    <bpmn:endEvent id="EndEvent_NoConsent" name="Consent Refused - Treatment Deferred">
      <bpmn:incoming>Flow_g12_no_endnoconsent</bpmn:incoming>
    </bpmn:endEvent>

    <!-- T-27: Elicit Patient Preferences -->
    <bpmn:userTask id="T27" name="Elicit Patient Treatment Preferences">
      <bpmn:incoming>Flow_g12_yes_t27</bpmn:incoming>
      <bpmn:outgoing>Flow_t27_g11</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-11: High Risk? -->
    <bpmn:exclusiveGateway id="G11" name="Patient at High Risk of Self-Harm or Harm to Others?">
      <bpmn:incoming>Flow_t27_g11</bpmn:incoming>
      <bpmn:outgoing>Flow_g11_yes_t29</bpmn:outgoing>
      <bpmn:outgoing>Flow_g11_no_t28</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-29: Risk Management Plan -->
    <bpmn:userTask id="T29" name="Develop Risk Management Plan for High-Risk Patient">
      <bpmn:incoming>Flow_g11_yes_t29</bpmn:incoming>
      <bpmn:outgoing>Flow_t29_t28</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-28: Individual Treatment Plan -->
    <bpmn:userTask id="T28" name="Develop Individual Treatment Plan">
      <bpmn:incoming>Flow_g11_no_t28</bpmn:incoming>
      <bpmn:incoming>Flow_t29_t28</bpmn:incoming>
      <bpmn:outgoing>Flow_t28_g08</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-08: Comorbidities Present? -->
    <bpmn:exclusiveGateway id="G08" name="Significant Comorbid Disorders Present?">
      <bpmn:incoming>Flow_t28_g08</bpmn:incoming>
      <bpmn:outgoing>Flow_g08_yes_g16</bpmn:outgoing>
      <bpmn:outgoing>Flow_g08_no_g13</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- G-16: Pharmacotherapy Indicated? -->
    <bpmn:exclusiveGateway id="G16" name="Pharmacotherapy Indicated as Primary or Augmentation?">
      <bpmn:incoming>Flow_g08_yes_g16</bpmn:incoming>
      <bpmn:incoming>Flow_g13_no_g16</bpmn:incoming>
      <bpmn:outgoing>Flow_g16_yes_t36</bpmn:outgoing>
      <bpmn:outgoing>Flow_g16_no_g13b</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-36: Prescribe Pharmacotherapy -->
    <bpmn:userTask id="T36" name="Prescribe and Manage Pharmacotherapy">
      <bpmn:incoming>Flow_g16_yes_t36</bpmn:incoming>
      <bpmn:outgoing>Flow_t36_t37</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-37: Administer Pharmacotherapy -->
    <bpmn:userTask id="T37" name="Administer Pharmacotherapy to Patient">
      <bpmn:incoming>Flow_t36_t37</bpmn:incoming>
      <bpmn:outgoing>Flow_t37_g13b</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-13: Trauma-Focused Therapy Available and Preferred? -->
    <bpmn:exclusiveGateway id="G13" name="Trauma-Focused Psychotherapy Available and Preferred?">
      <bpmn:incoming>Flow_g08_no_g13</bpmn:incoming>
      <bpmn:outgoing>Flow_g13_yes_g17</bpmn:outgoing>
      <bpmn:outgoing>Flow_g13_no_g16</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- G-13b: Join after pharmacotherapy -->
    <bpmn:exclusiveGateway id="G13b" name="Proceed to Therapy Modality Selection?">
      <bpmn:incoming>Flow_g16_no_g13b</bpmn:incoming>
      <bpmn:incoming>Flow_t37_g13b</bpmn:incoming>
      <bpmn:outgoing>Flow_g13b_g17</bpmn:outgoing>
      <bpmn:outgoing>Flow_g13b_endt35</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-35: KBT for Specific Symptoms -->
    <bpmn:userTask id="T35" name="Deliver KBT Targeting Specific Residual Symptoms - Sleep or Anger">
      <bpmn:incoming>Flow_g13b_endt35</bpmn:incoming>
      <bpmn:outgoing>Flow_t35_monitoring</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-17: Clinician Certified? -->
    <bpmn:exclusiveGateway id="G17" name="Clinician Holds Required CPČ / ŠPI Certification?">
      <bpmn:incoming>Flow_g13_yes_g17</bpmn:incoming>
      <bpmn:incoming>Flow_g13b_g17</bpmn:incoming>
      <bpmn:outgoing>Flow_g17_no_refercert</bpmn:outgoing>
      <bpmn:outgoing>Flow_g17_yes_g14</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- End: Refer Certified Specialist -->
    <bpmn:endEvent id="EndEvent_RefCert" name="Refer Patient to Certified Specialist for Specific Psychotherapy">
      <bpmn:incoming>Flow_g17_no_refercert</bpmn:incoming>
    </bpmn:endEvent>

    <!-- G-14: Which Modality? -->
    <bpmn:exclusiveGateway id="G14" name="Which Trauma-Focused Therapy Modality is Selected?">
      <bpmn:incoming>Flow_g17_yes_g14</bpmn:incoming>
      <bpmn:outgoing>Flow_g14_kbt_t32</bpmn:outgoing>
      <bpmn:outgoing>Flow_g14_emdr_t33</bpmn:outgoing>
      <bpmn:outgoing>Flow_g14_ikbt_g15</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ==================== PHASE 5: TREATMENT EXECUTION ==================== -->

    <!-- T-32: Trauma-Focused KBT -->
    <bpmn:userTask id="T32" name="Deliver Trauma-Focused KBT - 8 to 12 Sessions per Validated Manual">
      <bpmn:incoming>Flow_g14_kbt_t32</bpmn:incoming>
      <bpmn:outgoing>Flow_t32_monitoring</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-33: EMDR -->
    <bpmn:userTask id="T33" name="Deliver EMDR Therapy Protocol - 8 to 12 Sessions per Validated Manual">
      <bpmn:incoming>Flow_g14_emdr_t33</bpmn:incoming>
      <bpmn:outgoing>Flow_t33_monitoring</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-15: IKBT Contraindication Check -->
    <bpmn:exclusiveGateway id="G15" name="Severe Dissociative Symptoms or Risk to Self or Others Present?">
      <bpmn:incoming>Flow_g14_ikbt_g15</bpmn:incoming>
      <bpmn:outgoing>Flow_g15_yes_t32b</bpmn:outgoing>
      <bpmn:outgoing>Flow_g15_no_t34</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-32b: Redirect to KBT if IKBT contraindicated -->
    <bpmn:userTask id="T32b" name="Redirect to Face-to-Face KBT - IKBT Contraindicated">
      <bpmn:incoming>Flow_g15_yes_t32b</bpmn:incoming>
      <bpmn:outgoing>Flow_t32b_monitoring</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-34: IKBT -->
    <bpmn:userTask id="T34" name="Deliver Therapist-Guided Computerized KBT - IKBT - 8 to 10 Sessions">
      <bpmn:incoming>Flow_g15_no_t34</bpmn:incoming>
      <bpmn:outgoing>Flow_t34_monitoring</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-38: Practical Support -->
    <bpmn:userTask id="T38" name="Provide Practical Support and Social Assistance">
      <bpmn:incoming>Flow_join_t38</bpmn:incoming>
      <bpmn:outgoing>Flow_t38_t40</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-40: Family Psychoeducation -->
    <bpmn:userTask id="T40" name="Provide Psychoeducation and Structured Support to Family Members">
      <bpmn:incoming>Flow_t38_t40</bpmn:incoming>
      <bpmn:outgoing>Flow_t40_g24</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-24: Family Also Affected? -->
    <bpmn:exclusiveGateway id="G24" name="Family Members Also Affected by Traumatic Event?">
      <bpmn:incoming>Flow_t40_g24</bpmn:incoming>
      <bpmn:outgoing>Flow_g24_yes_t42</bpmn:outgoing>
      <bpmn:outgoing>Flow_g24_no_t41</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-42: Assess Family PTSD Risk -->
    <bpmn:userTask id="T42" name="Assess and Coordinate Family Members Own PTSD Risk and Treatment">
      <bpmn:incoming>Flow_g24_yes_t42</bpmn:incoming>
      <bpmn:outgoing>Flow_t42_t41</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-41: Refer Family to Support Group -->
    <bpmn:userTask id="T41" name="Refer Family Members to Peer Support Group">
      <bpmn:incoming>Flow_g24_no_t41</bpmn:incoming>
      <bpmn:incoming>Flow_t42_t41</bpmn:incoming>
      <bpmn:outgoing>Flow_t41_join</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Join gateway before monitoring -->
    <bpmn:exclusiveGateway id="JoinMonitoring" name="Converge to Monitoring Phase">
      <bpmn:incoming>Flow_t32_monitoring</bpmn:incoming>
      <bpmn:incoming>Flow_t33_monitoring</bpmn:incoming>
      <bpmn:incoming>Flow_t34_monitoring</bpmn:incoming>
      <bpmn:incoming>Flow_t32b_monitoring</bpmn:incoming>
      <bpmn:incoming>Flow_t35_monitoring</bpmn:incoming>
      <bpmn:incoming>Flow_t41_join</bpmn:incoming>
      <bpmn:outgoing>Flow_join_t38</bpmn:outgoing>
      <bpmn:outgoing>Flow_join_t43</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ==================== PHASE 6: MONITORING ==================== -->

    <!-- T-43: Session Monitoring -->
    <bpmn:userTask id="T43" name="Administer PHQ-9-SK and GAD-7-SK at Each Therapy Session">
      <bpmn:incoming>Flow_join_t43</bpmn:incoming>
      <bpmn:outgoing>Flow_t43_g21</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-21: Sessions Missed? -->
    <bpmn:exclusiveGateway id="G21" name="Patient Missing Therapy Sessions?">
      <bpmn:incoming>Flow_t43_g21</bpmn:incoming>
      <bpmn:outgoing>Flow_g21_yes_t45</bpmn:outgoing>
      <bpmn:outgoing>Flow_g21_no_g18</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-45: Active Follow-Up -->
    <bpmn:userTask id="T45" name="Conduct Active Follow-Up Contact for Missed Sessions">
      <bpmn:incoming>Flow_g21_yes_t45</bpmn:incoming>
      <bpmn:outgoing>Flow_t45_g18</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-18: Adequate Treatment Response? -->
    <bpmn:exclusiveGateway id="G18" name="Adequate Treatment Response Achieved?">
      <bpmn:incoming>Flow_g21_no_g18</bpmn:incoming>
      <bpmn:incoming>Flow_t45_g18</bpmn:incoming>
      <bpmn:outgoing>Flow_g18_yes_t44</bpmn:outgoing>
      <bpmn:outgoing>Flow_g18_no_g22</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- G-22: Residual Symptoms > 3 Months? -->
    <bpmn:exclusiveGateway id="G22" name="Symptoms Persistent Over 3 Months with Patient Unable or Unwilling for Trauma Therapy?">
      <bpmn:incoming>Flow_g18_no_g22</bpmn:incoming>
      <bpmn:outgoing>Flow_g22_yes_t35b</bpmn:outgoing>
      <bpmn:outgoing>Flow_g22_no_g20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-35b: KBT Specific Symptoms (monitoring loop) -->
    <bpmn:userTask id="T35b" name="Deliver KBT for Specific Residual Symptoms After Primary Treatment">
      <bpmn:incoming>Flow_g22_yes_t35b</bpmn:incoming>
      <bpmn:outgoing>Flow_t35b_g20</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-20: Comorbidity Remitting? -->
    <bpmn:exclusiveGateway id="G20" name="Comorbid Disorders Remitting During PTSD Treatment?">
      <bpmn:incoming>Flow_g22_no_g20</bpmn:incoming>
      <bpmn:incoming>Flow_t35b_g20</bpmn:incoming>
      <bpmn:outgoing>Flow_g20_yes_g19</bpmn:outgoing>
      <bpmn:outgoing>Flow_g20_no_t49</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-49: Switch or Augment Treatment -->
    <bpmn:userTask id="T49" name="Switch or Augment Treatment Modality Based on Response">
      <bpmn:incoming>Flow_g20_no_t49</bpmn:incoming>
      <bpmn:outgoing>Flow_t49_g19</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G-19: Escalation Beyond Ambulatory Needed? -->
    <bpmn:exclusiveGateway id="G19" name="Inadequate Response Requires Escalation Beyond Ambulatory Care?">
      <bpmn:incoming>Flow_g20_yes_g19</bpmn:incoming>
      <bpmn:incoming>Flow_t49_g19</bpmn:incoming>
      <bpmn:outgoing>Flow_g19_dayhospital_t47</bpmn:outgoing>
      <bpmn:outgoing>Flow_g19_hospitalize_t48</bpmn:outgoing>
      <bpmn:outgoing>Flow_g19_continue_t43</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-47: Day Hospital -->
    <bpmn:userTask id="T47" name="Evaluate and Initiate Day Hospital Psychiatric Treatment">
      <bpmn:incoming>Flow_g19_dayhospital_t47</bpmn:incoming>
      <bpmn:outgoing>Flow_t47_t43</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-48: Hospitalization Decision -->
    <bpmn:userTask id="T48" name="Decide and Initiate Inpatient Hospitalization">
      <bpmn:incoming>Flow_g19_hospitalize_t48</bpmn:incoming>
      <bpmn:outgoing>Flow_t48_endhospital</bpmn:outgoing>
    </bpmn:userTask>

    <!-- End: Hospitalization -->
    <bpmn:endEvent id="EndEvent_Hospital" name="Patient Hospitalized - Transfer to Inpatient PTSD Care">
      <bpmn:incoming>Flow_t48_endhospital</bpmn:incoming>
    </bpmn:endEvent>

    <!-- T-44: CORE-OM End of Treatment -->
    <bpmn:userTask id="T44" name="Administer CORE-OM at Treatment Completion and Evaluate Outcome">
      <bpmn:incoming>Flow_g18_yes_t44</bpmn:incoming>
      <bpmn:outgoing>Flow_t44_t46</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T-46: Record Documentation -->
    <bpmn:serviceTask id="T46" name="Record Clinical Outcome and Protocol Deviations in HIS">
      <bpmn:incoming>Flow_t44_t46</bpmn:incoming>
      <bpmn:outgoing>Flow_t46_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- G-25: Acute Crisis (Intermediate Boundary-style event modeled as gateway) -->
    <bpmn:exclusiveGateway id="G25" name="Acute Crisis State Detected at Any Process Point?">
      <bpmn:incoming>Flow_g19_continue_t43</bpmn:incoming>
      <bpmn:incoming>Flow_t47_t43</bpmn:incoming>
      <bpmn:outgoing>Flow_g25_yes_t39</bpmn:outgoing>
      <bpmn:outgoing>Flow_g25_no_t43loop</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T-39: Emergency Management -->
    <bpmn:userTask id="T39" name="Manage Acute Patient State - Emergency RZP Care">
      <bpmn:incoming>Flow_g25_yes_t39</bpmn:incoming>
      <bpmn:outgoing>Flow_t39_t43</bpmn:outgoing>
    </bpmn:userTask>

    <!-- End: Treatment Complete -->
    <bpmn:endEvent id="EndEvent_Complete" name="PTSD Treatment Completed - Patient in Remission">
      <bpmn:incoming>Flow_t46_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ==================== SEQUENCE FLOWS ==================== -->

    <!-- Entry flows -->
    <bpmn:sequenceFlow id="Flow_start_g04" sourceRef="StartEvent_1" targetRef="G04" />
    <bpmn:sequenceFlow id="Flow_g04_yes_t04" name="Mass casualty / refugee context confirmed" sourceRef="G04" targetRef="T04" />
    <bpmn:sequenceFlow id="Flow_g04_no_t01" name="Individual clinical presentation" sourceRef="G04" targetRef="T01" />
    <bpmn:sequenceFlow id="Flow_t04_t01" sourceRef="T04" targetRef="T01" />

    <!-- Phase 1: Primary care -->
    <bpmn:sequenceFlow id="Flow_t01_t06" sourceRef="T01" targetRef="T06" />
    <bpmn:sequenceFlow id="Flow_t06_t05" sourceRef="T06" targetRef="T05" />
    <bpmn:sequenceFlow id="Flow_t05_g01" sourceRef="T05" targetRef="G01" />
