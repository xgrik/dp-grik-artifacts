    <bpmn:sequenceFlow id="Flow_g02b_no_t03" name="Symptoms stable or resolved - preventive intervention" sourceRef="G02b" targetRef="T03" />
    <bpmn:sequenceFlow id="Flow_t03_endprev" sourceRef="T03" targetRef="EndEvent_Prevention" />
    <bpmn:sequenceFlow id="Flow_t08_t07" sourceRef="T08" targetRef="T07" />

    <!-- Phase 3: Diagnostic -->
    <bpmn:sequenceFlow id="Flow_t07_t11" sourceRef="T07" targetRef="T11" />
    <bpmn:sequenceFlow id="Flow_t11_t12" sourceRef="T11" targetRef="T12" />
    <bpmn:sequenceFlow id="Flow_t12_g10" sourceRef="T12" targetRef="G10" />
    <bpmn:sequenceFlow id="Flow_g10_yes_t12b" name="Head injury or physical trauma involved" sourceRef="G10" targetRef="T12b" />
    <bpmn:sequenceFlow id="Flow_g10_no_g06" name="No injury involved - standard somatic exclusion" sourceRef="G10" targetRef="G06" />
    <bpmn:sequenceFlow id="Flow_t12b_g06" sourceRef="T12b" targetRef="G06" />
    <bpmn:sequenceFlow id="Flow_g06_no_endsomatic" name="Organic cause identified - refer to somatic specialist" sourceRef="G06" targetRef="EndEvent_OrganicCause" />
    <bpmn:sequenceFlow id="Flow_g06_yes_t13" name="Somatic cause excluded - proceed to psychodiagnostics" sourceRef="G06" targetRef="T13" />
    <bpmn:sequenceFlow id="Flow_t13_t14" sourceRef="T13" targetRef="T14" />
    <bpmn:sequenceFlow id="Flow_t14_t15" sourceRef="T14" targetRef="T15" />
    <bpmn:sequenceFlow id="Flow_t15_t16" sourceRef="T15" targetRef="T16" />
    <bpmn:sequenceFlow id="Flow_t16_t17" sourceRef="T16" targetRef="T17" />
    <bpmn:sequenceFlow id="Flow_t17_t18" sourceRef="T17" targetRef="T18" />
    <bpmn:sequenceFlow id="Flow_t18_g09" sourceRef="T18" targetRef="G09" />
    <bpmn:sequenceFlow id="Flow_g09_yes_t19" name="Complex psychodiagnostic examination indicated" sourceRef="G09" targetRef="T19" />
    <bpmn:sequenceFlow id="Flow_g09_no_t20" name="Standard battery sufficient - proceed" sourceRef="G09" targetRef="T20" />
    <bpmn:sequenceFlow id="Flow_t19_t20" sourceRef="T19" targetRef="T20" />
    <bpmn:sequenceFlow id="Flow_t20_t25" sourceRef="T20" targetRef="T25" />
    <bpmn:sequenceFlow id="Flow_t25_t21" sourceRef="T25" targetRef="T21" />
    <bpmn:sequenceFlow id="Flow_t21_g07" sourceRef="T21" targetRef="G07" />
    <bpmn:sequenceFlow id="Flow_g07_yes_endalt" name="Alternative diagnosis better explains symptoms" sourceRef="G07" targetRef="EndEvent_AltDx" />
    <bpmn:sequenceFlow id="Flow_g07_no_t22" name="PTSD remains primary diagnosis" sourceRef="G07" targetRef="T22" />
    <bpmn:sequenceFlow id="Flow_t22_t23" sourceRef="T22" targetRef="T23" />
    <bpmn:sequenceFlow id="Flow_t23_t24" sourceRef="T23" targetRef="T24" />
    <bpmn:sequenceFlow id="Flow_t24_g05" sourceRef="T24" targetRef="G05" />
    <bpmn:sequenceFlow id="Flow_g05_no_endnodiag" name="ICD-10 criteria not fully met" sourceRef="G05" targetRef="EndEvent_NoDiag" />
    <bpmn:sequenceFlow id="Flow_g05_yes_t31" name="Full ICD-10 criteria A through E confirmed" sourceRef="G05" targetRef="T31" />

    <!-- Phase 4: Treatment Planning -->
    <bpmn:sequenceFlow id="Flow_t31_g23" sourceRef="T31" targetRef="G23" />
    <bpmn:sequenceFlow id="Flow_g23_yes_t31b" name="Language or cultural barrier identified" sourceRef="G23" targetRef="T31b" />
    <bpmn:sequenceFlow id="Flow_g23_no_t30" name="No language or cultural barrier" sourceRef="G23" targetRef="T30" />
    <bpmn:sequenceFlow id="Flow_t31b_t30" sourceRef="T31b" targetRef="T30" />
    <bpmn:sequenceFlow id="Flow_t30_t26" sourceRef="T30" targetRef="T26" />
    <bpmn:sequenceFlow id="Flow_t26_g12" sourceRef="T26" targetRef="G12" />
    <bpmn:sequenceFlow id="Flow_g12_no_endnoconsent" name="Patient refuses or cannot provide consent" sourceRef="G12" targetRef="EndEvent_NoConsent" />
    <bpmn:sequenceFlow id="Flow_g12_yes_t27" name="Informed consent obtained" sourceRef="G12" targetRef="T27" />
    <bpmn:sequenceFlow id="Flow_t27_g11" sourceRef="T27" targetRef="G11" />
    <bpmn:sequenceFlow id="Flow_g11_yes_t29" name="High risk of self-harm or harm to others confirmed" sourceRef="G11" targetRef="T29" />
    <bpmn:sequenceFlow id="Flow_g11_no_t28" name="No elevated risk identified" sourceRef="G11" targetRef="T28" />
    <bpmn:sequenceFlow id="Flow_t29_t28" sourceRef="T29" targetRef="T28" />
    <bpmn:sequenceFlow id="Flow_t28_g08" sourceRef="T28" targetRef="G08" />
    <bpmn:sequenceFlow id="Flow_g08_yes_g16" name="Significant comorbidities present - consider pharmacotherapy" sourceRef="G08" targetRef="G16" />
    <bpmn:sequenceFlow id="Flow_g08_no_g13" name="No significant comorbidities" sourceRef="G08" targetRef="G13" />
    <bpmn:sequenceFlow id="Flow_g13_yes_g17" name="Trauma-focused psychotherapy available and preferred" sourceRef="G13" targetRef="G17" />
    <bpmn:sequenceFlow id="Flow_g13_no_g16" name="Trauma-focused therapy not available or not preferred" sourceRef="G13" targetRef="G16" />
    <bpmn:sequenceFlow id="Flow_g16_yes_t36" name="Pharmacotherapy indicated as primary or augmentation" sourceRef="G16" targetRef="T36" />
    <bpmn:sequenceFlow id="Flow_g16_no_g13b" name="Pharmacotherapy not indicated" sourceRef="G16" targetRef="G13b" />
    <bpmn:sequenceFlow id="Flow_t36_t37" sourceRef="T36" targetRef="T37" />
    <bpmn:sequenceFlow id="Flow_t37_g13b" sourceRef="T37" targetRef="G13b" />
    <bpmn:sequenceFlow id="Flow_g13b_g17" name="Proceed to trauma-focused therapy modality selection" sourceRef="G13b" targetRef="G17" />
    <bpmn:sequenceFlow id="Flow_g13b_endt35" name="Patient unable or unwilling for trauma therapy - symptom-specific KBT" sourceRef="G13b" targetRef="T35" />
    <bpmn:sequenceFlow id="Flow_g17_no_refercert" name="Clinician not certified - refer to certified specialist" sourceRef="G17" targetRef="EndEvent_RefCert" />
    <bpmn:sequenceFlow id="Flow_g17_yes_g14" name="Required certification confirmed" sourceRef="G17" targetRef="G14" />
    <bpmn:sequenceFlow id="Flow_g14_kbt_t32" name="Trauma-focused KBT selected" sourceRef="G14" targetRef="T32" />
    <bpmn:sequenceFlow id="Flow_g14_emdr_t33" name="EMDR selected" sourceRef="G14" targetRef="T33" />
    <bpmn:sequenceFlow id="Flow_g14_ikbt_g15" name="Computerized KBT selected - check contraindications" sourceRef="G14" targetRef="G15" />

    <!-- Phase 5: Treatment Execution -->
    <bpmn:sequenceFlow id="Flow_g15_yes_t32b" name="IKBT contraindicated - severe dissociation or safety risk" sourceRef="G15" targetRef="T32b" />
    <bpmn:sequenceFlow id="Flow_g15_no_t34" name="No contraindications - IKBT eligible" sourceRef="G15" targetRef="T34" />
