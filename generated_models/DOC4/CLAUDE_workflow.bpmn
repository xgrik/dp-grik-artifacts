    <bpmn:sequenceFlow id="Flow_t48_endhospital" sourceRef="T48" targetRef="EndEvent_Hospital" />
    <bpmn:sequenceFlow id="Flow_t44_t46" sourceRef="T44" targetRef="T46" />
    <bpmn:sequenceFlow id="Flow_t46_end" sourceRef="T46" targetRef="EndEvent_Complete" />

  </bpmn:process>

