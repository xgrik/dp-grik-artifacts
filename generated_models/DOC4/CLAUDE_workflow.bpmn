    <bpmn:sequenceFlow id="Flow_t41_join" sourceRef="T41" targetRef="JoinMonitoring" />
    <bpmn:sequenceFlow id="Flow_join_t38" name="Provide family and social support" sourceRef="JoinMonitoring" targetRef="T38" />
    <bpmn:sequenceFlow id="Flow_join_t43" name="Proceed to session monitoring" sourceRef="JoinMonitoring" targetRef="T43" />
    <bpmn:sequenceFlow id="Flow_t38_t40" sourceRef="T38" targetRef="T40" />
    <bpmn:sequenceFlow id="Flow_t40_g24" sourceRef="T40" targetRef="G24" />
    <bpmn:sequenceFlow id="Flow_g24_yes_t42" name="Family members also affected by trauma" sourceRef="G24" targetRef="T42" />
    <bpmn:sequenceFlow id="Flow_g24_no_t41" name="Only index patient affected" sourceRef="G24" targetRef="T41" />
    <bpmn:sequenceFlow id="Flow_t42_t41" sourceRef="T42" targetRef="T41" />

    <!-- Phase 6: Monitoring -->
    <bpmn:sequenceFlow id="Flow_t43_g21" sourceRef="T43" targetRef="G21" />
    <bpmn:sequenceFlow id="Flow_g21_yes_t45" name="Patient missing sessions - active follow-up required" sourceRef="G21" targetRef="T45" />
    <bpmn:sequenceFlow id="Flow_g21_no_g18" name="Sessions attended - evaluate treatment response" sourceRef="G21" targetRef="G18" />
    <bpmn:sequenceFlow id="Flow_t45_g18" sourceRef="T45" targetRef="G18" />
    <bpmn:sequenceFlow id="Flow_g18_yes_t44" name="Adequate treatment response achieved" sourceRef="G18" targetRef="T44" />
    <bpmn:sequenceFlow id="Flow_g18_no_g22" name="Inadequate treatment response" sourceRef="G18" targetRef="G22" />
    <bpmn:sequenceFlow id="Flow_g22_yes_t35b" name="Symptoms persistent over 3 months and patient unwilling or unable" sourceRef="G22" targetRef="T35b" />
    <bpmn:sequenceFlow id="Flow_g22_no_g20" name="Consider comorbidity status and treatment switch" sourceRef="G22" targetRef="G20" />
    <bpmn:sequenceFlow id="Flow_t35b_g20" sourceRef="T35b" targetRef="G20" />
    <bpmn:sequenceFlow id="Flow_g20_yes_g19" name="Comorbidity remitting - evaluate escalation need" sourceRef="G20" targetRef="G19" />
