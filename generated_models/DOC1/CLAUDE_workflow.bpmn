<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  id="Definitions_0i3pgsi"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
                  exporter="Camunda Modeler"
                  exporterVersion="5.33.1"
                  modeler:executionPlatform="Camunda Platform"
                  modeler:executionPlatformVersion="7.22.0">

  <bpmn:process id="Process_1juweid" isExecutable="true" name="Complex Psychological Management of Adult Patient with Chronic Pain">

    <!-- START EVENT -->
    <bpmn:startEvent id="StartEvent_1" name="Patient Presents with Chronic Pain (&#62;3 months)">
      <bpmn:outgoing>SF_01</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- T01: Administer Risk Stratification Questionnaire -->
    <bpmn:userTask id="T01" name="Administer Risk Stratification Questionnaire (GP/Psychologist)">
      <bpmn:incoming>SF_01</bpmn:incoming>
      <bpmn:outgoing>SF_02</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T03: Administer PHQ-9 -->
    <bpmn:userTask id="T03" name="Administer PHQ-9 Depression Screening">
      <bpmn:incoming>SF_02</bpmn:incoming>
      <bpmn:outgoing>SF_03</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T04: Administer GAD-7 -->
    <bpmn:userTask id="T04" name="Administer GAD-7 Anxiety Screening">
      <bpmn:incoming>SF_03</bpmn:incoming>
      <bpmn:outgoing>SF_04</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T02: Score and Evaluate Risk Stratification Questionnaire -->
    <bpmn:businessRuleTask id="T02" name="Score and Evaluate Risk Stratification Questionnaire">
      <bpmn:incoming>SF_04</bpmn:incoming>
      <bpmn:outgoing>SF_05</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <!-- G01: Chronification Risk Level -->
    <bpmn:exclusiveGateway id="G01" name="Chronification Risk Level?">
      <bpmn:incoming>SF_05</bpmn:incoming>
      <bpmn:outgoing>SF_G01_LOW</bpmn:outgoing>
      <bpmn:outgoing>SF_G01_MED</bpmn:outgoing>
      <bpmn:outgoing>SF_G01_HIGH</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Low risk path: GP monitoring -->
    <bpmn:userTask id="T_GP_MONITOR" name="GP Manages Patient with Basic Intervention and Monitoring">
      <bpmn:incoming>SF_G01_LOW</bpmn:incoming>
      <bpmn:outgoing>SF_GP_END</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_GPMonitor" name="Patient Managed by GP - No Specialist Referral Required">
      <bpmn:incoming>SF_GP_END</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Medium risk path: Psychoeducation + physiotherapy referral -->
    <bpmn:userTask id="T_MED_RISK" name="Provide Psychoeducation and Adherence Support (Medium Risk)">
      <bpmn:incoming>SF_G01_MED</bpmn:incoming>
      <bpmn:outgoing>SF_MED_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- High risk: mandatory referral to clinical psychologist -->
    <!-- G01 HIGH goes to T05 -->

    <!-- T05: Issue Referral to Clinical Psychologist -->
    <bpmn:userTask id="T05" name="Issue Referral to Clinical Psychologist">
      <bpmn:incoming>SF_G01_HIGH</bpmn:incoming>
      <bpmn:incoming>SF_MED_JOIN</bpmn:incoming>
      <bpmn:outgoing>SF_06</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T08: Receive and Register Patient (Intake) -->
    <bpmn:userTask id="T08" name="Receive and Register Patient at Psychology Service (Intake)">
      <bpmn:incoming>SF_06</bpmn:incoming>
      <bpmn:outgoing>SF_07</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G07: Special Population Assessment Protocol -->
    <bpmn:exclusiveGateway id="G07" name="Patient Communication/Cognitive Status?">
      <bpmn:incoming>SF_07</bpmn:incoming>
      <bpmn:outgoing>SF_G07_STD</bpmn:outgoing>
      <bpmn:outgoing>SF_G07_SPEC</bpmn:outgoing>
      <bpmn:outgoing>SF_G07_ELD</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Standard assessment instruments -->
    <bpmn:userTask id="T13_STD" name="Administer Standard Pain Intensity Scale (VAS/NRS)">
      <bpmn:incoming>SF_G07_STD</bpmn:incoming>
      <bpmn:outgoing>SF_T13_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Special population: MOBID-2, CNPI, Doloplus-2 -->
    <bpmn:userTask id="T13_SPEC" name="Administer Behavioral Pain Assessment (MOBID-2/CNPI/Doloplus-2)">
      <bpmn:incoming>SF_G07_SPEC</bpmn:incoming>
      <bpmn:outgoing>SF_T13_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Elderly: NRS/VAS/Faces/Verbal -->
    <bpmn:userTask id="T13_ELD" name="Administer Age-Appropriate Pain Scale (NRS/VAS/Faces/VDS)">
      <bpmn:incoming>SF_G07_ELD</bpmn:incoming>
      <bpmn:outgoing>SF_T13_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Join after instrument selection -->
    <bpmn:exclusiveGateway id="G07_JOIN" name="Pain Scale Administered">
      <bpmn:incoming>SF_T13_JOIN</bpmn:incoming>
      <bpmn:outgoing>SF_08</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T09: Structured Clinical Observation -->
    <bpmn:userTask id="T09" name="Conduct Structured Clinical Observation (Mental Status, Pain Behaviour)">
      <bpmn:incoming>SF_08</bpmn:incoming>
      <bpmn:outgoing>SF_09</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T10: Structured Pain Anamnesis -->
    <bpmn:userTask id="T10" name="Conduct Structured Pain Anamnesis (Breivik 12-Item Protocol)">
      <bpmn:incoming>SF_09</bpmn:incoming>
      <bpmn:outgoing>SF_10</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T11: Bio-Psycho-Social Assessment -->
    <bpmn:userTask id="T11" name="Conduct Bio-Psycho-Social Assessment (Somatic, Psychological, Behavioural, Social Factors)">
      <bpmn:incoming>SF_10</bpmn:incoming>
      <bpmn:outgoing>SF_11</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T12: Assess Pain Beliefs and Cognitions -->
    <bpmn:userTask id="T12" name="Assess Pain Beliefs and Cognitions (Locus of Control, Catastrophizing, Self-Efficacy)">
      <bpmn:incoming>SF_11</bpmn:incoming>
      <bpmn:outgoing>SF_12</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T14: PCS -->
    <bpmn:userTask id="T14" name="Administer Pain Catastrophizing Scale (PCS)">
      <bpmn:incoming>SF_12</bpmn:incoming>
      <bpmn:outgoing>SF_13</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T15: TSK -->
    <bpmn:userTask id="T15" name="Administer Tampa Scale for Kinesiophobia (TSK)">
      <bpmn:incoming>SF_13</bpmn:incoming>
      <bpmn:outgoing>SF_14</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G06: Pain Diary Decision -->
    <bpmn:exclusiveGateway id="G06" name="Is Pain Diary Appropriate for This Patient?">
      <bpmn:incoming>SF_14</bpmn:incoming>
      <bpmn:outgoing>SF_G06_YES</bpmn:outgoing>
      <bpmn:outgoing>SF_G06_NO</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T16: Introduce Pain Diary -->
    <bpmn:userTask id="T16" name="Introduce and Instruct Pain Diary to Patient">
      <bpmn:incoming>SF_G06_YES</bpmn:incoming>
      <bpmn:outgoing>SF_T16_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T17: Patient completes pain diary -->
    <bpmn:userTask id="T17" name="Patient Completes Pain Diary Between Sessions (Self-Monitoring)">
      <bpmn:incoming>SF_T16_JOIN</bpmn:incoming>
      <bpmn:outgoing>SF_T17_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Join after diary decision -->
    <bpmn:exclusiveGateway id="G06_JOIN" name="Assessment Phase Complete">
      <bpmn:incoming>SF_G06_NO</bpmn:incoming>
      <bpmn:incoming>SF_T17_JOIN</bpmn:incoming>
      <bpmn:outgoing>SF_15</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T20: Psychodiagnostic Examination -->
    <bpmn:userTask id="T20" name="Perform Psychodiagnostic Examination (Standardised Instruments)">
      <bpmn:incoming>SF_15</bpmn:incoming>
      <bpmn:outgoing>SF_16</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T07: Issue Referral to Medical Specialist -->
    <bpmn:userTask id="T07" name="Issue Referral to Medical Specialist (Algesiologist/Neurologist/Orthopedist/Rheumatologist)">
      <bpmn:incoming>SF_16</bpmn:incoming>
      <bpmn:outgoing>SF_17</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T18: Specialist Medical Examination -->
    <bpmn:userTask id="T18" name="Conduct Specialist Medical Examination and Determine Pain Type (Nociceptive/Neuropathic/Mixed)">
      <bpmn:incoming>SF_17</bpmn:incoming>
      <bpmn:outgoing>SF_18</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T21: Differential Diagnosis -->
    <bpmn:userTask id="T21" name="Apply Differential Diagnostic Criteria (ICD-11 MG30, Exclude Psychiatric Overlap)">
      <bpmn:incoming>SF_18</bpmn:incoming>
      <bpmn:outgoing>SF_19</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G19: Oncological/Palliative Divergence -->
    <bpmn:exclusiveGateway id="G19" name="Is Pain Cancer-Related (ICD-11 MG30.1)?">
      <bpmn:incoming>SF_19</bpmn:incoming>
      <bpmn:outgoing>SF_G19_ONCO</bpmn:outgoing>
      <bpmn:outgoing>SF_G19_STD</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Oncological path: BPI + total pain assessment -->
    <bpmn:userTask id="T_ONCO" name="Conduct Oncological/Palliative Pain Assessment (BPI, Total Pain Model - Physical/Psychological/Social/Spiritual)">
      <bpmn:incoming>SF_G19_ONCO</bpmn:incoming>
      <bpmn:outgoing>SF_ONCO_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Join oncological and standard paths -->
    <bpmn:exclusiveGateway id="G19_JOIN" name="Diagnosis Pathway Determined">
      <bpmn:incoming>SF_G19_STD</bpmn:incoming>
      <bpmn:incoming>SF_ONCO_JOIN</bpmn:incoming>
      <bpmn:outgoing>SF_20</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T22: Assess Comorbid Symptoms -->
    <bpmn:userTask id="T22" name="Assess Comorbid Symptoms (Anxiety, Depression, Insomnia, Substance Use, Obesity)">
      <bpmn:incoming>SF_20</bpmn:incoming>
      <bpmn:outgoing>SF_21</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T23: Assess Suicide Risk -->
    <bpmn:userTask id="T23" name="Assess Suicide Risk (Risk Factor Evaluation: Depression, Disability, Substance Use, Sleep, Pain Severity)">
      <bpmn:incoming>SF_21</bpmn:incoming>
      <bpmn:outgoing>SF_22</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G10: Suicide Risk Level -->
    <bpmn:exclusiveGateway id="G10" name="Suicide Risk Level?">
      <bpmn:incoming>SF_22</bpmn:incoming>
      <bpmn:outgoing>SF_G10_ELEVATED</bpmn:outgoing>
      <bpmn:outgoing>SF_G10_NONE</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Elevated suicide risk: urgent psychiatric referral -->
    <bpmn:userTask id="T06_URGENT" name="Issue Urgent Referral to Psychiatrist (Elevated Suicide Risk)">
      <bpmn:incoming>SF_G10_ELEVATED</bpmn:incoming>
      <bpmn:outgoing>SF_URGENT_PSYCH</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="T19_URGENT" name="Conduct Urgent Psychiatric Examination">
      <bpmn:incoming>SF_URGENT_PSYCH</bpmn:incoming>
      <bpmn:outgoing>SF_URGENT_HOSP</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G12 URGENT: Hospitalization decision after urgent psychiatric -->
    <bpmn:exclusiveGateway id="G12_URGENT" name="Urgent Hospitalization Required?">
      <bpmn:incoming>SF_URGENT_HOSP</bpmn:incoming>
      <bpmn:outgoing>SF_HOSP_YES_URG</bpmn:outgoing>
      <bpmn:outgoing>SF_HOSP_NO_URG</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Hospitalization" name="Patient Admitted to Inpatient Psychiatric Care">
      <bpmn:incoming>SF_HOSP_YES_URG</bpmn:incoming>
    </bpmn:endEvent>

    <!-- G11: Differential Diagnosis Outcome -->
    <bpmn:exclusiveGateway id="G11" name="Differential Diagnosis Outcome?">
      <bpmn:incoming>SF_G10_NONE</bpmn:incoming>
      <bpmn:incoming>SF_HOSP_NO_URG</bpmn:incoming>
      <bpmn:outgoing>SF_G11_PRIMARY</bpmn:outgoing>
      <bpmn:outgoing>SF_G11_SECONDARY</bpmn:outgoing>
      <bpmn:outgoing>SF_G11_PSYCH</bpmn:outgoing>
      <bpmn:outgoing>SF_G11_FURTHER</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Further investigation needed -->
    <bpmn:userTask id="T_FURTHER_DIAG" name="Request Further Diagnostic Investigation (Specialist Consultation / Additional Tests)">
      <bpmn:incoming>SF_G11_FURTHER</bpmn:incoming>
      <bpmn:outgoing>SF_FURTHER_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Join back to diagnosis -->
    <bpmn:exclusiveGateway id="G11_JOIN" name="Diagnosis Established">
      <bpmn:incoming>SF_G11_PRIMARY</bpmn:incoming>
      <bpmn:incoming>SF_G11_SECONDARY</bpmn:incoming>
      <bpmn:incoming>SF_G11_PSYCH</bpmn:incoming>
      <bpmn:incoming>SF_FURTHER_JOIN</bpmn:incoming>
      <bpmn:outgoing>SF_23</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T24: Establish ICD-11 Diagnosis -->
    <bpmn:userTask id="T24" name="Establish Chronic Pain Diagnosis (ICD-11 MG30 Classification)">
      <bpmn:incoming>SF_23</bpmn:incoming>
      <bpmn:outgoing>SF_24</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G08: Comorbid Insomnia -->
    <bpmn:exclusiveGateway id="G08" name="Comorbid Insomnia Present?">
      <bpmn:incoming>SF_24</bpmn:incoming>
      <bpmn:outgoing>SF_G08_YES</bpmn:outgoing>
      <bpmn:outgoing>SF_G08_NO</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="G08_JOIN" name="Insomnia Assessment Complete">
      <bpmn:incoming>SF_G08_YES</bpmn:incoming>
      <bpmn:incoming>SF_G08_NO</bpmn:incoming>
      <bpmn:outgoing>SF_25</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- G09: Substance Use Risk -->
    <bpmn:exclusiveGateway id="G09" name="Substance Use / Opioid Misuse Risk Identified?">
      <bpmn:incoming>SF_25</bpmn:incoming>
      <bpmn:outgoing>SF_G09_YES</bpmn:outgoing>
      <bpmn:outgoing>SF_G09_NO</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="T_SUBSTANCE" name="Conduct Substance Misuse Assessment and Modify Treatment Plan Accordingly">
      <bpmn:incoming>SF_G09_YES</bpmn:incoming>
      <bpmn:outgoing>SF_G09_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="G09_JOIN" name="Comorbidity Assessment Complete">
      <bpmn:incoming>SF_G09_JOIN</bpmn:incoming>
      <bpmn:incoming>SF_G09_NO</bpmn:incoming>
      <bpmn:outgoing>SF_26</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- G02: PHQ-9 Severity -->
    <bpmn:exclusiveGateway id="G02" name="PHQ-9 Depression Severity?">
      <bpmn:incoming>SF_26</bpmn:incoming>
      <bpmn:outgoing>SF_G02_NONE</bpmn:outgoing>
      <bpmn:outgoing>SF_G02_MILD</bpmn:outgoing>
      <bpmn:outgoing>SF_G02_MODERATE</bpmn:outgoing>
      <bpmn:outgoing>SF_G02_SEVERE</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="G02_JOIN" name="Depression Severity Pathway Merged">
      <bpmn:incoming>SF_G02_NONE</bpmn:incoming>
      <bpmn:incoming>SF_G02_MILD</bpmn:incoming>
      <bpmn:incoming>SF_G02_MODERATE</bpmn:incoming>
      <bpmn:incoming>SF_G02_SEVERE</bpmn:incoming>
      <bpmn:outgoing>SF_27</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- G03: GAD-7 Severity -->
    <bpmn:exclusiveGateway id="G03" name="GAD-7 Anxiety Severity?">
      <bpmn:incoming>SF_27</bpmn:incoming>
      <bpmn:outgoing>SF_G03_MIN</bpmn:outgoing>
      <bpmn:outgoing>SF_G03_MILD</bpmn:outgoing>
      <bpmn:outgoing>SF_G03_MOD</bpmn:outgoing>
      <bpmn:outgoing>SF_G03_SEV</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="G03_JOIN" name="Anxiety Severity Pathway Merged">
      <bpmn:incoming>SF_G03_MIN</bpmn:incoming>
      <bpmn:incoming>SF_G03_MILD</bpmn:incoming>
      <bpmn:incoming>SF_G03_MOD</bpmn:incoming>
      <bpmn:incoming>SF_G03_SEV</bpmn:incoming>
      <bpmn:outgoing>SF_28</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T06: Issue Referral to Psychiatrist (non-urgent) -->
    <bpmn:userTask id="T06" name="Issue Referral to Psychiatrist (Confirmed Psychiatric Comorbidity)">
      <bpmn:incoming>SF_28</bpmn:incoming>
      <bpmn:outgoing>SF_29</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T19: Psychiatric Examination -->
    <bpmn:userTask id="T19" name="Conduct Psychiatric Examination (Mental Status, Comorbidities, Pharmacotherapy Assessment)">
      <bpmn:incoming>SF_29</bpmn:incoming>
      <bpmn:outgoing>SF_30</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T25: Formulate Individual Therapeutic Plan -->
    <bpmn:userTask id="T25" name="Formulate Individual Therapeutic Plan (Bio-Psycho-Social, Multidisciplinary)">
      <bpmn:incoming>SF_30</bpmn:incoming>
      <bpmn:outgoing>SF_31</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T26: Obtain Informed Consent -->
    <bpmn:userTask id="T26" name="Obtain Informed Consent from Patient (UDZS Template)">
      <bpmn:incoming>SF_31</bpmn:incoming>
      <bpmn:outgoing>SF_32</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T27: Hospitalization Decision -->
    <bpmn:userTask id="T27" name="Make Hospitalization Decision (Specialist Physician / Psychiatrist)">
      <bpmn:incoming>SF_32</bpmn:incoming>
      <bpmn:outgoing>SF_33</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G12: Hospitalization vs Outpatient -->
    <bpmn:exclusiveGateway id="G12" name="Hospitalization Required?">
      <bpmn:incoming>SF_33</bpmn:incoming>
      <bpmn:outgoing>SF_G12_INPAT</bpmn:outgoing>
      <bpmn:outgoing>SF_G12_OUTPAT</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_InpatientCare" name="Patient Transferred to Inpatient Care (Psychiatric / Specialist Ward)">
      <bpmn:incoming>SF_G12_INPAT</bpmn:incoming>
    </bpmn:endEvent>

    <!-- G14: Therapist CPČ Certification Check -->
    <bpmn:businessRuleTask id="G14_TASK" name="Verify Therapist CPČ Certification for ŠPI Delivery">
      <bpmn:incoming>SF_G12_OUTPAT</bpmn:incoming>
      <bpmn:outgoing>SF_34</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="G14" name="Therapist Holds CPČ Certification?">
      <bpmn:incoming>SF_34</bpmn:incoming>
      <bpmn:outgoing>SF_G14_YES</bpmn:outgoing>
      <bpmn:outgoing>SF_G14_NO</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="T_REASSIGN" name="Reassign to Certified Therapist or Select Alternative Non-ŠPI Intervention">
      <bpmn:incoming>SF_G14_NO</bpmn:incoming>
      <bpmn:outgoing>SF_G14_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="G14_JOIN" name="Therapy Assignment Resolved">
      <bpmn:incoming>SF_G14_YES</bpmn:incoming>
      <bpmn:incoming>SF_G14_JOIN</bpmn:incoming>
      <bpmn:outgoing>SF_35</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- G13: Primary Psychotherapy Modality Selection -->
    <bpmn:exclusiveGateway id="G13" name="Primary Psychotherapy Modality?">
      <bpmn:incoming>SF_35</bpmn:incoming>
      <bpmn:outgoing>SF_G13_KBT</bpmn:outgoing>
      <bpmn:outgoing>SF_G13_ACT</bpmn:outgoing>
      <bpmn:outgoing>SF_G13_EMDR</bpmn:outgoing>
      <bpmn:outgoing>SF_G13_ALT</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T29: KBT -->
    <bpmn:userTask id="T29" name="Deliver Cognitive-Behavioural Therapy for Chronic Pain (KBT-CP, Evidence-Based, Individual or Group)">
      <bpmn:incoming>SF_G13_KBT</bpmn:incoming>
      <bpmn:outgoing>SF_T29_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T30: ACT -->
    <bpmn:userTask id="T30" name="Deliver Acceptance and Commitment Therapy (ACT, 8-Session Protocol: Values, Defusion, Committed Action)">
      <bpmn:incoming>SF_G13_ACT</bpmn:incoming>
      <bpmn:outgoing>SF_T30_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T32: EMDR -->
    <bpmn:userTask id="T32" name="Deliver EMDR Therapy (Desensitization and Reprocessing of Emotional Distress in Chronic Pain)">
      <bpmn:incoming>SF_G13_EMDR</bpmn:incoming>
      <bpmn:outgoing>SF_T32_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Alternative certified psychotherapy -->
    <bpmn:userTask id="T_ALT_PSYCH" name="Deliver Alternative Certified Psychotherapy (When Evidence-Based ŠPI Not Available)">
      <bpmn:incoming>SF_G13_ALT</bpmn:incoming>
      <bpmn:outgoing>SF_TALT_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Join after primary modality -->
    <bpmn:exclusiveGateway id="G13_JOIN" name="Primary Psychotherapy Delivered">
      <bpmn:incoming>SF_T29_JOIN</bpmn:incoming>
      <bpmn:incoming>SF_T30_JOIN</bpmn:incoming>
      <bpmn:incoming>SF_T32_JOIN</bpmn:incoming>
      <bpmn:incoming>SF_TALT_JOIN</bpmn:incoming>
      <bpmn:outgoing>SF_36</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T28: Psychoeducation (always delivered) -->
    <bpmn:userTask id="T28" name="Deliver Psychoeducation (Bio-Psycho-Social Pain Model, Gate Control Theory, Metaphors)">
      <bpmn:incoming>SF_36</bpmn:incoming>
      <bpmn:outgoing>SF_37</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G15: Adjunct Treatment Selection (OR gateway) -->
    <bpmn:inclusiveGateway id="G15" name="Select Adjunct Treatment Components">
      <bpmn:incoming>SF_37</bpmn:incoming>
      <bpmn:outgoing>SF_G15_BIO</bpmn:outgoing>
      <bpmn:outgoing>SF_G15_RELAX</bpmn:outgoing>
      <bpmn:outgoing>SF_G15_PHARMA</bpmn:outgoing>
      <bpmn:outgoing>SF_G15_SOCIAL</bpmn:outgoing>
      <bpmn:outgoing>SF_G15_INSOMNIA</bpmn:outgoing>
    </bpmn:inclusiveGateway>

    <!-- T33: Biofeedback -->
    <bpmn:userTask id="T33" name="Deliver EMG Biofeedback Therapy (Supportive Component, Combined with Psychotherapy)">
      <bpmn:incoming>SF_G15_BIO</bpmn:incoming>
      <bpmn:outgoing>SF_T33_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T34: Progressive Muscle Relaxation -->
    <bpmn:userTask id="T34" name="Deliver Jacobson Progressive Muscle Relaxation (Therapist-Led, then Patient Self-Administration)">
      <bpmn:incoming>SF_G15_RELAX</bpmn:incoming>
      <bpmn:outgoing>SF_T34_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T35: Pharmacotherapy -->
    <bpmn:userTask id="T35" name="Prescribe and Administer Pharmacotherapy (Antidepressants Considered; Multiple Drug Classes Contraindicated)">
      <bpmn:incoming>SF_G15_PHARMA</bpmn:incoming>
      <bpmn:outgoing>SF_T35_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T36: Social Intervention -->
    <bpmn:userTask id="T36" name="Deliver Social Intervention (Social Worker: Employment, Disability, Financial, Family Issues)">
      <bpmn:incoming>SF_G15_SOCIAL</bpmn:incoming>
      <bpmn:outgoing>SF_T36_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T31: KBT-I for Insomnia (conditional on G08 positive) -->
    <bpmn:userTask id="T31" name="Deliver CBT for Insomnia (KBT-I, 8-Session Jungquist Protocol: Sleep Restriction, Stimulus Control, Cognitive Restructuring)">
      <bpmn:incoming>SF_G15_INSOMNIA</bpmn:incoming>
      <bpmn:incoming>SF_G08_YES</bpmn:incoming>
      <bpmn:outgoing>SF_T31_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G17: Sleep Restriction Titration (internal to KBT-I) -->
    <bpmn:exclusiveGateway id="G17" name="Sleep Efficiency ≥ 90% in KBT-I?">
      <bpmn:incoming>SF_T31_JOIN</bpmn:incoming>
      <bpmn:outgoing>SF_G17_YES</bpmn:outgoing>
      <bpmn:outgoing>SF_G17_NO</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="T_TITRATION" name="Increase Prescribed Time in Bed by 15 Minutes (Upward Titration)">
      <bpmn:incoming>SF_G17_YES</bpmn:incoming>
      <bpmn:outgoing>SF_G17_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="T_NO_TITRATION" name="Maintain Current Sleep Restriction Parameters (Reassess Next Session)">
      <bpmn:incoming>SF_G17_NO</bpmn:incoming>
      <bpmn:outgoing>SF_G17_JOIN</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="G17_JOIN" name="KBT-I Titration Step Complete">
      <bpmn:incoming>SF_G17_JOIN</bpmn:incoming>
      <bpmn:outgoing>SF_T31_DONE</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Join all adjunct components -->
    <bpmn:inclusiveGateway id="G15_JOIN" name="All Selected Adjunct Components Delivered">
      <bpmn:incoming>SF_T33_JOIN</bpmn:incoming>
      <bpmn:incoming>SF_T34_JOIN</bpmn:incoming>
      <bpmn:incoming>SF_T35_JOIN</bpmn:incoming>
      <bpmn:incoming>SF_T36_JOIN</bpmn:incoming>
      <bpmn:incoming>SF_T31_DONE</bpmn:incoming>
      <bpmn:outgoing>SF_38</bpmn:outgoing>
    </bpmn:inclusiveGateway>

    <!-- T38: CAQ Outcome Questionnaire -->
    <bpmn:userTask id="T38" name="Administer CAQ Outcome Questionnaire (CAQ-8/18: Depression, Social Functioning, Mental Health, Vitality)">
      <bpmn:incoming>SF_38</bpmn:incoming>
      <bpmn:outgoing>SF_39</bpmn:outgoing>
    </bpmn:userTask>

    <!-- T37: Outpatient Follow-up -->
    <bpmn:userTask id="T37" name="Conduct Outpatient Follow-up Visit (Outcome Measures Review, Treatment Adherence, Motivation)">
      <bpmn:incoming>SF_39</bpmn:incoming>
      <bpmn:outgoing>SF_40</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G16: Treatment Response Evaluation -->
    <bpmn:exclusiveGateway id="G16" name="Treatment Response?">
      <bpmn:incoming>SF_40</bpmn:incoming>
      <bpmn:outgoing>SF_G16_ADEQUATE</bpmn:outgoing>
      <bpmn:outgoing>SF_G16_PARTIAL</bpmn:outgoing>
      <bpmn:outgoing>SF_G16_NONE</bpmn:outgoing>
      <bpmn:outgoing>SF_G16_DETERIORATION</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Partial response: modify plan -->
    <bpmn:userTask id="T_MODIFY_PLAN" name="Modify Treatment Plan (Add Adjunct Components or Change Modality)">
      <bpmn:incoming>SF_G16_PARTIAL</bpmn:incoming>
      <bpmn:outgoing>SF_MODIFY_LOOP</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Non-response: multidisciplinary review -->
    <bpmn:userTask id="T_MDT_REVIEW" name="Activate Multidisciplinary Review and Reconsider Diagnosis / Escalate Referral">
      <bpmn:incoming>SF_G16_NONE</bpmn:incoming>
      <bpmn:outgoing>SF_MDT_LOOP</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Deterioration: re-triggers suicide risk assessment -->
    <bpmn:userTask id="T_DETERIORATION" name="Conduct Urgent Reassessment (Clinical Deterioration, Re-evaluate Suicide Risk)">
      <bpmn:incoming>SF_G16_DETERIORATION</bpmn:incoming>
      <bpmn:outgoing>SF_DETR_LOOP</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Loop gateway: allows re-entry into treatment planning -->
    <bpmn:exclusiveGateway id="G16_LOOP_JOIN" name="Re-enter Treatment Planning">
      <bpmn:incoming>SF_MODIFY_LOOP</bpmn:incoming>
      <bpmn:incoming>SF_MDT_LOOP</bpmn:incoming>
      <bpmn:incoming>SF_DETR_LOOP</bpmn:incoming>
      <bpmn:outgoing>SF_LOOP_BACK</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T39: Relapse Prevention -->
    <bpmn:userTask id="T39" name="Conduct Relapse Prevention Session (Skills Review, Early Warning Signs, Maintenance Plan)">
      <bpmn:incoming>SF_G16_ADEQUATE</bpmn:incoming>
      <bpmn:outgoing>SF_41</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G18: Relapse / Treatment Completion -->
    <bpmn:exclusiveGateway id="G18" name="Treatment Outcome?">
      <bpmn:incoming>SF_41</bpmn:incoming>
      <bpmn:outgoing>SF_G18_COMPLETE</bpmn:outgoing>
      <bpmn:outgoing>SF_G18_CONTINUE</bpmn:outgoing>
      <bpmn:outgoing>SF_G18_RELAPSE</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Continue treatment: loop back -->
    <bpmn:exclusiveGateway id="G18_CONTINUE_JOIN" name="Continue Treatment Loop">
      <bpmn:incoming>SF_G18_CONTINUE</bpmn:incoming>
      <bpmn:incoming>SF_G18_RELAPSE</bpmn:incoming>
      <bpmn:outgoing>SF_CONTINUE_LOOP</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- T40: Record Clinical Documentation -->
    <bpmn:userTask id="T40" name="Record Clinical Documentation in Patient Health Record">
      <bpmn:incoming>SF_G18_COMPLETE</bpmn:incoming>
      <bpmn:outgoing>SF_42</bpmn:outgoing>
    </bpmn:userTask>

    <!-- G05: Multidisciplinary Parallel Assessment (AND split for complex cases) -->
    <bpmn:parallelGateway id="G05" name="Activate Multidisciplinary Parallel Assessment">
      <bpmn:incoming>SF_LOOP_BACK</bpmn:incoming>
      <bpmn:incoming>SF_CONTINUE_LOOP</bpmn:incoming>
      <bpmn:outgoing>SF_G05_PSYCH</bpmn:outgoing>
      <bpmn:outgoing>SF_G05_MED</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:userTask id="T_PSYCH_COORD" name="Coordinate Psychological and Social Care Track">
      <bpmn:incoming>SF_G05_PSYCH</bpmn:incoming>
      <bpmn:outgoing>SF_G05_PSYCH_DONE</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="T_MED_COORD" name="Coordinate Medical Specialist and Psychiatric Care Track">
      <bpmn:incoming>SF_G05_MED</bpmn:incoming>
      <bpmn:outgoing>SF_G05_MED_DONE</bpmn:outgoing>
    </bpmn:userTask>

    <!-- AND join -->
    <bpmn:parallelGateway id="G05_JOIN" name="Multidisciplinary Coordination Complete">
      <bpmn:incoming>SF_G05_PSYCH_DONE</bpmn:incoming>
      <bpmn:incoming>SF_G05_MED_DONE</bpmn:incoming>
      <bpmn:outgoing>SF_G05_DONE</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- Loop back to treatment plan update -->
    <bpmn:userTask id="T25_UPDATE" name="Update Individual Therapeutic Plan (Post-Review / Post-Relapse)">
      <bpmn:incoming>SF_G05_DONE</bpmn:incoming>
      <bpmn:outgoing>SF_BACK_TO_THERAPY</bpmn:outgoing>
    </bpmn:userTask>

    <!-- END EVENT: Treatment Complete -->
    <bpmn:endEvent id="EndEvent_TreatmentComplete" name="Treatment Goals Achieved - Patient Discharged with Relapse Prevention Plan">
      <bpmn:incoming>SF_42</bpmn:incoming>
    </bpmn:endEvent>

    <!-- SEQUENCE FLOWS -->
    <bpmn:sequenceFlow id="SF_01" sourceRef="StartEvent_1" targetRef="T01"/>
    <bpmn:sequenceFlow id="SF_02" sourceRef="T01" targetRef="T03"/>
    <bpmn:sequenceFlow id="SF_03" sourceRef="T03" targetRef="T04"/>
    <bpmn:sequenceFlow id="SF_04" sourceRef="T04" targetRef="T02"/>
    <bpmn:sequenceFlow id="SF_05" sourceRef="T02" targetRef="G01"/>
    <bpmn:sequenceFlow id="SF_G01_LOW" name="Low Risk: GP Management" sourceRef="G01" targetRef="T_GP_MONITOR"/>
    <bpmn:sequenceFlow id="SF_G01_MED" name="Medium Risk: Enhanced Psychoeducation and Physiotherapy" sourceRef="G01" targetRef="T_MED_RISK"/>
    <bpmn:sequenceFlow id="SF_G01_HIGH" name="High Risk: Mandatory Referral to Clinical Psychologist" sourceRef="G01" targetRef="T05"/>
    <bpmn:sequenceFlow id="SF_GP_END" sourceRef="T_GP_MONITOR" targetRef="EndEvent_GPMonitor"/>
    <bpmn:sequenceFlow id="SF_MED_JOIN" sourceRef="T_MED_RISK" targetRef="T05"/>
    <bpmn:sequenceFlow id="SF_06" sourceRef="T05" targetRef="T08"/>
    <bpmn:sequenceFlow id="SF_07" sourceRef="T08" targetRef="G07"/>
    <bpmn:sequenceFlow id="SF_G07_STD" name="Standard Communication and Cognition" sourceRef="G07" targetRef="T13_STD"/>
    <bpmn:sequenceFlow id="SF_G07_SPEC" name="Communication Impairment or Dementia" sourceRef="G07" targetRef="T13_SPEC"/>
    <bpmn:sequenceFlow id="SF_G07_ELD" name="Elderly Patient with Standard Cognition" sourceRef="G07" targetRef="T13_ELD"/>
    <bpmn:sequenceFlow id="SF_T13_JOIN" sourceRef="T13_STD" targetRef="G07_JOIN"/>
    <bpmn:sequenceFlow id="SF_T13_JOIN_SPEC" sourceRef="T13_SPEC" targetRef="G07_JOIN"/>
    <bpmn:sequenceFlow id="SF_T13_JOIN_ELD" sourceRef="T13_ELD" targetRef="G07_JOIN"/>
    <bpmn:sequenceFlow id="SF_08" sourceRef="G07_JOIN" targetRef="T09"/>
    <bpmn:sequenceFlow id="SF_09" sourceRef="T09" targetRef="T10"/>
    <bpmn:sequenceFlow id="SF_10" sourceRef="T10" targetRef="T11"/>
    <bpmn:sequenceFlow id="SF_11" sourceRef="T11" targetRef="T12"/>
    <bpmn:sequenceFlow id="SF_12" sourceRef="T12" targetRef="T14"/>
    <bpmn:sequenceFlow id="SF_13" sourceRef="T14" targetRef="T15"/>
    <bpmn:sequenceFlow id="SF_14" sourceRef="T15" targetRef="G06"/>
    <bpmn:sequenceFlow id="SF_G06_YES" name="Pain Diary Appropriate: Low Vigilance" sourceRef="G06" targetRef="T16"/>
    <bpmn:sequenceFlow id="SF_G06_NO" name="Pain Diary Not Appropriate: High Pain Vigilance" sourceRef="G06" targetRef="G06_JOIN"/>
    <bpmn:sequenceFlow id="SF_T16_JOIN" sourceRef="T16" targetRef="T17"/>
    <bpmn:sequenceFlow id="SF_T17_JOIN" sourceRef="T17" targetRef="G06_JOIN"/>
    <bpmn:sequenceFlow id="SF_15" sourceRef="G06_JOIN" targetRef="T20"/>
    <bpmn:sequenceFlow id="SF_16" sourceRef="T20" targetRef="T07"/>
    <bpmn:sequenceFlow id="SF_17" sourceRef="T07" targetRef="T18"/>
    <bpmn:sequenceFlow id="SF_18" sourceRef="T18" targetRef="T21"/>
    <bpmn:sequenceFlow id="SF_19" sourceRef="T21" targetRef="G19"/>
    <bpmn:sequenceFlow id="SF_G19_ONCO" name="Cancer-Related Chronic Pain (ICD-11 MG30.1)" sourceRef="G19" targetRef="T_ONCO"/>
    <bpmn:sequenceFlow id="SF_G19_STD" name="Non-Cancer Chronic Pain: Standard Pathway" sourceRef="G19" targetRef="G19_JOIN"/>
    <bpmn:sequenceFlow id="SF_ONCO_JOIN" sourceRef="T_ONCO" targetRef="G19_JOIN"/>
    <bpmn:sequenceFlow id="SF_20" sourceRef="G19_JOIN" targetRef="T22"/>
    <bpmn:sequenceFlow id="SF_21" sourceRef="T22" targetRef="T23"/>
    <bpmn:sequenceFlow id="SF_22" sourceRef="T23" targetRef="G10"/>
    <bpmn:sequenceFlow id="SF_G10_ELEVATED" name="Elevated Suicide Risk: Immediate Escalation Required" sourceRef="G10" targetRef="T06_URGENT"/>
    <bpmn:sequenceFlow id="SF_G10_NONE" name="No Elevated Suicide Risk: Continue Standard Pathway" sourceRef="G10" targetRef="G11"/>
    <bpmn:sequenceFlow id="SF_URGENT_PSYCH" sourceRef="T06_URGENT" targetRef="T19_URGENT"/>
    <bpmn:sequenceFlow id="SF_URGENT_HOSP" sourceRef="T19_URGENT" targetRef="G12_URGENT"/>
    <bpmn:sequenceFlow id="SF_HOSP_YES_URG" name="Immediate Inpatient Admission Required" sourceRef="G12_URGENT" targetRef="EndEvent_Hospitalization"/>
    <bpmn:sequenceFlow id="SF_HOSP_NO_URG" name="Outpatient Psychiatric Management Sufficient" sourceRef="G12_URGENT" targetRef="G11"/>
    <bpmn:sequenceFlow id="SF_G11_PRIMARY" name="Chronic Primary Pain (MG30.0)" sourceRef="G11" targetRef="G11_JOIN"/>
    <bpmn:sequenceFlow id="SF_G11_SECONDARY" name="Chronic Secondary Pain (MG30.1-MG30.6)" sourceRef="G11" targetRef="G11_JOIN"/>
    <bpmn:sequenceFlow id="SF_G11_PSYCH" name="Chronic Pain with Confirmed Psychiatric Comorbidity" sourceRef="G11" targetRef="G11_JOIN"/>
    <bpmn:sequenceFlow id="SF_G11_FURTHER" name="Diagnosis Unclear: Further Investigation Required" sourceRef="G11" targetRef="T_FURTHER_DIAG"/>
    <bpmn:sequenceFlow id="SF_FURTHER_JOIN" sourceRef="T_FURTHER_DIAG" targetRef="G11_JOIN"/>
    <bpmn:sequenceFlow id="SF_23" sourceRef="G11_JOIN" targetRef="T24"/>
    <bpmn:sequenceFlow id="SF_24" sourceRef="T24" targetRef="G08"/>
    <bpmn:sequenceFlow id="SF_G08_YES" name="Comorbid Insomnia Present: KBT-I Indicated" sourceRef="G08" targetRef="G08_JOIN"/>
    <bpmn:sequenceFlow id="SF_G08_NO" name="No Insomnia Comorbidity" sourceRef="G08" targetRef="G08_JOIN"/>
    <bpmn:sequenceFlow id="SF_25" sourceRef="G08_JOIN" targetRef="G09"/>
    <bpmn:sequenceFlow id="SF_G09_YES" name="Substance Use or Opioid Misuse Risk Identified" sourceRef="G09" targetRef="T_SUBSTANCE"/>
    <bpmn:sequenceFlow id="SF_G09_NO" name="No Substance Misuse Risk" sourceRef="G09" targetRef="G09_JOIN"/>
    <bpmn:sequenceFlow id="SF_G09_JOIN" sourceRef="T_SUBSTANCE" targetRef="G09_JOIN"/>
    <bpmn:sequenceFlow id="SF_26" sourceRef="G09_JOIN" targetRef="G02"/>
    <bpmn:sequenceFlow id="SF_G02_NONE" name="PHQ-9 Score Below 5: No Significant Depression" sourceRef="G02" targetRef="G02_JOIN"/>
    <bpmn:sequenceFlow id="SF_G02_MILD" name="PHQ-9 Score 5-9: Mild Depression - Monitor" sourceRef="G02" targetRef="G02_JOIN"/>
    <bpmn:sequenceFlow id="SF_G02_MODERATE" name="PHQ-9 Score 10-19: Moderate Depression - Integrate Intervention" sourceRef="G02" targetRef="G02_JOIN"/>
    <bpmn:sequenceFlow id="SF_G02_SEVERE" name="PHQ-9 Score 20+: Severe Depression - Psychiatric Referral" sourceRef="G02" targetRef="G02_JOIN"/>
    <bpmn:sequenceFlow id="SF_27" sourceRef="G02_JOIN" targetRef="G03"/>
    <bpmn:sequenceFlow id="SF_G03_MIN" name="GAD-7 Score 0-4: Minimal Anxiety" sourceRef="G03" targetRef="G03_JOIN"/>
    <bpmn:sequenceFlow id="SF_G03_MILD" name="GAD-7 Score 5-9: Mild Anxiety - Monitor" sourceRef="G03" targetRef="G03_JOIN"/>
    <bpmn:sequenceFlow id="SF_G03_MOD" name="GAD-7 Score 10-14: Moderate Anxiety - Integrate Intervention" sourceRef="G03" targetRef="G03_JOIN"/>
    <bpmn:sequenceFlow id="SF_G03_SEV" name="GAD-7 Score 15-21: Severe Anxiety - Psychiatric Referral" sourceRef="G03" targetRef="G03_JOIN"/>
    <bpmn:sequenceFlow id="SF_28" sourceRef="G03_JOIN" targetRef="T06"/>
    <bpmn:sequenceFlow id="SF_29" sourceRef="T06" targetRef="T19"/>
    <bpmn:sequenceFlow id="SF_30" sourceRef="T19" targetRef="T25"/>
    <bpmn:sequenceFlow id="SF_31" sourceRef="T25" targetRef="T26"/>
    <bpmn:sequenceFlow id="SF_32" sourceRef="T26" targetRef="T27"/>
    <bpmn:sequenceFlow id="SF_33" sourceRef="T27" targetRef="G12"/>
    <bpmn:sequenceFlow id="SF_G12_INPAT" name="Inpatient Hospitalization Required" sourceRef="G12" targetRef="EndEvent_InpatientCare"/>
    <bpmn:sequenceFlow id="SF_G12_OUTPAT" name="Outpatient Management Sufficient" sourceRef="G12" targetRef="G14_TASK"/>
    <bpmn:sequenceFlow id="SF_34" sourceRef="G14_TASK" targetRef="G14"/>
    <bpmn:sequenceFlow id="SF_G14_YES" name="Therapist Holds Valid CPČ Certification" sourceRef="G14" targetRef="G14_JOIN"/>
    <bpmn:sequenceFlow id="SF_G14_NO" name="Therapist Lacks CPČ Certification: Reassignment Required" sourceRef="G14" targetRef="T_REASSIGN"/>
    <bpmn:sequenceFlow id="SF_G14_JOIN" sourceRef="T_REASSIGN" targetRef="G14_JOIN"/>
    <bpmn:sequenceFlow id="SF_35" sourceRef="G14_JOIN" targetRef="G13"/>
    <bpmn:sequenceFlow id="SF_G13_KBT" name="KBT (CBT) Selected as First-Line Evidence-Based Modality" sourceRef="G13" targetRef="T29"/>
    <bpmn:sequenceFlow id="SF_G13_ACT" name="ACT Selected Based on Psychological Flexibility Profile" sourceRef="G13" targetRef="T30"/>
    <bpmn:sequenceFlow id="SF_G13_EMDR" name="EMDR Selected for High Emotional Distress or Trauma Component" sourceRef="G13" targetRef="T32"/>
    <bpmn:sequenceFlow id="SF_G13_ALT" name="Alternative Certified Psychotherapy Selected (ŠPI Unavailable)" sourceRef="G13" targetRef="T_ALT_PSYCH"/>
    <bpmn:sequenceFlow id="SF_T29_JOIN" sourceRef="T29" targetRef="G13_JOIN"/>
    <bpmn:sequenceFlow id="SF_T30_JOIN" sourceRef="T30" targetRef="G13_JOIN"/>
    <bpmn:sequenceFlow id="SF_T32_JOIN" sourceRef="T32" targetRef="G13_JOIN"/>
    <bpmn:sequenceFlow id="SF_TALT_JOIN" sourceRef="T_ALT_PSYCH" targetRef="G13_JOIN"/>
    <bpmn:sequenceFlow id="SF_36" sourceRef="G13_JOIN" targetRef="T28"/>
    <bpmn:sequenceFlow id="SF_37" sourceRef="T28" targetRef="G15"/>
    <bpmn:sequenceFlow id="SF_G15_BIO" name="Biofeedback Added as Supportive Component" sourceRef="G15" targetRef="T33"/>
    <bpmn:sequenceFlow id="SF_G15_RELAX" name="Progressive Muscle Relaxation Added" sourceRef="G15" targetRef="T34"/>
    <bpmn:sequenceFlow id="SF_G15_PHARMA" name="Pharmacotherapy Added (Antidepressant Consideration)" sourceRef="G15" targetRef="T35"/>
    <bpmn:sequenceFlow id="SF_G15_SOCIAL" name="Social Intervention Added (Social Problems Identified)" sourceRef="G15" targetRef="T36"/>
    <bpmn:sequenceFlow id="SF_G15_INSOMNIA" name="KBT-I Added (Insomnia Comorbidity Confirmed)" sourceRef="G15" targetRef="T31"/>
    <bpmn:sequenceFlow id="SF_T33_JOIN" sourceRef="T33" targetRef="G15_JOIN"/>
    <bpmn:sequenceFlow id="SF_T34_JOIN" sourceRef="T34" targetRef="G15_JOIN"/>
    <bpmn:sequenceFlow id="SF_T35_JOIN" sourceRef="T35" targetRef="G15_JOIN"/>
    <bpmn:sequenceFlow id="SF_T36_JOIN" sourceRef="T36" targetRef="G15_JOIN"/>
    <bpmn:sequenceFlow id="SF_T31_JOIN" sourceRef="T31" targetRef="G17"/>
    <bpmn:sequenceFlow id="SF_G17_YES" name="Sleep Efficiency ≥ 90%: Upward Titration Indicated" sourceRef="G17" targetRef="T_TITRATION"/>
