<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_0cwasaq" targetNamespace="http://bpmn.io/schema/bpmn" xmlns:modeler="http://camunda.org/schema/modeler/1.0" exporter="Camunda Modeler" exporterVersion="5.33.1" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.22.0">
  <bpmn:process id="Process_0hbbe8d" name="Management of Adult Patient with Depressive Disorder" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Suspected Depressive Disorder Identified">
      <bpmn:outgoing>Flow_StartToScreening</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_InitialScreening" name="Perform Initial Screening" camunda:candidateGroups="GP">
      <bpmn:incoming>Flow_StartToScreening</bpmn:incoming>
      <bpmn:outgoing>Flow_ScreeningToSuicideRisk</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_IdentifySuicideRisk" name="Identify Suicide and Self-Harm Risk" camunda:candidateGroups="GP_Specialist">
      <bpmn:incoming>Flow_ScreeningToSuicideRisk</bpmn:incoming>
      <bpmn:outgoing>Flow_SuicideRiskToGateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_SuicideRisk" name="High Suicide Risk Identified?">
      <bpmn:incoming>Flow_SuicideRiskToGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_HighSuicideRisk</bpmn:outgoing>
      <bpmn:outgoing>Flow_LowSuicideRisk</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_CrisisIntervention" name="Execute Crisis Intervention and Hospitalization" camunda:candidateGroups="Psychiatrist">
      <bpmn:incoming>Flow_HighSuicideRisk</bpmn:incoming>
      <bpmn:outgoing>Flow_CrisisToEnd</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Crisis" name="Emergency Care Transitioned">
      <bpmn:incoming>Flow_CrisisToEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_IdentifySyndrome" name="Identify Disorder Syndrome" camunda:candidateGroups="GP">
      <bpmn:incoming>Flow_LowSuicideRisk</bpmn:incoming>
      <bpmn:outgoing>Flow_SyndromeToCompetency</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_CompetencyCheck" name="Practitioner Competent for Mental State Assessment?">
      <bpmn:incoming>Flow_SyndromeToCompetency</bpmn:incoming>
      <bpmn:outgoing>Flow_ReferralRequired</bpmn:outgoing>
      <bpmn:outgoing>Flow_CompetencyVerified</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ReferToSpecialist" name="Refer to Clinical Psychologist or Psychiatrist" camunda:candidateGroups="GP">
      <bpmn:incoming>Flow_ReferralRequired</bpmn:incoming>
      <bpmn:outgoing>Flow_ReferralToDiag</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Psychodiagnostics" name="Perform Psychodiagnostic Examination" camunda:candidateGroups="Clinical_Psychologist">
      <bpmn:incoming>Flow_ReferralToDiag</bpmn:incoming>
      <bpmn:incoming>Flow_CompetencyVerified</bpmn:incoming>
      <bpmn:outgoing>Flow_DiagToAssessment</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_StandardizedQuestionnaires" name="Administer Standardized Questionnaires (PHQ-9/BDI-II)" camunda:candidateGroups="Clinician">
      <bpmn:incoming>Flow_DiagToAssessment</bpmn:incoming>
      <bpmn:outgoing>Flow_AssessmentToRule</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:businessRuleTask id="Task_DetermineSeverity" name="Determine Depression Severity and Stepped Care Level" camunda:decisionRef="Decision_SeverityScoring">
      <bpmn:incoming>Flow_AssessmentToRule</bpmn:incoming>
      <bpmn:incoming>Flow_InadequateResponse</bpmn:incoming>
      <bpmn:outgoing>Flow_RuleToSelection</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_TreatmentSelection" name="Select Treatment Step">
      <bpmn:incoming>Flow_RuleToSelection</bpmn:incoming>
      <bpmn:outgoing>Flow_RouteStep1</bpmn:outgoing>
      <bpmn:outgoing>Flow_RouteStep2</bpmn:outgoing>
      <bpmn:outgoing>Flow_RouteStep3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_Step1_ActiveMonitoring" name="Provide Active Monitoring and Psychoeducation" camunda:candidateGroups="Healthcare_Worker">
      <bpmn:incoming>Flow_RouteStep1</bpmn:incoming>
      <bpmn:outgoing>Flow_Step1ToEval</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_Step2_IKBT" name="Administer Computerized CBT (IKBT) and Self-Help" camunda:type="external" camunda:topic="ikbt_service">
      <bpmn:incoming>Flow_RouteStep2</bpmn:incoming>
      <bpmn:outgoing>Flow_Step2ToEval</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_Step3_Intensive" name="Provide High-Intensity Therapy and Pharmacotherapy" camunda:candidateGroups="Specialist">
      <bpmn:incoming>Flow_RouteStep3</bpmn:incoming>
      <bpmn:outgoing>Flow_Step3ToEval</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_TreatmentEvaluation" name="Treatment Effective after Monitoring Period?">
      <bpmn:incoming>Flow_Step1ToEval</bpmn:incoming>
      <bpmn:incoming>Flow_Step2ToEval</bpmn:incoming>
      <bpmn:incoming>Flow_Step3ToEval</bpmn:incoming>
      <bpmn:outgoing>Flow_ImprovedRemission</bpmn:outgoing>
      <bpmn:outgoing>Flow_InadequateResponse</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_Remission" name="Remission and Maintenance Phase Achieved">
      <bpmn:incoming>Flow_ImprovedRemission</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_StartToScreening" sourceRef="StartEvent_1" targetRef="Task_InitialScreening" />
    <bpmn:sequenceFlow id="Flow_ScreeningToSuicideRisk" sourceRef="Task_InitialScreening" targetRef="Task_IdentifySuicideRisk" />
    <bpmn:sequenceFlow id="Flow_SuicideRiskToGateway" sourceRef="Task_IdentifySuicideRisk" targetRef="Gateway_SuicideRisk" />
    <bpmn:sequenceFlow id="Flow_HighSuicideRisk" name="High Risk Identified" sourceRef="Gateway_SuicideRisk" targetRef="Task_CrisisIntervention" />
    <bpmn:sequenceFlow id="Flow_LowSuicideRisk" name="Low / Managed Risk" sourceRef="Gateway_SuicideRisk" targetRef="Task_IdentifySyndrome" />
    <bpmn:sequenceFlow id="Flow_CrisisToEnd" sourceRef="Task_CrisisIntervention" targetRef="EndEvent_Crisis" />
    <bpmn:sequenceFlow id="Flow_SyndromeToCompetency" sourceRef="Task_IdentifySyndrome" targetRef="Gateway_CompetencyCheck" />
    <bpmn:sequenceFlow id="Flow_ReferralRequired" name="Specialist Referral Needed" sourceRef="Gateway_CompetencyCheck" targetRef="Task_ReferToSpecialist" />
    <bpmn:sequenceFlow id="Flow_CompetencyVerified" name="Practitioner Competent" sourceRef="Gateway_CompetencyCheck" targetRef="Task_Psychodiagnostics" />
    <bpmn:sequenceFlow id="Flow_ReferralToDiag" sourceRef="Task_ReferToSpecialist" targetRef="Task_Psychodiagnostics" />
    <bpmn:sequenceFlow id="Flow_DiagToAssessment" sourceRef="Task_Psychodiagnostics" targetRef="Task_StandardizedQuestionnaires" />
    <bpmn:sequenceFlow id="Flow_AssessmentToRule" sourceRef="Task_StandardizedQuestionnaires" targetRef="Task_DetermineSeverity" />
    <bpmn:sequenceFlow id="Flow_RuleToSelection" sourceRef="Task_DetermineSeverity" targetRef="Gateway_TreatmentSelection" />
    <bpmn:sequenceFlow id="Flow_RouteStep1" name="Subclinical / Initial (Step 1)" sourceRef="Gateway_TreatmentSelection" targetRef="Task_Step1_ActiveMonitoring" />
    <bpmn:sequenceFlow id="Flow_RouteStep2" name="Mild / Moderate (Step 2)" sourceRef="Gateway_TreatmentSelection" targetRef="Task_Step2_IKBT" />
    <bpmn:sequenceFlow id="Flow_RouteStep3" name="Moderate / Severe (Step 3)" sourceRef="Gateway_TreatmentSelection" targetRef="Task_Step3_Intensive" />
    <bpmn:sequenceFlow id="Flow_Step1ToEval" sourceRef="Task_Step1_ActiveMonitoring" targetRef="Gateway_TreatmentEvaluation" />
    <bpmn:sequenceFlow id="Flow_Step2ToEval" sourceRef="Task_Step2_IKBT" targetRef="Gateway_TreatmentEvaluation" />
    <bpmn:sequenceFlow id="Flow_Step3ToEval" sourceRef="Task_Step3_Intensive" targetRef="Gateway_TreatmentEvaluation" />
    <bpmn:sequenceFlow id="Flow_ImprovedRemission" name="Improved / Remitted" sourceRef="Gateway_TreatmentEvaluation" targetRef="EndEvent_Remission" />
    <bpmn:sequenceFlow id="Flow_InadequateResponse" name="Symptoms Persistent" sourceRef="Gateway_TreatmentEvaluation" targetRef="Task_DetermineSeverity" />
  </bpmn:process>
