<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  id="Definitions_DepressionManagement"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
                  exporter="Camunda Modeler"
                  exporterVersion="5.33.1"
                  modeler:executionPlatform="Camunda Platform"
                  modeler:executionPlatformVersion="7.22.0">

  <!-- ═══════════════════════════════════════════════════════════
       COLLABORATION
  ═══════════════════════════════════════════════════════════ -->
  <bpmn:collaboration id="Collaboration_Depression">
    <bpmn:participant id="Participant_GP"             name="Všeobecný lekár (GP)"          processRef="Process_GP"/>
    <bpmn:participant id="Participant_Specialist"     name="Klinický psychológ / Psychiater" processRef="Process_Specialist"/>
    <bpmn:participant id="Participant_Patient"        name="Pacient"                         processRef="Process_Patient"/>
  </bpmn:collaboration>

  <!-- ═══════════════════════════════════════════════════════════
       PROCESS – GP
  ═══════════════════════════════════════════════════════════ -->
  <bpmn:process id="Process_GP" name="Proces – Všeobecný lekár" isExecutable="true">

    <bpmn:startEvent id="SE_PatientPresents" name="Pacient príde k lekárovi">
      <bpmn:outgoing>SF_SE_to_Screening</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="T_Screening" name="Skríning depresie&#10;(PHQ-9, 2 otázky NICE)">
      <bpmn:incoming>SF_SE_to_Screening</bpmn:incoming>
      <bpmn:outgoing>SF_Screening_to_GW1</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="GW_DepressionSuspected" name="Podozrenie&#10;na depresiu?">
      <bpmn:incoming>SF_Screening_to_GW1</bpmn:incoming>
      <bpmn:outgoing>SF_NoDepression</bpmn:outgoing>
      <bpmn:outgoing>SF_DepressionSuspected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="T_NoDepressionFollowUp" name="Bežná starostlivosť /&#10;sledovanie">
      <bpmn:incoming>SF_NoDepression</bpmn:incoming>
      <bpmn:outgoing>SF_NoDepression_End</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EE_NoDepression" name="Ukončenie (bez depresie)">
      <bpmn:incoming>SF_NoDepression_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="T_ExcludeSomatic" name="Vylúčenie somatických príčin&#10;(lab., anamnéza, EEG, CT)">
      <bpmn:incoming>SF_DepressionSuspected</bpmn:incoming>
      <bpmn:outgoing>SF_Excl_to_GW2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="GW_SomaticCause" name="Somatická príčina?">
      <bpmn:incoming>SF_Excl_to_GW2</bpmn:incoming>
      <bpmn:outgoing>SF_SomaticYes</bpmn:outgoing>
      <bpmn:outgoing>SF_SomaticNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="T_TreatSomatic" name="Liečba somatickej príčiny&#10;/ odoslanie k špecialistovi">
      <bpmn:incoming>SF_SomaticYes</bpmn:incoming>
      <bpmn:outgoing>SF_TreatSomatic_End</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EE_SomaticTreated" name="Ukončenie (somatická liečba)">
      <bpmn:incoming>SF_TreatSomatic_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:task id="T_AssessSeverity_GP" name="Posúdenie závažnosti depresie&#10;(PHQ-9 skóre)">
      <bpmn:incoming>SF_SomaticNo</bpmn:incoming>
      <bpmn:outgoing>SF_Severity_to_GW3</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="GW_Severity_GP" name="Závažnosť depresie?">
      <bpmn:incoming>SF_Severity_to_GW3</bpmn:incoming>
      <bpmn:outgoing>SF_MildGP</bpmn:outgoing>
      <bpmn:outgoing>SF_ModSevereGP</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Mild: GP manages + active monitoring -->
    <bpmn:task id="T_GP_ActiveMonitoring" name="Edukácia, aktívne monitorovanie&#10;(kontrola o 2 týždne)">
      <bpmn:incoming>SF_MildGP</bpmn:incoming>
      <bpmn:outgoing>SF_Monitor_to_GW4</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="GW_Improvement_GP" name="Nastáva zlepšenie?">
      <bpmn:incoming>SF_Monitor_to_GW4</bpmn:incoming>
      <bpmn:outgoing>SF_ImprovementYes_GP</bpmn:outgoing>
      <bpmn:outgoing>SF_ImprovementNo_GP</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="T_GP_ContinueMonitor" name="Pokračovanie v sledovaní&#10;+ katamnestická starostlivosť">
      <bpmn:incoming>SF_ImprovementYes_GP</bpmn:incoming>
      <bpmn:outgoing>SF_ContinueMonitor_End</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EE_GP_Resolved" name="Pacient stabilizovaný">
      <bpmn:incoming>SF_ContinueMonitor_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Referral to specialist -->
    <bpmn:task id="T_ReferToSpecialist" name="Odoslanie ku klinickému&#10;psychológovi / psychiatrovi">
      <bpmn:incoming>SF_ImprovementNo_GP</bpmn:incoming>
      <bpmn:incoming>SF_ModSevereGP</bpmn:incoming>
      <bpmn:outgoing>SF_Refer_MsgOut</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EE_GP_Referred" name="Pacient odoslaný">
      <bpmn:incoming>SF_Refer_MsgOut</bpmn:incoming>
      <bpmn:messageEventDefinition id="MED_ReferOut" messageRef="Msg_Referral"/>
    </bpmn:endEvent>

    <!-- Sequence flows GP -->
    <bpmn:sequenceFlow id="SF_SE_to_Screening"      sourceRef="SE_PatientPresents"      targetRef="T_Screening"/>
    <bpmn:sequenceFlow id="SF_Screening_to_GW1"     sourceRef="T_Screening"             targetRef="GW_DepressionSuspected"/>
    <bpmn:sequenceFlow id="SF_NoDepression"          sourceRef="GW_DepressionSuspected"  targetRef="T_NoDepressionFollowUp" name="Nie"/>
    <bpmn:sequenceFlow id="SF_DepressionSuspected"   sourceRef="GW_DepressionSuspected"  targetRef="T_ExcludeSomatic"       name="Áno"/>
    <bpmn:sequenceFlow id="SF_NoDepression_End"      sourceRef="T_NoDepressionFollowUp"  targetRef="EE_NoDepression"/>
    <bpmn:sequenceFlow id="SF_Excl_to_GW2"           sourceRef="T_ExcludeSomatic"        targetRef="GW_SomaticCause"/>
    <bpmn:sequenceFlow id="SF_SomaticYes"            sourceRef="GW_SomaticCause"         targetRef="T_TreatSomatic"         name="Áno"/>
    <bpmn:sequenceFlow id="SF_SomaticNo"             sourceRef="GW_SomaticCause"         targetRef="T_AssessSeverity_GP"    name="Nie"/>
    <bpmn:sequenceFlow id="SF_TreatSomatic_End"      sourceRef="T_TreatSomatic"          targetRef="EE_SomaticTreated"/>
    <bpmn:sequenceFlow id="SF_Severity_to_GW3"       sourceRef="T_AssessSeverity_GP"     targetRef="GW_Severity_GP"/>
    <bpmn:sequenceFlow id="SF_MildGP"                sourceRef="GW_Severity_GP"          targetRef="T_GP_ActiveMonitoring"  name="Mierna depresia"/>
    <bpmn:sequenceFlow id="SF_ModSevereGP"           sourceRef="GW_Severity_GP"          targetRef="T_ReferToSpecialist"    name="Stredná / Ťažká"/>
    <bpmn:sequenceFlow id="SF_Monitor_to_GW4"        sourceRef="T_GP_ActiveMonitoring"   targetRef="GW_Improvement_GP"/>
    <bpmn:sequenceFlow id="SF_ImprovementYes_GP"     sourceRef="GW_Improvement_GP"       targetRef="T_GP_ContinueMonitor"   name="Áno"/>
    <bpmn:sequenceFlow id="SF_ImprovementNo_GP"      sourceRef="GW_Improvement_GP"       targetRef="T_ReferToSpecialist"    name="Nie"/>
    <bpmn:sequenceFlow id="SF_ContinueMonitor_End"   sourceRef="T_GP_ContinueMonitor"    targetRef="EE_GP_Resolved"/>
    <bpmn:sequenceFlow id="SF_Refer_MsgOut"          sourceRef="T_ReferToSpecialist"     targetRef="EE_GP_Referred"/>
  </bpmn:process>

  <!-- ═══════════════════════════════════════════════════════════
       PROCESS – SPECIALIST (Clinical Psychologist / Psychiatrist)
  ═══════════════════════════════════════════════════════════ -->
  <bpmn:process id="Process_Specialist" name="Proces – Klinický psychológ / Psychiater" isExecutable="true">

    <bpmn:startEvent id="SE_SpecialistReceives" name="Prijatie pacienta">
      <bpmn:outgoing>SF_Sp_Start_to_Assess</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MED_ReferIn" messageRef="Msg_Referral"/>
    </bpmn:startEvent>

    <!-- Comprehensive assessment -->
    <bpmn:task id="T_Sp_Assessment" name="Komplexné psychologické vyšetrenie&#10;(PHQ-9, BDI-II, HAMD, MMPI,&#10;anamnéza, suicidálne riziko)">
      <bpmn:incoming>SF_Sp_Start_to_Assess</bpmn:incoming>
      <bpmn:outgoing>SF_Assess_to_SuicideGW</bpmn:outgoing>
    </bpmn:task>

    <!-- Suicide risk -->
    <bpmn:exclusiveGateway id="GW_SuicideRisk" name="Vysoké suicidálne&#10;riziko?">
      <bpmn:incoming>SF_Assess_to_SuicideGW</bpmn:incoming>
      <bpmn:outgoing>SF_SuicideYes</bpmn:outgoing>
      <bpmn:outgoing>SF_SuicideNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="T_CrisisIntervention" name="Krízová intervencia&#10;+ zváženie hospitalizácie (Stupeň 4)">
      <bpmn:incoming>SF_SuicideYes</bpmn:incoming>
      <bpmn:outgoing>SF_Crisis_to_Stabilise</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="T_Stabilise" name="Stabilizácia pacienta&#10;+ intenzívna psychosociálna liečba">
      <bpmn:incoming>SF_Crisis_to_Stabilise</bpmn:incoming>
      <bpmn:outgoing>SF_Stabilise_to_SeverityGW</bpmn:outgoing>
    </bpmn:task>

    <!-- Severity classification -->
    <bpmn:exclusiveGateway id="GW_Sp_Severity" name="Závažnosť depresie?">
      <bpmn:incoming>SF_SuicideNo</bpmn:incoming>
      <bpmn:incoming>SF_Stabilise_to_SeverityGW</bpmn:incoming>
      <bpmn:outgoing>SF_Step2</bpmn:outgoing>
      <bpmn:outgoing>SF_Step3</bpmn:outgoing>
      <bpmn:outgoing>SF_Step4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ── STEP 2: mild / subthreshold ── -->
    <bpmn:subProcess id="SP_Step2" name="Stupeň 2: Mierna / subklinická depresia">
      <bpmn:incoming>SF_Step2</bpmn:incoming>
      <bpmn:outgoing>SF_Step2_to_ImprovGW</bpmn:outgoing>

      <bpmn:startEvent id="SE_Step2"/>
      <bpmn:parallelGateway id="PGW_Step2_Options" name="Vyber ŠPI intervencií"/>

      <bpmn:task id="T_Step2_SelfHelpCBT"   name="Individuálna svojpomocná liečba&#10;(princípy KBT, 6-8 sedení / 9-12 týž.)"/>
      <bpmn:task id="T_Step2_ComputerCBT"   name="Počítačová / internetová KBT&#10;(9-12 týždňov)"/>
      <bpmn:task id="T_Step2_PhysActivity"  name="Skupinový program fyzickej aktivity&#10;(3× týžd., 45-60 min., 10-14 dní)"/>
      <bpmn:task id="T_Step2_Psychoedu"     name="Psychoedukácia o depresii&#10;a spánková hygiena"/>

      <bpmn:parallelGateway id="PGW_Step2_Join" name="Dokončenie ŠPI"/>
      <bpmn:endEvent id="EE_Step2"/>

      <bpmn:sequenceFlow id="SF_Step2_SE_to_PGW"        sourceRef="SE_Step2"             targetRef="PGW_Step2_Options"/>
      <bpmn:sequenceFlow id="SF_Step2_PGW_to_SelfHelp"  sourceRef="PGW_Step2_Options"    targetRef="T_Step2_SelfHelpCBT"/>
      <bpmn:sequenceFlow id="SF_Step2_PGW_to_CompCBT"   sourceRef="PGW_Step2_Options"    targetRef="T_Step2_ComputerCBT"/>
      <bpmn:sequenceFlow id="SF_Step2_PGW_to_Phys"      sourceRef="PGW_Step2_Options"    targetRef="T_Step2_PhysActivity"/>
      <bpmn:sequenceFlow id="SF_Step2_PGW_to_Edu"       sourceRef="PGW_Step2_Options"    targetRef="T_Step2_Psychoedu"/>
      <bpmn:sequenceFlow id="SF_Step2_SelfHelp_to_Join" sourceRef="T_Step2_SelfHelpCBT"  targetRef="PGW_Step2_Join"/>
      <bpmn:sequenceFlow id="SF_Step2_CompCBT_to_Join"  sourceRef="T_Step2_ComputerCBT"  targetRef="PGW_Step2_Join"/>
      <bpmn:sequenceFlow id="SF_Step2_Phys_to_Join"     sourceRef="T_Step2_PhysActivity" targetRef="PGW_Step2_Join"/>
      <bpmn:sequenceFlow id="SF_Step2_Edu_to_Join"      sourceRef="T_Step2_Psychoedu"    targetRef="PGW_Step2_Join"/>
      <bpmn:sequenceFlow id="SF_Step2_Join_to_EE"       sourceRef="PGW_Step2_Join"       targetRef="EE_Step2"/>
    </bpmn:subProcess>

    <!-- ── STEP 3: moderate / severe ── -->
    <bpmn:subProcess id="SP_Step3" name="Stupeň 3: Stredná / Ťažká depresia">
      <bpmn:incoming>SF_Step3</bpmn:incoming>
      <bpmn:outgoing>SF_Step3_to_ImprovGW</bpmn:outgoing>

      <bpmn:startEvent id="SE_Step3"/>

      <bpmn:task id="T_Step3_Pharma" name="Farmakoterapia (antidepresíva)&#10;– v kompetencii psychiatra"/>

      <bpmn:exclusiveGateway id="GW_TherapyChoice" name="Výber psychoterapie">
        <bpmn:outgoing>SF_Choice_KBT</bpmn:outgoing>
        <bpmn:outgoing>SF_Choice_IPT</bpmn:outgoing>
        <bpmn:outgoing>SF_Choice_BA</bpmn:outgoing>
        <bpmn:outgoing>SF_Choice_Couples</bpmn:outgoing>
        <bpmn:outgoing>SF_Choice_Psychodyn</bpmn:outgoing>
      </bpmn:exclusiveGateway>

      <bpmn:task id="T_Step3_KBT"      name="KBT (16-20 sedení / 3-4 mes.)&#10;2× týžd. v prvých 2-3 týžd."/>
      <bpmn:task id="T_Step3_IPT"      name="IPT (16-20 sedení / 3-4 mes.)"/>
      <bpmn:task id="T_Step3_BA"       name="Behaviorálna aktivácia&#10;(16-20 sedení / 3-4 mes.)"/>
      <bpmn:task id="T_Step3_Couples"  name="Párová / rodinná terapia&#10;(15-20 sedení / 5-6 mes.)"/>
      <bpmn:task id="T_Step3_Psychodyn"name="Krátkodobá psychodynamická&#10;terapia (16-20 sedení / 4-6 mes.)"/>

      <bpmn:exclusiveGateway id="GW_Step3_TherapyJoin" name="Zlúčenie výsledku terapie"/>

      <bpmn:task id="T_Step3_Monitoring" name="Priebežné dotazníkové monitorovanie&#10;(PHQ-9, BDI-II)"/>
      <bpmn:endEvent id="EE_Step3"/>

      <bpmn:sequenceFlow id="SF_Step3_SE_to_Pharma"    sourceRef="SE_Step3"            targetRef="T_Step3_Pharma"/>
      <bpmn:sequenceFlow id="SF_Step3_Pharma_to_Choice" sourceRef="T_Step3_Pharma"      targetRef="GW_TherapyChoice"/>
      <bpmn:sequenceFlow id="SF_Choice_KBT"             sourceRef="GW_TherapyChoice"    targetRef="T_Step3_KBT"       name="KBT"/>
      <bpmn:sequenceFlow id="SF_Choice_IPT"             sourceRef="GW_TherapyChoice"    targetRef="T_Step3_IPT"       name="IPT"/>
      <bpmn:sequenceFlow id="SF_Choice_BA"              sourceRef="GW_TherapyChoice"    targetRef="T_Step3_BA"        name="Beh. aktivácia"/>
      <bpmn:sequenceFlow id="SF_Choice_Couples"         sourceRef="GW_TherapyChoice"    targetRef="T_Step3_Couples"   name="Párová/rodinná"/>
      <bpmn:sequenceFlow id="SF_Choice_Psychodyn"       sourceRef="GW_TherapyChoice"    targetRef="T_Step3_Psychodyn" name="Psychodyn."/>
      <bpmn:sequenceFlow id="SF_KBT_to_Join"            sourceRef="T_Step3_KBT"         targetRef="GW_Step3_TherapyJoin"/>
      <bpmn:sequenceFlow id="SF_IPT_to_Join"            sourceRef="T_Step3_IPT"         targetRef="GW_Step3_TherapyJoin"/>
      <bpmn:sequenceFlow id="SF_BA_to_Join"             sourceRef="T_Step3_BA"          targetRef="GW_Step3_TherapyJoin"/>
      <bpmn:sequenceFlow id="SF_Couples_to_Join"        sourceRef="T_Step3_Couples"     targetRef="GW_Step3_TherapyJoin"/>
      <bpmn:sequenceFlow id="SF_Psychodyn_to_Join"      sourceRef="T_Step3_Psychodyn"   targetRef="GW_Step3_TherapyJoin"/>
      <bpmn:sequenceFlow id="SF_Step3_Join_to_Monitor"  sourceRef="GW_Step3_TherapyJoin" targetRef="T_Step3_Monitoring"/>
      <bpmn:sequenceFlow id="SF_Step3_Monitor_to_EE"    sourceRef="T_Step3_Monitoring"  targetRef="EE_Step3"/>
    </bpmn:subProcess>

    <!-- ── STEP 4: severe / psychotic ── -->
    <bpmn:subProcess id="SP_Step4" name="Stupeň 4: Komplexná / ťažká depresia">
      <bpmn:incoming>SF_Step4</bpmn:incoming>
      <bpmn:outgoing>SF_Step4_to_ImprovGW</bpmn:outgoing>

      <bpmn:startEvent id="SE_Step4"/>
      <bpmn:task id="T_Step4_Hospitalise"  name="Hospitalizácia&#10;(zváženie pri suicidálnom riziku)"/>
      <bpmn:task id="T_Step4_ECT"          name="Elektrokonvulzívna terapia (ECT)&#10;+ Farmakoterapia"/>
      <bpmn:task id="T_Step4_IntensivePsycho" name="Intenzívna psychosociálna liečba&#10;(vysoká frekvencia sedení)"/>
      <bpmn:task id="T_Step4_Monitoring"   name="Nepretržité monitorovanie&#10;suicidálneho rizika"/>
      <bpmn:endEvent id="EE_Step4"/>

      <bpmn:sequenceFlow id="SF_Step4_SE_to_Hosp"    sourceRef="SE_Step4"              targetRef="T_Step4_Hospitalise"/>
      <bpmn:sequenceFlow id="SF_Step4_Hosp_to_ECT"   sourceRef="T_Step4_Hospitalise"   targetRef="T_Step4_ECT"/>
      <bpmn:sequenceFlow id="SF_Step4_ECT_to_Psycho" sourceRef="T_Step4_ECT"           targetRef="T_Step4_IntensivePsycho"/>
      <bpmn:sequenceFlow id="SF_Step4_Psycho_to_Mon" sourceRef="T_Step4_IntensivePsycho" targetRef="T_Step4_Monitoring"/>
      <bpmn:sequenceFlow id="SF_Step4_Mon_to_EE"     sourceRef="T_Step4_Monitoring"    targetRef="EE_Step4"/>
    </bpmn:subProcess>

    <!-- Post-treatment improvement check -->
    <bpmn:exclusiveGateway id="GW_Sp_Improvement" name="Dostatočná odpoveď&#10;na liečbu?">
      <bpmn:incoming>SF_Step2_to_ImprovGW</bpmn:incoming>
      <bpmn:incoming>SF_Step3_to_ImprovGW</bpmn:incoming>
      <bpmn:incoming>SF_Step4_to_ImprovGW</bpmn:incoming>
      <bpmn:outgoing>SF_Sp_ImprovYes</bpmn:outgoing>
      <bpmn:outgoing>SF_Sp_ImprovNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Relapse prevention -->
    <bpmn:subProcess id="SP_RelapsePrevention" name="Udržiavacia liečba a prevencia relapsu">
      <bpmn:incoming>SF_Sp_ImprovYes</bpmn:incoming>
      <bpmn:outgoing>SF_Relapse_to_End</bpmn:outgoing>

      <bpmn:startEvent id="SE_Relapse"/>
      <bpmn:task id="T_Relapse_RiskAssess"  name="Posúdenie rizika relapsu&#10;(anamnéza, reziduálne symptómy)"/>
      <bpmn:exclusiveGateway id="GW_RelapseRisk" name="Vysoké riziko relapsu?">
        <bpmn:outgoing>SF_RR_High</bpmn:outgoing>
        <bpmn:outgoing>SF_RR_Low</bpmn:outgoing>
      </bpmn:exclusiveGateway>

      <bpmn:task id="T_Relapse_MBCT"    name="MBCT (skupinová, 8 týždňov)&#10;pre ≥3 predchádzajúce epizódy"/>
      <bpmn:task id="T_Relapse_KBT_IPT" name="KBT / IPT pre prevenciu relapsu&#10;(16-20 sedení / 3-4 mes.)"/>
      <bpmn:task id="T_Relapse_Pharma"  name="Pokračovanie antidepresív&#10;min. 6 mes. po remisii"/>
      <bpmn:exclusiveGateway id="GW_Relapse_Join" name="Zlúčenie"/>
      <bpmn:task id="T_Relapse_Monitor" name="Systematické posudzovanie&#10;(PHQ-9, BDI-II, funkčnosť)"/>
      <bpmn:task id="T_Relapse_FollowUp" name="Katamnestické sledovanie&#10;+ kontrolné sedenia"/>
      <bpmn:endEvent id="EE_Relapse"/>

      <bpmn:sequenceFlow id="SF_R_SE_to_RiskA"    sourceRef="SE_Relapse"           targetRef="T_Relapse_RiskAssess"/>
      <bpmn:sequenceFlow id="SF_R_RiskA_to_GW"    sourceRef="T_Relapse_RiskAssess" targetRef="GW_RelapseRisk"/>
      <bpmn:sequenceFlow id="SF_RR_High"           sourceRef="GW_RelapseRisk"       targetRef="T_Relapse_MBCT"     name="Áno"/>
      <bpmn:sequenceFlow id="SF_RR_Low"            sourceRef="GW_RelapseRisk"       targetRef="T_Relapse_KBT_IPT"  name="Nie"/>
      <bpmn:sequenceFlow id="SF_MBCT_to_Pharma"    sourceRef="T_Relapse_MBCT"       targetRef="T_Relapse_Pharma"/>
      <bpmn:sequenceFlow id="SF_KBT_IPT_to_Pharma" sourceRef="T_Relapse_KBT_IPT"   targetRef="T_Relapse_Pharma"/>
      <bpmn:sequenceFlow id="SF_Pharma_to_Join"    sourceRef="T_Relapse_Pharma"     targetRef="GW_Relapse_Join"/>
      <bpmn:sequenceFlow id="SF_Join_to_Monitor"   sourceRef="GW_Relapse_Join"      targetRef="T_Relapse_Monitor"/>
      <bpmn:sequenceFlow id="SF_Monitor_to_FU"     sourceRef="T_Relapse_Monitor"    targetRef="T_Relapse_FollowUp"/>
      <bpmn:sequenceFlow id="SF_FU_to_EE"          sourceRef="T_Relapse_FollowUp"   targetRef="EE_Relapse"/>
    </bpmn:subProcess>

    <!-- Treatment change if no improvement -->
    <bpmn:task id="T_ChangeTreatment" name="Zmena terapeutického prístupu&#10;/ eskalácia na vyšší stupeň&#10;/ odporučenie psychiatrovi">
      <bpmn:incoming>SF_Sp_ImprovNo</bpmn:incoming>
      <bpmn:outgoing>SF_Change_to_Severity</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EE_Sp_Completed" name="Liečba úspešne ukončená">
      <bpmn:incoming>SF_Relapse_to_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence flows Specialist (outer) -->
    <bpmn:sequenceFlow id="SF_Sp_Start_to_Assess"    sourceRef="SE_SpecialistReceives" targetRef="T_Sp_Assessment"/>
    <bpmn:sequenceFlow id="SF_Assess_to_SuicideGW"   sourceRef="T_Sp_Assessment"       targetRef="GW_SuicideRisk"/>
    <bpmn:sequenceFlow id="SF_SuicideYes"             sourceRef="GW_SuicideRisk"        targetRef="T_CrisisIntervention"    name="Áno"/>
    <bpmn:sequenceFlow id="SF_SuicideNo"              sourceRef="GW_SuicideRisk"        targetRef="GW_Sp_Severity"          name="Nie"/>
    <bpmn:sequenceFlow id="SF_Crisis_to_Stabilise"    sourceRef="T_CrisisIntervention"  targetRef="T_Stabilise"/>
    <bpmn:sequenceFlow id="SF_Stabilise_to_SeverityGW" sourceRef="T_Stabilise"          targetRef="GW_Sp_Severity"/>
    <bpmn:sequenceFlow id="SF_Step2"                  sourceRef="GW_Sp_Severity"        targetRef="SP_Step2"                name="Mierna / subklinická"/>
    <bpmn:sequenceFlow id="SF_Step3"                  sourceRef="GW_Sp_Severity"        targetRef="SP_Step3"                name="Stredná / Ťažká"/>
    <bpmn:sequenceFlow id="SF_Step4"                  sourceRef="GW_Sp_Severity"        targetRef="SP_Step4"                name="Komplexná / Psychotická"/>
    <bpmn:sequenceFlow id="SF_Step2_to_ImprovGW"      sourceRef="SP_Step2"              targetRef="GW_Sp_Improvement"/>
    <bpmn:sequenceFlow id="SF_Step3_to_ImprovGW"      sourceRef="SP_Step3"              targetRef="GW_Sp_Improvement"/>
    <bpmn:sequenceFlow id="SF_Step4_to_ImprovGW"      sourceRef="SP_Step4"              targetRef="GW_Sp_Improvement"/>
    <bpmn:sequenceFlow id="SF_Sp_ImprovYes"           sourceRef="GW_Sp_Improvement"     targetRef="SP_RelapsePrevention"    name="Áno"/>
    <bpmn:sequenceFlow id="SF_Sp_ImprovNo"            sourceRef="GW_Sp_Improvement"     targetRef="T_ChangeTreatment"       name="Nie"/>
    <bpmn:sequenceFlow id="SF_Change_to_Severity"     sourceRef="T_ChangeTreatment"     targetRef="GW_Sp_Severity"/>
    <bpmn:sequenceFlow id="SF_Relapse_to_End"         sourceRef="SP_RelapsePrevention"  targetRef="EE_Sp_Completed"/>
  </bpmn:process>

  <!-- ═══════════════════════════════════════════════════════════
       PROCESS – PATIENT (thin lane for message correlation)
  ═══════════════════════════════════════════════════════════ -->
  <bpmn:process id="Process_Patient" name="Proces – Pacient" isExecutable="false">
    <bpmn:startEvent id="SE_Pat_Start" name="Pacient zaregistruje ťažkosti">
      <bpmn:outgoing>SF_Pat_to_End</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="T_Pat_Consent" name="Informovaný súhlas s liečbou&#10;+ aktívna účasť na terapii">
      <bpmn:incoming>SF_Pat_to_End</bpmn:incoming>
      <bpmn:outgoing>SF_Pat_Consent_to_EE</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EE_Pat_End" name="Pacient v starostlivosti">
      <bpmn:incoming>SF_Pat_Consent_to_EE</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SF_Pat_to_End"        sourceRef="SE_Pat_Start"   targetRef="T_Pat_Consent"/>
    <bpmn:sequenceFlow id="SF_Pat_Consent_to_EE" sourceRef="T_Pat_Consent"  targetRef="EE_Pat_End"/>
  </bpmn:process>

  <!-- ═══════════════════════════════════════════════════════════
       MESSAGE
  ═══════════════════════════════════════════════════════════ -->
  <bpmn:message id="Msg_Referral" name="OdoslanieKSpecialistovi"/>

  <!-- ═══════════════════════════════════════════════════════════
       MESSAGE FLOWS (between pools)
  ═══════════════════════════════════════════════════════════ -->
  <bpmn:messageFlow id="MF_GPtoSpecialist"
                    sourceRef="EE_GP_Referred"
                    targetRef="SE_SpecialistReceives"
                    name="Odporúčanie pacienta"/>

