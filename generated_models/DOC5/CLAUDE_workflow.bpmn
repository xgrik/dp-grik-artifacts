    <bpmn:userTask id="UT_MaintPharma" name="Continue antidepressant pharmacotherapy during maintenance phase minimum 6 months"><bpmn:incoming>F_G31_Standard</bpmn:incoming><bpmn:incoming>F_G33_No</bpmn:incoming><bpmn:outgoing>F_MaintPharma_G32</bpmn:outgoing></bpmn:userTask>
