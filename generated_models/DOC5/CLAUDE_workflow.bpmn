<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_0cwasaq" targetNamespace="http://bpmn.io/schema/bpmn" xmlns:modeler="http://camunda.org/schema/modeler/1.0" exporter="Camunda Modeler" exporterVersion="5.33.1" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.22.0">
  <bpmn:process id="Process_0hbbe8d" isExecutable="true" name="Complex Psychological Management of Adult Patient with Depressive Disorder">
    <bpmn:startEvent id="SE_1" name="Patient presents with depressive symptoms"><bpmn:outgoing>F_SE1_G01</bpmn:outgoing></bpmn:startEvent>
    <bpmn:exclusiveGateway id="GW_G01" name="How does patient enter care?"><bpmn:incoming>F_SE1_G01</bpmn:incoming><bpmn:outgoing>F_G01_ViaGP</bpmn:outgoing><bpmn:outgoing>F_G01_ViaSpec</bpmn:outgoing><bpmn:outgoing>F_G01_Direct</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_GPScreen" name="Conduct initial depression screening (GP)"><bpmn:incoming>F_G01_ViaGP</bpmn:incoming><bpmn:outgoing>F_GPScreen_T02</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_ExclSomatic" name="Exclude somatic causes of depressive symptoms"><bpmn:incoming>F_G01_ViaSpec</bpmn:incoming><bpmn:outgoing>F_ExclSomatic_G02</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G02" name="Somatic cause identified?"><bpmn:incoming>F_ExclSomatic_G02</bpmn:incoming><bpmn:outgoing>F_G02_YesSomatic</bpmn:outgoing><bpmn:outgoing>F_G02_NoSomatic</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:endEvent id="EE_Somatic" name="Redirect to somatic medicine pathway"><bpmn:incoming>F_G02_YesSomatic</bpmn:incoming></bpmn:endEvent>
    <bpmn:userTask id="UT_NotifyGP" name="Notify GP of referral made by other specialist"><bpmn:incoming>F_G02_NoSomatic</bpmn:incoming><bpmn:outgoing>F_NotifyGP_T02</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_TwoQScreen" name="Administer two-question depression screen (NICE)"><bpmn:incoming>F_GPScreen_T02</bpmn:incoming><bpmn:incoming>F_NotifyGP_T02</bpmn:incoming><bpmn:outgoing>F_TwoQ_T03</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="ST_PHQ9" name="Administer and score PHQ-9 Sk screening questionnaire"><bpmn:incoming>F_TwoQ_T03</bpmn:incoming><bpmn:outgoing>F_PHQ9_G03</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_G03" name="Depression screening result positive?"><bpmn:incoming>F_PHQ9_G03</bpmn:incoming><bpmn:outgoing>F_G03_Positive</bpmn:outgoing><bpmn:outgoing>F_G03_Negative</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_ActiveMonNeg" name="Conduct active monitoring - no depression detected"><bpmn:incoming>F_G03_Negative</bpmn:incoming><bpmn:outgoing>F_MonNeg_EE</bpmn:outgoing></bpmn:userTask>
    <bpmn:endEvent id="EE_NoDepr" name="No depression confirmed - discharge or watchful waiting"><bpmn:incoming>F_MonNeg_EE</bpmn:incoming></bpmn:endEvent>
    <bpmn:userTask id="UT_Psychoed" name="Provide psychoeducation about depression and treatment options"><bpmn:incoming>F_G03_Positive</bpmn:incoming><bpmn:outgoing>F_Psychoed_DiscProb</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_DiscProb" name="Discuss problem and provide information on depression origin and course"><bpmn:incoming>F_Psychoed_DiscProb</bpmn:incoming><bpmn:outgoing>F_DiscProb_SchedFU</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_SchedFU" name="Schedule follow-up appointment at two-week interval"><bpmn:incoming>F_DiscProb_SchedFU</bpmn:incoming><bpmn:outgoing>F_SchedFU_SuicAss</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_ClinExam" name="Conduct psychiatric or clinical-psychological examination"><bpmn:incoming>F_G01_Direct</bpmn:incoming><bpmn:incoming>F_Refer_ClinExam</bpmn:incoming><bpmn:outgoing>F_ClinExam_SuicAss</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_SuicAss" name="Assess suicidal ideation and intent"><bpmn:incoming>F_SchedFU_SuicAss</bpmn:incoming><bpmn:incoming>F_ClinExam_SuicAss</bpmn:incoming><bpmn:outgoing>F_SuicAss_G10</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G10" name="Suicidal ideation or intent present?"><bpmn:incoming>F_SuicAss_G10</bpmn:incoming><bpmn:outgoing>F_G10_SuicYes</bpmn:outgoing><bpmn:outgoing>F_G10_SuicNo</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_SocSupport" name="Assess adequacy of social support and available help resources"><bpmn:incoming>F_G10_SuicYes</bpmn:incoming><bpmn:outgoing>F_SocSupp_G11</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G11" name="Level of suicidal risk?"><bpmn:incoming>F_SocSupp_G11</bpmn:incoming><bpmn:outgoing>F_G11_Moderate</bpmn:outgoing><bpmn:outgoing>F_G11_High</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_InformFamily" name="Inform patient, family and close persons about warning signs"><bpmn:incoming>F_G11_Moderate</bpmn:incoming><bpmn:outgoing>F_InformFam_LimitMed</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_LimitMed" name="Limit access to medications to reduce overdose risk"><bpmn:incoming>F_InformFam_LimitMed</bpmn:incoming><bpmn:outgoing>F_LimitMed_IncrContact</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_IncrContact" name="Increase frequency of patient contacts"><bpmn:incoming>F_LimitMed_IncrContact</bpmn:incoming><bpmn:outgoing>F_IncrContact_G04</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_UrgRef" name="Issue urgent referral to mental health specialist"><bpmn:incoming>F_G11_High</bpmn:incoming><bpmn:outgoing>F_UrgRef_DecHosp</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_DecHosp" name="Decide on hospitalisation for high-risk patient"><bpmn:incoming>F_UrgRef_DecHosp</bpmn:incoming><bpmn:outgoing>F_DecHosp_G26</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G26" name="Hospitalisation required?"><bpmn:incoming>F_DecHosp_G26</bpmn:incoming><bpmn:outgoing>F_G26_Yes</bpmn:outgoing><bpmn:outgoing>F_G26_No</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_InpatTreat" name="Deliver high-intensity psychosocial treatment during hospitalisation"><bpmn:incoming>F_G26_Yes</bpmn:incoming><bpmn:outgoing>F_Inpat_EE</bpmn:outgoing></bpmn:userTask>
    <bpmn:endEvent id="EE_Hosp" name="Patient hospitalised - inpatient pathway handover"><bpmn:incoming>F_Inpat_EE</bpmn:incoming></bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_G04" name="Clinician competent to assess mental state?"><bpmn:incoming>F_G10_SuicNo</bpmn:incoming><bpmn:incoming>F_IncrContact_G04</bpmn:incoming><bpmn:incoming>F_G26_No</bpmn:incoming><bpmn:outgoing>F_G04_NotComp</bpmn:outgoing><bpmn:outgoing>F_G04_Comp</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_Refer" name="Refer patient to clinical psychologist or psychiatrist"><bpmn:incoming>F_G04_NotComp</bpmn:incoming><bpmn:outgoing>F_Refer_ClinExam</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_PsychoDiag" name="Conduct psychodiagnostic examination with standardised instruments"><bpmn:incoming>F_G04_Comp</bpmn:incoming><bpmn:outgoing>F_PsychoDiag_G05</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G05" name="Complex psychological examination indicated?"><bpmn:incoming>F_PsychoDiag_G05</bpmn:incoming><bpmn:outgoing>F_G05_Yes</bpmn:outgoing><bpmn:outgoing>F_G05_No</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_ComplexExam" name="Conduct complex psychological examination for cognitive and personality disorders"><bpmn:incoming>F_G05_Yes</bpmn:incoming><bpmn:outgoing>F_ComplexExam_G06</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G06" name="Stress reactivity assessment indicated?"><bpmn:incoming>F_G05_No</bpmn:incoming><bpmn:incoming>F_ComplexExam_G06</bpmn:incoming><bpmn:outgoing>F_G06_Yes</bpmn:outgoing><bpmn:outgoing>F_G06_No</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_StressReact" name="Conduct stress reactivity examination and create stress profile"><bpmn:incoming>F_G06_Yes</bpmn:incoming><bpmn:outgoing>F_StressReact_Diag</bpmn:outgoing></bpmn:userTask>
    <bpmn:businessRuleTask id="BRT_Diag" name="Apply diagnostic criteria and assign ICD-10 diagnosis F32 or F33"><bpmn:incoming>F_G06_No</bpmn:incoming><bpmn:incoming>F_StressReact_Diag</bpmn:incoming><bpmn:outgoing>F_Diag_DiffDiag</bpmn:outgoing></bpmn:businessRuleTask>
    <bpmn:userTask id="UT_DiffDiag" name="Conduct differential diagnosis to exclude somatic bipolar and other disorders"><bpmn:incoming>F_Diag_DiffDiag</bpmn:incoming><bpmn:outgoing>F_DiffDiag_G08</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G08" name="Manic or hypomanic episode in history?"><bpmn:incoming>F_DiffDiag_G08</bpmn:incoming><bpmn:outgoing>F_G08_Bipolar</bpmn:outgoing><bpmn:outgoing>F_G08_Depressive</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:endEvent id="EE_Bipolar" name="Redirect to bipolar affective disorder management pathway"><bpmn:incoming>F_G08_Bipolar</bpmn:incoming></bpmn:endEvent>
    <bpmn:userTask id="UT_FuncImp" name="Assess functional impairment and psychosocial factors"><bpmn:incoming>F_G08_Depressive</bpmn:incoming><bpmn:outgoing>F_FuncImp_TreatHist</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_TreatHist" name="Assess treatment history and prior response to interventions"><bpmn:incoming>F_FuncImp_TreatHist</bpmn:incoming><bpmn:outgoing>F_TreatHist_G09</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G09" name="Severity of current depressive episode?"><bpmn:incoming>F_TreatHist_G09</bpmn:incoming><bpmn:outgoing>F_G09_Mild</bpmn:outgoing><bpmn:outgoing>F_G09_Moderate</bpmn:outgoing><bpmn:outgoing>F_G09_Severe</bpmn:outgoing><bpmn:outgoing>F_G09_SeverePsy</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_G07" name="First episode or recurrent depressive disorder?"><bpmn:incoming>F_G09_Mild</bpmn:incoming><bpmn:incoming>F_G09_Moderate</bpmn:incoming><bpmn:outgoing>F_G07_First</bpmn:outgoing><bpmn:outgoing>F_G07_Recurrent</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_Consent" name="Obtain informed consent for treatment"><bpmn:incoming>F_G07_First</bpmn:incoming><bpmn:incoming>F_G07_Recurrent</bpmn:incoming><bpmn:incoming>F_G09_Severe</bpmn:incoming><bpmn:incoming>F_G09_SeverePsy</bpmn:incoming><bpmn:outgoing>F_Consent_StepDet</bpmn:outgoing></bpmn:userTask>
    <bpmn:businessRuleTask id="BRT_StepDet" name="Determine treatment step level 1 to 4"><bpmn:incoming>F_Consent_StepDet</bpmn:incoming><bpmn:outgoing>F_StepDet_DiscTreat</bpmn:outgoing></bpmn:businessRuleTask>
    <bpmn:userTask id="UT_DiscTreat" name="Discuss treatment options with patient"><bpmn:incoming>F_StepDet_DiscTreat</bpmn:incoming><bpmn:outgoing>F_DiscTreat_SelTreat</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_SelTreat" name="Select treatment modality considering patient preference and EBM availability"><bpmn:incoming>F_DiscTreat_SelTreat</bpmn:incoming><bpmn:outgoing>F_SelTreat_RelRisk</bpmn:outgoing></bpmn:userTask>
    <bpmn:businessRuleTask id="BRT_RelRisk" name="Assess relapse risk factors"><bpmn:incoming>F_SelTreat_RelRisk</bpmn:incoming><bpmn:outgoing>F_RelRisk_G12</bpmn:outgoing></bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="GW_G12" name="Assign to stepped care level"><bpmn:incoming>F_RelRisk_G12</bpmn:incoming><bpmn:outgoing>F_G12_S1</bpmn:outgoing><bpmn:outgoing>F_G12_S2</bpmn:outgoing><bpmn:outgoing>F_G12_S3</bpmn:outgoing><bpmn:outgoing>F_G12_S4</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_S1Mon" name="Conduct active monitoring and watchful waiting Step 1"><bpmn:incoming>F_G12_S1</bpmn:incoming><bpmn:outgoing>F_S1Mon_S1Rev</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_S1Rev" name="Schedule follow-up and assess improvement at two-week review"><bpmn:incoming>F_S1Mon_S1Rev</bpmn:incoming><bpmn:outgoing>F_S1Rev_G14</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G14" name="Improvement following active monitoring Step 1?"><bpmn:incoming>F_S1Rev_G14</bpmn:incoming><bpmn:outgoing>F_G14_Improve</bpmn:outgoing><bpmn:outgoing>F_G14_NoImprove</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_G15" name="Condition likely to improve without psychosocial intervention?"><bpmn:incoming>F_G14_Improve</bpmn:incoming><bpmn:outgoing>F_G15_Yes</bpmn:outgoing><bpmn:outgoing>F_G15_No</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_S1Cont" name="Continue active monitoring until remission or escalation needed"><bpmn:incoming>F_G15_Yes</bpmn:incoming><bpmn:outgoing>F_S1Cont_G29</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G13" name="Comorbid anxiety present - which condition to prioritise?"><bpmn:incoming>F_G12_S2</bpmn:incoming><bpmn:incoming>F_G14_NoImprove</bpmn:incoming><bpmn:incoming>F_G15_No</bpmn:incoming><bpmn:outgoing>F_G13_DeprPrio</bpmn:outgoing><bpmn:outgoing>F_G13_AnxPrio</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_SleepHyg" name="Recommend sleep hygiene education if indicated"><bpmn:incoming>F_G13_DeprPrio</bpmn:incoming><bpmn:incoming>F_G13_AnxPrio</bpmn:incoming><bpmn:outgoing>F_SleepHyg_G16</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G16" name="Patient accepts Step 2 low-intensity treatment SPI?"><bpmn:incoming>F_SleepHyg_G16</bpmn:incoming><bpmn:outgoing>F_G16_Accept</bpmn:outgoing><bpmn:outgoing>F_G16_Refuse</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:inclusiveGateway id="GW_G17" name="Select Step 2 SPI treatment modality"><bpmn:incoming>F_G16_Accept</bpmn:incoming><bpmn:outgoing>F_G17_SelfHelp</bpmn:outgoing><bpmn:outgoing>F_G17_IKBT</bpmn:outgoing><bpmn:outgoing>F_G17_Physical</bpmn:outgoing></bpmn:inclusiveGateway>
    <bpmn:userTask id="UT_SelfHelp" name="Deliver individual self-help program based on CBT principles 6 to 8 sessions"><bpmn:incoming>F_G17_SelfHelp</bpmn:incoming><bpmn:outgoing>F_SelfHelp_G17J</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="ST_IKBT" name="Deliver computer-based internet CBT program IKBT 9 to 12 weeks"><bpmn:incoming>F_G17_IKBT</bpmn:incoming><bpmn:outgoing>F_IKBT_G17J</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="UT_PhysAct" name="Deliver structured group physical activity program 3 sessions per week"><bpmn:incoming>F_G17_Physical</bpmn:incoming><bpmn:outgoing>F_PhysAct_G17J</bpmn:outgoing></bpmn:userTask>
    <bpmn:inclusiveGateway id="GW_G17J" name="Step 2 SPI treatment modalities completed"><bpmn:incoming>F_SelfHelp_G17J</bpmn:incoming><bpmn:incoming>F_IKBT_G17J</bpmn:incoming><bpmn:incoming>F_PhysAct_G17J</bpmn:incoming><bpmn:outgoing>F_G17J_G18</bpmn:outgoing></bpmn:inclusiveGateway>
    <bpmn:userTask id="UT_GroupCBT" name="Deliver group CBT as alternative to individual SPI 10 to 12 sessions"><bpmn:incoming>F_G16_Refuse</bpmn:incoming><bpmn:outgoing>F_GroupCBT_G18</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G18" name="Pharmacotherapy indicated at Step 2?"><bpmn:incoming>F_G17J_G18</bpmn:incoming><bpmn:incoming>F_GroupCBT_G18</bpmn:incoming><bpmn:outgoing>F_G18_Yes</bpmn:outgoing><bpmn:outgoing>F_G18_No</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_PharmaS2" name="Consider and initiate pharmacotherapy at Step 2"><bpmn:incoming>F_G18_Yes</bpmn:incoming><bpmn:outgoing>F_PharmaS2_ScoreS2</bpmn:outgoing></bpmn:userTask>
    <bpmn:scriptTask id="SCR_ScoreS2" name="Compute and record standardised outcome scores PHQ-9 BDI-II Step 2"><bpmn:incoming>F_G18_No</bpmn:incoming><bpmn:incoming>F_PharmaS2_ScoreS2</bpmn:incoming><bpmn:outgoing>F_ScoreS2_EvalS2</bpmn:outgoing></bpmn:scriptTask>
    <bpmn:userTask id="UT_EvalS2" name="Evaluate treatment response at defined intervals Step 2"><bpmn:incoming>F_ScoreS2_EvalS2</bpmn:incoming><bpmn:outgoing>F_EvalS2_G19</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G19" name="Adequate improvement following Step 2 treatment?"><bpmn:incoming>F_EvalS2_G19</bpmn:incoming><bpmn:outgoing>F_G19_Improve</bpmn:outgoing><bpmn:outgoing>F_G19_NoImprove</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_G20" name="Patient refuses pharmacotherapy at Step 3?"><bpmn:incoming>F_G12_S3</bpmn:incoming><bpmn:incoming>F_G19_NoImprove</bpmn:incoming><bpmn:outgoing>F_G20_Accept</bpmn:outgoing><bpmn:outgoing>F_G20_Refuse</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_PharmaS3" name="Initiate or continue pharmacotherapy at Step 3"><bpmn:incoming>F_G20_Accept</bpmn:incoming><bpmn:outgoing>F_PharmaS3_G22</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G22" name="First-line Step 3 therapy available and acceptable?"><bpmn:incoming>F_G20_Refuse</bpmn:incoming><bpmn:incoming>F_PharmaS3_G22</bpmn:incoming><bpmn:outgoing>F_G22_FirstLine</bpmn:outgoing><bpmn:outgoing>F_G22_AltLine</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_G21" name="Select Step 3 high-intensity psychotherapy modality"><bpmn:incoming>F_G22_FirstLine</bpmn:incoming><bpmn:outgoing>F_G21_CBT</bpmn:outgoing><bpmn:outgoing>F_G21_IPT</bpmn:outgoing><bpmn:outgoing>F_G21_BA</bpmn:outgoing><bpmn:outgoing>F_G21_Family</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_CBT" name="Deliver individual CBT high-intensity 16 to 20 sessions 3 to 4 months"><bpmn:incoming>F_G21_CBT</bpmn:incoming><bpmn:outgoing>F_CBT_ScoreS3</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_IPT" name="Deliver individual Interpersonal Psychotherapy IPT 16 to 20 sessions"><bpmn:incoming>F_G21_IPT</bpmn:incoming><bpmn:outgoing>F_IPT_ScoreS3</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_BA" name="Deliver behavioural activation therapy 16 to 20 sessions 3 to 4 months"><bpmn:incoming>F_G21_BA</bpmn:incoming><bpmn:outgoing>F_BA_ScoreS3</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_FamilyTher" name="Deliver behavioural couple or family therapy 15 to 20 sessions"><bpmn:incoming>F_G21_Family</bpmn:incoming><bpmn:outgoing>F_FamilyTher_ScoreS3</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_SuppCouns" name="Deliver individual supportive non-directive counselling 6 to 10 sessions"><bpmn:incoming>F_G22_AltLine</bpmn:incoming><bpmn:outgoing>F_SuppCouns_ScoreS3</bpmn:outgoing></bpmn:userTask>
    <bpmn:scriptTask id="SCR_ScoreS3" name="Compute and record standardised outcome scores PHQ-9 BDI-II Step 3"><bpmn:incoming>F_CBT_ScoreS3</bpmn:incoming><bpmn:incoming>F_IPT_ScoreS3</bpmn:incoming><bpmn:incoming>F_BA_ScoreS3</bpmn:incoming><bpmn:incoming>F_FamilyTher_ScoreS3</bpmn:incoming><bpmn:incoming>F_SuppCouns_ScoreS3</bpmn:incoming><bpmn:outgoing>F_ScoreS3_G23</bpmn:outgoing></bpmn:scriptTask>
    <bpmn:exclusiveGateway id="GW_G23" name="Significant improvement after 4 to 8 weeks of psychotherapy?"><bpmn:incoming>F_ScoreS3_G23</bpmn:incoming><bpmn:outgoing>F_G23_Improve</bpmn:outgoing><bpmn:outgoing>F_G23_AddPharma</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_AddPharma" name="Add pharmacotherapy to ongoing psychotherapy due to insufficient response"><bpmn:incoming>F_G23_AddPharma</bpmn:incoming><bpmn:outgoing>F_AddPharma_EvalS3</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_EvalS3" name="Evaluate treatment response at defined intervals Step 3"><bpmn:incoming>F_G23_Improve</bpmn:incoming><bpmn:incoming>F_AddPharma_EvalS3</bpmn:incoming><bpmn:outgoing>F_EvalS3_G24</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G24" name="Adequate improvement following Step 3 treatment?"><bpmn:incoming>F_EvalS3_G24</bpmn:incoming><bpmn:outgoing>F_G24_Improve</bpmn:outgoing><bpmn:outgoing>F_G24_NoImprove</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_G25" name="Adequate response to combined pharmacotherapy and psychotherapy?"><bpmn:incoming>F_G24_NoImprove</bpmn:incoming><bpmn:outgoing>F_G25_Improve</bpmn:outgoing><bpmn:outgoing>F_G25_NoImprove</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="UT_ChangeAppr" name="Change therapeutic approach or refer to psychiatric specialist"><bpmn:incoming>F_G25_NoImprove</bpmn:incoming><bpmn:outgoing>F_ChangeAppr_S4Ass</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="UT_S4Assess" name="Conduct comprehensive expert assessment Step 4 symptoms risk comorbidities"><bpmn:incoming>F_G12_S4</bpmn:incoming><bpmn:incoming>F_ChangeAppr_S4Ass</bpmn:incoming><bpmn:outgoing>F_S4Ass_G28</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_G28" name="Was previous treatment inadequate or adherence insufficient?"><bpmn:incoming>F_S4Ass_G28</bpmn:incoming><bpmn:outgoing>F_G28_ReIndicate</bpmn:outgoing><bpmn:outgoing>F_G28_NewTreat</bpmn:outgoing></bpmn:exclusiveGateway>
