    <bpmn:exclusiveGateway id="GW_G31" name="Relapsed despite antidepressant medication or significant residual symptoms?"><bpmn:incoming>F_G30_CBT_IPT</bpmn:incoming><bpmn:outgoing>F_G31_RelapsePT</bpmn:outgoing><bpmn:outgoing>F_G31_Standard</bpmn:outgoing></bpmn:exclusiveGateway>
