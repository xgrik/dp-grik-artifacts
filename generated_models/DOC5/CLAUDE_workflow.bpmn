    <bpmn:exclusiveGateway id="GW_G27" name="ECT indicated for treatment-resistant or severe depression?"><bpmn:incoming>F_G28_NewTreat</bpmn:incoming><bpmn:incoming>F_ReIndicate_G27</bpmn:incoming><bpmn:outgoing>F_G27_ECT</bpmn:outgoing><bpmn:outgoing>F_G27_NoECT</bpmn:outgoing></bpmn:exclusiveGateway>
