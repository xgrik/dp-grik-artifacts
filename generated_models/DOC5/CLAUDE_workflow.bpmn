    <bpmn:exclusiveGateway id="GW_G29" name="Significant relapse risk present?"><bpmn:incoming>F_S1Cont_G29</bpmn:incoming><bpmn:incoming>F_G19_Improve</bpmn:incoming><bpmn:incoming>F_G24_Improve</bpmn:incoming><bpmn:incoming>F_G25_Improve</bpmn:incoming><bpmn:incoming>F_S4Join_G29</bpmn:incoming><bpmn:outgoing>F_G29_High</bpmn:outgoing><bpmn:outgoing>F_G29_Low</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_G33" name="Formal maintenance treatment indicated 3 or more episodes or chronic?"><bpmn:incoming>F_G29_High</bpmn:incoming><bpmn:outgoing>F_G33_Yes</bpmn:outgoing><bpmn:outgoing>F_G33_No</bpmn:outgoing></bpmn:exclusiveGateway>
