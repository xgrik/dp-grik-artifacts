<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  id="Definitions_1fnwx2w"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
                  exporter="Camunda Modeler"
                  exporterVersion="5.33.1"
                  modeler:executionPlatform="Camunda Platform"
                  modeler:executionPlatformVersion="7.22.0">

  <bpmn:process id="Process_0mxms9h" isExecutable="true" name="Agorafobia - Standardny diagnosticky a terapeuticky postup">

    <!-- ==================== START EVENT ==================== -->
    <bpmn:startEvent id="StartEvent_1" name="Pacient / populacia identifikovana pre intervenciu">
      <bpmn:outgoing>Flow_Start_A1</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ==================== PHASE A: PREVENTION ==================== -->
    <bpmn:userTask id="Task_A1_RiskFactors" name="A1: Identifikovat rizikove a protektivne faktory">
      <bpmn:incoming>Flow_Start_A1</bpmn:incoming>
      <bpmn:outgoing>Flow_A1_G01</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_01_RiskProfile" name="G01: Su pritomne rizikove faktory?">
      <bpmn:incoming>Flow_A1_G01</bpmn:incoming>
      <bpmn:outgoing>Flow_G01_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_G01_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_A2_SelectProgram" name="A2: Vybrat typ preventivneho programu">
      <bpmn:incoming>Flow_G01_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_A2_G02</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_02_PrevType" name="G02: Typ preventivneho programu?">
      <bpmn:incoming>Flow_A2_G02</bpmn:incoming>
      <bpmn:outgoing>Flow_G02_Indicated</bpmn:outgoing>
      <bpmn:outgoing>Flow_G02_Selective</bpmn:outgoing>
      <bpmn:outgoing>Flow_G02_Universal</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_A3a_Indicated" name="A3a: Realizovat indikovanу preventivny program">
      <bpmn:incoming>Flow_G02_Indicated</bpmn:incoming>
      <bpmn:outgoing>Flow_A3a_Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_A3b_Selective" name="A3b: Realizovat selektivny preventivny program">
      <bpmn:incoming>Flow_G02_Selective</bpmn:incoming>
      <bpmn:outgoing>Flow_A3b_Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_A3c_Universal" name="A3c: Realizovat univerzalny preventivny program">
      <bpmn:incoming>Flow_G02_Universal</bpmn:incoming>
      <bpmn:outgoing>Flow_A3c_Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_PrevJoin" name="G_PrevJoin: Zlucenie po prevencii">
      <bpmn:incoming>Flow_A3a_Join</bpmn:incoming>
      <bpmn:incoming>Flow_A3b_Join</bpmn:incoming>
      <bpmn:incoming>Flow_A3c_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_PrevJoin_End</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Prevention" name="Koniec: Preventivna intervencia dokoncena">
      <bpmn:incoming>Flow_PrevJoin_End</bpmn:incoming>
      <bpmn:incoming>Flow_G01_No</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ==================== PHASE B: SCREENING ==================== -->
    <bpmn:startEvent id="StartEvent_Screening" name="Pacient prichadza do primarnej starostlivosti">
      <bpmn:outgoing>Flow_StartB_B1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_B1_Screening" name="B1: Administrovat 4-otazkovy skrning uzkosti">
      <bpmn:incoming>Flow_StartB_B1</bpmn:incoming>
      <bpmn:outgoing>Flow_B1_B2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:businessRuleTask id="Task_B2_EvalScreen" name="B2: Vyhodnotit vysledok skriningu">
      <bpmn:incoming>Flow_B1_B2</bpmn:incoming>
      <bpmn:outgoing>Flow_B2_G03</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="GW_03_ScreenResult" name="G03: Pozitivny skrning?">
      <bpmn:incoming>Flow_B2_G03</bpmn:incoming>
      <bpmn:outgoing>Flow_G03_Positive</bpmn:outgoing>
      <bpmn:outgoing>Flow_G03_Negative</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_NegScreen" name="Koniec: Negativny skrning - rutinna starostlivost">
      <bpmn:incoming>Flow_G03_Negative</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="Task_B3_InitAssess" name="B3: Vykonat pociatocne klinicke posudenie">
      <bpmn:incoming>Flow_G03_Positive</bpmn:incoming>
      <bpmn:outgoing>Flow_B3_G04</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_04_Referral" name="G04: Odoslanie k specialistovi?">
      <bpmn:incoming>Flow_B3_G04</bpmn:incoming>
      <bpmn:outgoing>Flow_G04_Refer</bpmn:outgoing>
      <bpmn:outgoing>Flow_G04_GPManage</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_B4_RefInfo" name="B4: Poskytnout pisomne informacie o odoslaní pacientovi">
      <bpmn:incoming>Flow_G04_Refer</bpmn:incoming>
      <bpmn:outgoing>Flow_B4_B5</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_B5_InitiateRef" name="B5: Iniciovat specialisticke odoslanie">
      <bpmn:incoming>Flow_B4_B5</bpmn:incoming>
      <bpmn:outgoing>Flow_B5_G05</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_B_GPManage" name="B_GP: Manazovat pacienta v primarnej starostlivosti so specialistom">
      <bpmn:incoming>Flow_G04_GPManage</bpmn:incoming>
      <bpmn:outgoing>Flow_GPManage_G05</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_05_SelfRef" name="G05: Pacient odoslany VL alebo self-referral?">
      <bpmn:incoming>Flow_B5_G05</bpmn:incoming>
      <bpmn:incoming>Flow_GPManage_G05</bpmn:incoming>
      <bpmn:outgoing>Flow_G05_GPRef</bpmn:outgoing>
      <bpmn:outgoing>Flow_G05_SelfRef</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_B6_NotifyGP" name="B6: Informovat vseobecneho lekara o self-referral">
      <bpmn:incoming>Flow_G05_SelfRef</bpmn:incoming>
      <bpmn:outgoing>Flow_B6_C1</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ==================== PHASE C: DIAGNOSIS ==================== -->
    <bpmn:userTask id="Task_C1_PsychExam" name="C1: Vykonat komplexne psychiatricke vysetrenie">
      <bpmn:incoming>Flow_G05_GPRef</bpmn:incoming>
      <bpmn:incoming>Flow_B6_C1</bpmn:incoming>
      <bpmn:outgoing>Flow_C1_C2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_C2_PsychoDiag" name="C2: Vykonat psychodiagnosticke vysetrenie">
      <bpmn:incoming>Flow_C1_C2</bpmn:incoming>
      <bpmn:outgoing>Flow_C2_C3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_C3_SomaticExcl" name="C3: Vykonat somaticke vylucujuce vysetrenie (EKG, EEG, krvny tlak, krv, moc)">
      <bpmn:incoming>Flow_C2_C3</bpmn:incoming>
      <bpmn:outgoing>Flow_C3_G06</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_06_Somatic" name="G06: Vysledok somatickeho vylucenia?">
      <bpmn:incoming>Flow_C3_G06</bpmn:incoming>
      <bpmn:outgoing>Flow_G06_Excluded</bpmn:outgoing>
      <bpmn:outgoing>Flow_G06_Primary</bpmn:outgoing>
      <bpmn:outgoing>Flow_G06_Comorbid</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_SomaticPrimary" name="Koniec: Odoslanie na somaticku liecbu (primarná somaticka pricina)">
      <bpmn:incoming>Flow_G06_Primary</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="Task_C3b_SomaticParallel" name="C3b: Iniciovat paralelnu somaticku liecbu (komorbidita)">
      <bpmn:incoming>Flow_G06_Comorbid</bpmn:incoming>
      <bpmn:outgoing>Flow_C3b_C4</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_C4_Psychometric" name="C4: Administrovat diagnosticke psychometricke nastroje (PHQ-9, GAD-7, dotaznik strachu, SCL-90)">
      <bpmn:incoming>Flow_G06_Excluded</bpmn:incoming>
      <bpmn:incoming>Flow_C3b_C4</bpmn:incoming>
      <bpmn:outgoing>Flow_C4_C5</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_C5_Suicidality" name="C5: Posoudit suicidalnu ideaciu (povinne pre vsetkych pacientov)">
      <bpmn:incoming>Flow_C4_C5</bpmn:incoming>
      <bpmn:outgoing>Flow_C5_G07</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_07_Suicidality" name="G07: Pritomna suicidalita?">
      <bpmn:incoming>Flow_C5_G07</bpmn:incoming>
      <bpmn:outgoing>Flow_G07_Present</bpmn:outgoing>
      <bpmn:outgoing>Flow_G07_Absent</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Emergency" name="Koniec: Aktivacia nudzoveho protokolu (SOP - sebaposkoozenie / samovrazda)">
      <bpmn:incoming>Flow_G07_Present</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="GW_08_Neuro" name="G08: Podozrenie na neurologicky diferencial?">
      <bpmn:incoming>Flow_G07_Absent</bpmn:incoming>
      <bpmn:outgoing>Flow_G08_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_G08_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_C_NeuroRef" name="C_Neuro: Odoslat na neurologicke diferencialne diagnosticke vysetrenie">
      <bpmn:incoming>Flow_G08_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_NeuroRef_C6</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_C6_DiffDiag" name="C6: Vykonat diferencialne diagnosticke posudenie (ICD-10 kriteria, Tab.5-6)">
      <bpmn:incoming>Flow_G08_No</bpmn:incoming>
      <bpmn:incoming>Flow_NeuroRef_C6</bpmn:incoming>
      <bpmn:outgoing>Flow_C6_C7</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_C7_Psychophysio" name="C7: Posoudit psychofyziologicku reaktivitu (stresovy profil)">
      <bpmn:incoming>Flow_C6_C7</bpmn:incoming>
      <bpmn:outgoing>Flow_C7_G09</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_09_CompPsych" name="G09: Podozrenie na kognitívne poskodenie alebo poruchu osobnosti?">
      <bpmn:incoming>Flow_C7_G09</bpmn:incoming>
      <bpmn:outgoing>Flow_G09_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_G09_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_C8_CompPsychExam" name="C8: Vykonat komplexne psychologicke vysetrenie (kognitívne / osobnostne)">
      <bpmn:incoming>Flow_G09_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_C8_G10</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_10_DiffOutcome" name="G10: Vysledok diferentialnej diagnostiky?">
      <bpmn:incoming>Flow_G09_No</bpmn:incoming>
      <bpmn:incoming>Flow_C8_G10</bpmn:incoming>
      <bpmn:outgoing>Flow_G10_Confirmed</bpmn:outgoing>
      <bpmn:outgoing>Flow_G10_Alternative</bpmn:outgoing>
      <bpmn:outgoing>Flow_G10_Comorbid</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_AltDiag" name="Koniec: Presmerovanie na alternativnu diagnosticku / liecebnu cestu">
      <bpmn:incoming>Flow_G10_Alternative</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="Task_C9_Diagnosis" name="C9: Formulovat formalnu diagnostiku podla ICD-10 F40.0 (hlavna + komorbidne diagnozy)">
      <bpmn:incoming>Flow_G10_Confirmed</bpmn:incoming>
      <bpmn:incoming>Flow_G10_Comorbid</bpmn:incoming>
      <bpmn:outgoing>Flow_C9_C10</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_C10_SelfHelpCap" name="C10: Posoudit kapacitu pacienta na svojpomocne materialy">
      <bpmn:incoming>Flow_C9_C10</bpmn:incoming>
      <bpmn:outgoing>Flow_C10_D1</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ==================== PHASE D: TREATMENT PLANNING ==================== -->
    <bpmn:userTask id="Task_D1_TreatDiscuss" name="D1: Prejednat moznosti liecby s pacientom">
      <bpmn:incoming>Flow_C10_D1</bpmn:incoming>
      <bpmn:outgoing>Flow_D1_D2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_D2_TreatInfo" name="D2: Poskytnout pacientovi informacie o navrhovanej liecbe">
      <bpmn:incoming>Flow_D1_D2</bpmn:incoming>
      <bpmn:outgoing>Flow_D2_D3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_D3_Consent" name="D3: Ziskat informovany suhlas pacienta">
      <bpmn:incoming>Flow_D2_D3</bpmn:incoming>
      <bpmn:outgoing>Flow_D3_F5a</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_F5a_Comorbidity" name="F5a: Posoudit komorbidne stavy a upravit liecebnu cestu">
      <bpmn:incoming>Flow_D3_F5a</bpmn:incoming>
      <bpmn:outgoing>Flow_F5a_G13</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_13_Depression" name="G13: Komorbidna depresia?">
      <bpmn:incoming>Flow_F5a_G13</bpmn:incoming>
      <bpmn:outgoing>Flow_G13_PrimaryDep</bpmn:outgoing>
      <bpmn:outgoing>Flow_G13_Comorbid</bpmn:outgoing>
      <bpmn:outgoing>Flow_G13_Subthreshold</bpmn:outgoing>
      <bpmn:outgoing>Flow_G13_None</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_DepFirst" name="D_Dep: Liecit primarne depresivnu poruchu podla prislusneho SDTP">
      <bpmn:incoming>Flow_G13_PrimaryDep</bpmn:incoming>
      <bpmn:outgoing>Flow_DepFirst_G14</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_BothSDTP" name="D_Both: Aplikovat SDTP pre obe diagnosticke jednotky (uzkost aj depresia)">
      <bpmn:incoming>Flow_G13_Comorbid</bpmn:incoming>
      <bpmn:outgoing>Flow_BothSDTP_G14</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_SubDisc" name="D_Sub: Prejednat s pacientom priority liecby (subklinicky priebeh)">
      <bpmn:incoming>Flow_G13_Subthreshold</bpmn:incoming>
      <bpmn:outgoing>Flow_SubDisc_G14</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_14_Alcohol" name="G14: Zneuzivanie alkoholu / zavislost?">
      <bpmn:incoming>Flow_G13_None</bpmn:incoming>
      <bpmn:incoming>Flow_DepFirst_G14</bpmn:incoming>
      <bpmn:incoming>Flow_BothSDTP_G14</bpmn:incoming>
      <bpmn:incoming>Flow_SubDisc_G14</bpmn:incoming>
      <bpmn:outgoing>Flow_G14_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_G14_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_AlcFirst" name="D_Alc: Odporucit liecbu zavislosti od alkoholu ako prioritu">
      <bpmn:incoming>Flow_G14_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_AlcFirst_G15</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_15_CogImpair" name="G15: Kognitívne poskodenie / porucha ucenia?">
      <bpmn:incoming>Flow_G14_No</bpmn:incoming>
      <bpmn:incoming>Flow_AlcFirst_G15</bpmn:incoming>
      <bpmn:outgoing>Flow_G15_Mild</bpmn:outgoing>
      <bpmn:outgoing>Flow_G15_Severe</bpmn:outgoing>
      <bpmn:outgoing>Flow_G15_None</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_MildAdapt" name="D_Mild: Upravit sposob poskytovania liecby (mirne kognitívne poskodenie)">
      <bpmn:incoming>Flow_G15_Mild</bpmn:incoming>
      <bpmn:outgoing>Flow_MildAdapt_D4</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_SevereConsult" name="D_Severe: Konzultovat specialistu pre individualne odporucania (stredne az tazke poskodenie)">
      <bpmn:incoming>Flow_G15_Severe</bpmn:incoming>
      <bpmn:outgoing>Flow_SevereConsult_D4</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_D4_TherapPlan" name="D4: Formulovat individualny terapeuticky plan (EBM-zalozeny, stupnova starostlivost)">
      <bpmn:incoming>Flow_G15_None</bpmn:incoming>
      <bpmn:incoming>Flow_MildAdapt_D4</bpmn:incoming>
      <bpmn:incoming>Flow_SevereConsult_D4</bpmn:incoming>
      <bpmn:outgoing>Flow_D4_D5</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_D5_Hosp" name="D5: Rozhodnut o potrebe hospitalizacie">
      <bpmn:incoming>Flow_D4_D5</bpmn:incoming>
      <bpmn:outgoing>Flow_D5_G11</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_11_Hosp" name="G11: Hospitalizacia potrebna?">
      <bpmn:incoming>Flow_D5_G11</bpmn:incoming>
      <bpmn:outgoing>Flow_G11_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_G11_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Inpatient" name="Koniec: Odoslanie na ustavnu / hospitalizacnu starostlivost (externy proces)">
      <bpmn:incoming>Flow_G11_Yes</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="GW_12_Outpatient" name="G12: Pacient schopny a ochotny navstivit ambulanciu?">
      <bpmn:incoming>Flow_G11_No</bpmn:incoming>
      <bpmn:outgoing>Flow_G12_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_G12_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ==================== PHASE E: TREATMENT DELIVERY ==================== -->
    <bpmn:userTask id="Task_E1_Psychoed" name="E1: Realizovat psychoedukáciu (porucha, stresova reakcia, bludny kruh uzkosti)">
      <bpmn:incoming>Flow_G12_Yes</bpmn:incoming>
      <bpmn:incoming>Flow_G12_No</bpmn:incoming>
      <bpmn:outgoing>Flow_E1_G16</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_16_StepEntry" name="G16: Vstupny stupen stupnovej starostlivosti?">
      <bpmn:incoming>Flow_E1_G16</bpmn:incoming>
      <bpmn:outgoing>Flow_G16_Step1</bpmn:outgoing>
      <bpmn:outgoing>Flow_G16_Step2</bpmn:outgoing>
      <bpmn:outgoing>Flow_G16_Step3</bpmn:outgoing>
      <bpmn:outgoing>Flow_G16_Step4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Step 1 -->
    <bpmn:userTask id="Task_E2_SelfHelp" name="E2: Pacient realizuje svojpomocne techniky a zmenu zivotneho stylu (Krok 1)">
      <bpmn:incoming>Flow_G16_Step1</bpmn:incoming>
      <bpmn:outgoing>Flow_E2_F1</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Step 2 gateway -->
    <bpmn:exclusiveGateway id="GW_17_Step2Modal" name="G17: Modalita psychologickej terapie (Krok 2)?">
      <bpmn:incoming>Flow_G16_Step2</bpmn:incoming>
      <bpmn:outgoing>Flow_G17_SelfSupport</bpmn:outgoing>
      <bpmn:outgoing>Flow_G17_KBT</bpmn:outgoing>
      <bpmn:outgoing>Flow_G17_IKBT</bpmn:outgoing>
      <bpmn:outgoing>Flow_G17_Relax</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_20_EBMAvail" name="G20: EBM pristupy dostupne a terapeut certifikovany?">
      <bpmn:incoming>Flow_G17_KBT</bpmn:incoming>
      <bpmn:outgoing>Flow_G20_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_G20_NoAvail</bpmn:outgoing>
      <bpmn:outgoing>Flow_G20_PatPref</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_21_CertCheck" name="G21: Terapeut ma certifikat CPС pre specificku psychoterapiu agorafobie?">
      <bpmn:incoming>Flow_G20_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_G21_Certified</bpmn:outgoing>
      <bpmn:outgoing>Flow_G21_AltCert</bpmn:outgoing>
      <bpmn:outgoing>Flow_G21_NoCert</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_E3_SelfSupport" name="E3: Realizovat svojpomocnu terapiu s podporou terapeuta (KBT kniha/pracovny zosit, Krok 2a)">
      <bpmn:incoming>Flow_G17_SelfSupport</bpmn:incoming>
      <bpmn:outgoing>Flow_E3_Step2Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_E4_KBT" name="E4: Realizovat kognitívno-behavioralnu terapiu - tvarou v tvar (12-15 sedení, Krok 2b)">
      <bpmn:incoming>Flow_G21_Certified</bpmn:incoming>
      <bpmn:outgoing>Flow_E4_CogRestr</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_E10_CogRestr" name="E10: Realizovat kognitivnu restrukturalizaciu a behavioralne experimenty">
      <bpmn:incoming>Flow_E4_CogRestr</bpmn:incoming>
      <bpmn:outgoing>Flow_E10_E11</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_E11_Exposure" name="E11: Konstruovat a realizovat expozicnu hierarchiu (externé a interné podnety)">
      <bpmn:incoming>Flow_E10_E11</bpmn:incoming>
      <bpmn:outgoing>Flow_E11_E12</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_E12_RemoveSafety" name="E12: Odstranit zabezpecovacie a vyhybave spravania">
      <bpmn:incoming>Flow_E11_E12</bpmn:incoming>
      <bpmn:outgoing>Flow_E12_E13</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_E13_ProbSolve" name="E13: Realizovat intervenciu riesenia problemov (partnerske, pracovne, socialne)">
      <bpmn:incoming>Flow_E12_E13</bpmn:incoming>
      <bpmn:outgoing>Flow_E13_KBTJoin</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_AltCertTherapy" name="E4b: Realizovat alternativnu certifikovanu psychoterapiu (individualne zdovodnenie)">
      <bpmn:incoming>Flow_G21_AltCert</bpmn:incoming>
      <bpmn:outgoing>Flow_AltCert_Step2Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_NoCertEscalate" name="E4c: Eskalovat - vyhladat certifikovaneho terapeuta alebo aplikovat SPI modalitu">
      <bpmn:incoming>Flow_G21_NoCert</bpmn:incoming>
      <bpmn:outgoing>Flow_NoCert_Step2Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_AltEBM" name="E4d: Realizovat alternativny psychoterapeuticky pristup (KBT nedostupna) s informovanim pacienta">
      <bpmn:incoming>Flow_G20_NoAvail</bpmn:incoming>
      <bpmn:incoming>Flow_G20_PatPref</bpmn:incoming>
      <bpmn:outgoing>Flow_AltEBM_Step2Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="SvcTask_IKBT" name="E5: Poskytovat internetovu KBT (I-KBT) cez digitalnu platformu (Krok 2 - alternativa)">
      <bpmn:incoming>Flow_G17_IKBT</bpmn:incoming>
      <bpmn:incoming>Flow_G12_No</bpmn:incoming>
      <bpmn:outgoing>Flow_IKBT_Step2Join</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:userTask id="Task_E6_Relax" name="E6: Realizovat aplikovanu relaxacnu terapiu (12-15 sedení, Krok 2c)">
      <bpmn:incoming>Flow_G17_Relax</bpmn:incoming>
      <bpmn:outgoing>Flow_E6_Step2Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_Step2Join" name="G_Step2Join: Zlucenie po Kroku 2">
      <bpmn:incoming>Flow_E3_Step2Join</bpmn:incoming>
      <bpmn:incoming>Flow_E13_KBTJoin</bpmn:incoming>
      <bpmn:incoming>Flow_AltCert_Step2Join</bpmn:incoming>
      <bpmn:incoming>Flow_NoCert_Step2Join</bpmn:incoming>
      <bpmn:incoming>Flow_AltEBM_Step2Join</bpmn:incoming>
      <bpmn:incoming>Flow_IKBT_Step2Join</bpmn:incoming>
      <bpmn:incoming>Flow_E6_Step2Join</bpmn:incoming>
      <bpmn:outgoing>Flow_Step2Join_G18</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Steps 2+3 combination gateway -->
    <bpmn:inclusiveGateway id="GW_18_Combine" name="G18: Kombinovat Kroky 2 a 3 (psychoterapia + farmakoterapia)?">
      <bpmn:incoming>Flow_Step2Join_G18</bpmn:incoming>
      <bpmn:incoming>Flow_G16_Step3</bpmn:incoming>
      <bpmn:outgoing>Flow_G18_Step2Only</bpmn:outgoing>
      <bpmn:outgoing>Flow_G18_Step3Only</bpmn:outgoing>
      <bpmn:outgoing>Flow_G18_Both</bpmn:outgoing>
    </bpmn:inclusiveGateway>

    <bpmn:userTask id="Task_E7_Pharma" name="E7: Podavat farmakoterapiu podla prislusneho SDTP - Panicka porucha (Krok 3)">
      <bpmn:incoming>Flow_G18_Step3Only</bpmn:incoming>
      <bpmn:incoming>Flow_G18_Both</bpmn:incoming>
      <bpmn:outgoing>Flow_E7_TreatJoin</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_E8_SupportGroup" name="E8: Facilitovat ucast v podpornej skupine (Krok 4)">
      <bpmn:incoming>Flow_G16_Step4</bpmn:incoming>
      <bpmn:outgoing>Flow_E8_TreatJoin</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_TreatJoin" name="G_TreatJoin: Zlucenie liecebnych ciest">
      <bpmn:incoming>Flow_G18_Step2Only</bpmn:incoming>
      <bpmn:incoming>Flow_E7_TreatJoin</bpmn:incoming>
      <bpmn:incoming>Flow_E8_TreatJoin</bpmn:incoming>
      <bpmn:incoming>Flow_E2_F1</bpmn:incoming>
      <bpmn:outgoing>Flow_TreatJoin_F1</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ==================== PHASE F: MONITORING ==================== -->
    <bpmn:userTask id="Task_F1_Monitor" name="F1: Administrovat nastroje monitorovania liecby (PHQ-9, GAD-7, dotaznik mobility)">
      <bpmn:incoming>Flow_TreatJoin_F1</bpmn:incoming>
      <bpmn:outgoing>Flow_F1_HIS</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="SvcTask_HIS" name="HIS: Zaznamenat klinické rozhodnutie a vysledky monitorovania do zdravotnej dokumentacie">
      <bpmn:incoming>Flow_F1_HIS</bpmn:incoming>
      <bpmn:outgoing>Flow_HIS_G22</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:businessRuleTask id="Task_G22_Threshold" name="G22-BRT: Vyhodnotit skore monitorovacich nastrojov voci klinickym prahom">
      <bpmn:incoming>Flow_HIS_G22</bpmn:incoming>
      <bpmn:outgoing>Flow_G22_Improve</bpmn:outgoing>
      <bpmn:outgoing>Flow_G22_Stagnate</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:userTask id="Task_F4_StatusAssess" name="F4: Vykonat pravidelne ambulantne posúdenie stavu pacienta">
      <bpmn:incoming>Flow_G22_Improve</bpmn:incoming>
      <bpmn:outgoing>Flow_F4_G23</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_F2_TreatResponse" name="F2: Vyhodnotit terapeutickú odpoved a rozhodnut o eskalacii">
      <bpmn:incoming>Flow_G22_Stagnate</bpmn:incoming>
      <bpmn:outgoing>Flow_F2_G19</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_19_Escalation" name="G19: Rozhodnutie o eskalacii liecby?">
      <bpmn:incoming>Flow_F2_G19</bpmn:incoming>
      <bpmn:outgoing>Flow_G19_Continue</bpmn:outgoing>
      <bpmn:outgoing>Flow_G19_Escalate</bpmn:outgoing>
      <bpmn:outgoing>Flow_G19_Combine</bpmn:outgoing>
      <bpmn:outgoing>Flow_G19_Severe</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_F3_DocDecision" name="F3: Dokumentovat klinicke rozhodnutie a zdovodnenie v zdravotnej dokumentacii">
      <bpmn:incoming>Flow_G19_Continue</bpmn:incoming>
      <bpmn:outgoing>Flow_F3_F4</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_23_SocialNeeds" name="G23: Pacient potrebuje socialnu / vzdelavaciu / zamestnanecku podporu?">
      <bpmn:incoming>Flow_F4_G23</bpmn:incoming>
      <bpmn:incoming>Flow_F3_F4</bpmn:incoming>
      <bpmn:outgoing>Flow_G23_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_G23_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_SocialRef" name="F5b: Odporucit socialnu podporu (svojpomocne skupiny, rehabilitacne / zamestnanecke sluzby)">
      <bpmn:incoming>Flow_G23_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_SocialRef_SuicCheck</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Recurring suicidality check during treatment -->
    <bpmn:userTask id="Task_SuicCheck" name="C5b: Opakované posudenie suicidalnej ideacie (priebezne pocas liecby)">
      <bpmn:incoming>Flow_G23_No</bpmn:incoming>
      <bpmn:incoming>Flow_SocialRef_SuicCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_SuicCheck_G07b</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_07b_SuicTreat" name="G07b: Pritomna suicidalita pocas liecby?">
      <bpmn:incoming>Flow_SuicCheck_G07b</bpmn:incoming>
      <bpmn:outgoing>Flow_G07b_Present</bpmn:outgoing>
      <bpmn:outgoing>Flow_G07b_Absent</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Emergency2" name="Koniec: Aktivacia nudzoveho protokolu pocas liecby (SOP)">
      <bpmn:incoming>Flow_G07b_Present</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="Task_E14_Relapse" name="E14: Pripravit pacienta na samostatny zivot a prevenciu relapsu">
      <bpmn:incoming>Flow_G07b_Absent</bpmn:incoming>
      <bpmn:outgoing>Flow_E14_G24</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_24_Completion" name="G24: Ukoncenie liecby a pripravenost na prevenciu relapsu?">
      <bpmn:incoming>Flow_E14_G24</bpmn:incoming>
      <bpmn:outgoing>Flow_G24_Achieved</bpmn:outgoing>
      <bpmn:outgoing>Flow_G24_Maintenance</bpmn:outgoing>
      <bpmn:outgoing>Flow_G24_Relapse</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Escalation loops -->
    <bpmn:userTask id="Task_EscalateStep" name="E_Esc: Eskalovat na dalsi stupen stupnovej starostlivosti">
      <bpmn:incoming>Flow_G19_Escalate</bpmn:incoming>
      <bpmn:outgoing>Flow_EscalateStep_G16</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_CombineSteps" name="E_Comb: Kombinovat psychoterapiu a farmakoterapiu (Kroky 2+3)">
      <bpmn:incoming>Flow_G19_Combine</bpmn:incoming>
      <bpmn:outgoing>Flow_CombineSteps_G18</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_ReassessHosp" name="D5b: Prehodnotit rozhodnutie o hospitalizacii (tazky priebeh, suicidalita)">
      <bpmn:incoming>Flow_G19_Severe</bpmn:incoming>
      <bpmn:outgoing>Flow_ReassessHosp_G11b</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_11b_HospLoop" name="G11b: Hospitalizacia potrebna po prehodnotení?">
      <bpmn:incoming>Flow_ReassessHosp_G11b</bpmn:incoming>
      <bpmn:outgoing>Flow_G11b_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_G11b_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Inpatient2" name="Koniec: Odoslanie na ustavnu starostlivost (sekundarny vstup)">
      <bpmn:incoming>Flow_G11b_Yes</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Maintenance -->
    <bpmn:userTask id="Task_Maintenance" name="F4b: Naplanovovat udrziacie monitorovacie navstevy (prevencia relapsu)">
      <bpmn:incoming>Flow_G24_Maintenance</bpmn:incoming>
      <bpmn:outgoing>Flow_Maintenance_F1</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Relapse re-entry -->
    <bpmn:userTask id="Task_RelapseReentry" name="E_Rel: Znovu vstupovat do liecebneho planu na primeranom stupni (relaps)">
      <bpmn:incoming>Flow_G24_Relapse</bpmn:incoming>
      <bpmn:outgoing>Flow_RelapseReentry_G16</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Acute emergency path -->
    <bpmn:startEvent id="StartEvent_Acute" name="Akutny stav pacienta">
      <bpmn:outgoing>Flow_Acute_E9</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_E9_Emergency" name="E9: Poskytnout akutnu nudzovu starostlivost (lekár RZP)">
      <bpmn:incoming>Flow_Acute_E9</bpmn:incoming>
      <bpmn:outgoing>Flow_E9_End</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_AcuteStabilized" name="Koniec: Akutny stav stabilizovany - navrat do liecebneho procesu">
      <bpmn:incoming>Flow_E9_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Final discharge end event -->
    <bpmn:endEvent id="EndEvent_Discharge" name="Koniec: Prepustenie pacienta s planom prevencie relapsu">
      <bpmn:incoming>Flow_G24_Achieved</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ==================== SEQUENCE FLOWS ==================== -->
    <!-- Prevention phase -->
    <bpmn:sequenceFlow id="Flow_Start_A1" sourceRef="StartEvent_1" targetRef="Task_A1_RiskFactors" />
    <bpmn:sequenceFlow id="Flow_A1_G01" sourceRef="Task_A1_RiskFactors" targetRef="GW_01_RiskProfile" />
    <bpmn:sequenceFlow id="Flow_G01_Yes" name="Rizikove faktory pritomne" sourceRef="GW_01_RiskProfile" targetRef="Task_A2_SelectProgram" />
    <bpmn:sequenceFlow id="Flow_G01_No" name="Ziadne vyznamne rizikove faktory" sourceRef="GW_01_RiskProfile" targetRef="EndEvent_Prevention" />
    <bpmn:sequenceFlow id="Flow_A2_G02" sourceRef="Task_A2_SelectProgram" targetRef="GW_02_PrevType" />
    <bpmn:sequenceFlow id="Flow_G02_Indicated" name="Indikovana prevencia (subklinicke symptomy)" sourceRef="GW_02_PrevType" targetRef="Task_A3a_Indicated" />
    <bpmn:sequenceFlow id="Flow_G02_Selective" name="Selektivna prevencia (vysoko rizikove osoby)" sourceRef="GW_02_PrevType" targetRef="Task_A3b_Selective" />
    <bpmn:sequenceFlow id="Flow_G02_Universal" name="Univerzalna prevencia (cela populacia)" sourceRef="GW_02_PrevType" targetRef="Task_A3c_Universal" />
    <bpmn:sequenceFlow id="Flow_A3a_Join" sourceRef="Task_A3a_Indicated" targetRef="GW_PrevJoin" />
    <bpmn:sequenceFlow id="Flow_A3b_Join" sourceRef="Task_A3b_Selective" targetRef="GW_PrevJoin" />
    <bpmn:sequenceFlow id="Flow_A3c_Join" sourceRef="Task_A3c_Universal" targetRef="GW_PrevJoin" />
    <bpmn:sequenceFlow id="Flow_PrevJoin_End" sourceRef="GW_PrevJoin" targetRef="EndEvent_Prevention" />

    <!-- Screening phase -->
    <bpmn:sequenceFlow id="Flow_StartB_B1" sourceRef="StartEvent_Screening" targetRef="Task_B1_Screening" />
    <bpmn:sequenceFlow id="Flow_B1_B2" sourceRef="Task_B1_Screening" targetRef="Task_B2_EvalScreen" />
    <bpmn:sequenceFlow id="Flow_B2_G03" sourceRef="Task_B2_EvalScreen" targetRef="GW_03_ScreenResult" />
    <bpmn:sequenceFlow id="Flow_G03_Positive" name="Pozitivny skrning - podozrenie na uzkostnu poruchu" sourceRef="GW_03_ScreenResult" targetRef="Task_B3_InitAssess" />
    <bpmn:sequenceFlow id="Flow_G03_Negative" name="Negativny skrning - ziadne uzkostne indikatory" sourceRef="GW_03_ScreenResult" targetRef="EndEvent_NegScreen" />
    <bpmn:sequenceFlow id="Flow_B3_G04" sourceRef="Task_B3_InitAssess" targetRef="GW_04_Referral" />
    <bpmn:sequenceFlow id="Flow_G04_Refer" name="Okamzite odoslanie k specialistovi" sourceRef="GW_04_Referral" targetRef="Task_B4_RefInfo" />
    <bpmn:sequenceFlow id="Flow_G04_GPManage" name="Manazovat v primárnej starostlivosti so specialistom" sourceRef="GW_04_Referral" targetRef="Task_B_GPManage" />
    <bpmn:sequenceFlow id="Flow_B4_B5" sourceRef="Task_B4_RefInfo" targetRef="Task_B5_InitiateRef" />
    <bpmn:sequenceFlow id="Flow_B5_G05" sourceRef="Task_B5_InitiateRef" targetRef="GW_05_SelfRef" />
    <bpmn:sequenceFlow id="Flow_GPManage_G05" sourceRef="Task_B_GPManage" targetRef="GW_05_SelfRef" />
    <bpmn:sequenceFlow id="Flow_G05_GPRef" name="Pacient odoslany vseobecnym lekarom" sourceRef="GW_05_SelfRef" targetRef="Task_C1_PsychExam" />
    <bpmn:sequenceFlow id="Flow_G05_SelfRef" name="Pacient prisiel na vlastnu iniciatívu (self-referral)" sourceRef="GW_05_SelfRef" targetRef="Task_B6_NotifyGP" />
    <bpmn:sequenceFlow id="Flow_B6_C1" sourceRef="Task_B6_NotifyGP" targetRef="Task_C1_PsychExam" />

    <!-- Diagnostic phase -->
    <bpmn:sequenceFlow id="Flow_C1_C2" sourceRef="Task_C1_PsychExam" targetRef="Task_C2_PsychoDiag" />
    <bpmn:sequenceFlow id="Flow_C2_C3" sourceRef="Task_C2_PsychoDiag" targetRef="Task_C3_SomaticExcl" />
    <bpmn:sequenceFlow id="Flow_C3_G06" sourceRef="Task_C3_SomaticExcl" targetRef="GW_06_Somatic" />
    <bpmn:sequenceFlow id="Flow_G06_Excluded" name="Somaticka pricina vylucena" sourceRef="GW_06_Somatic" targetRef="Task_C4_Psychometric" />
    <bpmn:sequenceFlow id="Flow_G06_Primary" name="Somaticka pricina je primarná diagnoza" sourceRef="GW_06_Somatic" targetRef="EndEvent_SomaticPrimary" />
    <bpmn:sequenceFlow id="Flow_G06_Comorbid" name="Somatická komorbidita - pokracovat v psychiatrickom vysetreni" sourceRef="GW_06_Somatic" targetRef="Task_C3b_SomaticParallel" />
    <bpmn:sequenceFlow id="Flow_C3b_C4" sourceRef="Task_C3b_SomaticParallel" targetRef="Task_C4_Psychometric" />
    <bpmn:sequenceFlow id="Flow_C4_C5" sourceRef="Task_C4_Psychometric" targetRef="Task_C5_Suicidality" />
    <bpmn:sequenceFlow id="Flow_C5_G07" sourceRef="Task_C5_Suicidality" targetRef="GW_07_Suicidality" />
    <bpmn:sequenceFlow id="Flow_G07_Present" name="Suicidalita pritomna - aktivovat SOP" sourceRef="GW_07_Suicidality" targetRef="EndEvent_Emergency" />
    <bpmn:sequenceFlow id="Flow_G07_Absent" name="Suicidalita nepritomna - pokracovat v diagnostike" sourceRef="GW_07_Suicidality" targetRef="GW_08_Neuro" />
    <bpmn:sequenceFlow id="Flow_G08_Yes" name="Neurologicky diferencial podozrivaný" sourceRef="GW_08_Neuro" targetRef="Task_C_NeuroRef" />
    <bpmn:sequenceFlow id="Flow_G08_No" name="Neurologicky diferencial neindikovaný" sourceRef="GW_08_Neuro" targetRef="Task_C6_DiffDiag" />
    <bpmn:sequenceFlow id="Flow_NeuroRef_C6" sourceRef="Task_C_NeuroRef" targetRef="Task_C6_DiffDiag" />
    <bpmn:sequenceFlow id="Flow_C6_C7" sourceRef="Task_C6_DiffDiag" targetRef="Task_C7_Psychophysio" />
    <bpmn:sequenceFlow id="Flow_C7_G09" sourceRef="Task_C7_Psychophysio" targetRef="GW_09_CompPsych" />
    <bpmn:sequenceFlow id="Flow_G09_Yes" name="Podozrenie na kognitívne / osobnostne poskodenie potvrdene" sourceRef="GW_09_CompPsych" targetRef="Task_C8_CompPsychExam" />
    <bpmn:sequenceFlow id="Flow_G09_No" name="Ziadne podozrenie na kognitívne alebo osobnostné poskodenie" sourceRef="GW_09_CompPsych" targetRef="GW_10_DiffOutcome" />
    <bpmn:sequenceFlow id="Flow_C8_G10" sourceRef="Task_C8_CompPsychExam" targetRef="GW_10_DiffOutcome" />
