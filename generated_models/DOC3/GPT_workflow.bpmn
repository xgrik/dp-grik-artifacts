      <bpmn:outgoing>Flow_012</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:businessRuleTask id="BusinessRule_PsychExamNeed" name="Assess Indication for Clinical-Psychological Examination">
