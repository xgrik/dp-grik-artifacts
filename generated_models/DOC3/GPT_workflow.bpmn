    <bpmn:userTask id="UserTask_Screening" name="Perform Initial Mental Health Screening">
      <bpmn:incoming>Flow_001</bpmn:incoming>
      <bpmn:outgoing>Flow_002</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:businessRuleTask id="BusinessRule_AssessSuspicion" name="Assess Suspicion of Agoraphobia or Related Anxiety Disorder">
