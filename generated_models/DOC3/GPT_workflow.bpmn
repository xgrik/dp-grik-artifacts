      <bpmn:outgoing>Flow_013</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="Gateway_PsychExam" name="Clinical-Psychological Examination Indicated?">
      <bpmn:incoming>Flow_013</bpmn:incoming>
