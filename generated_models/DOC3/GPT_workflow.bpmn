      <bpmn:outgoing>Flow_004</bpmn:outgoing>
      <bpmn:outgoing>Flow_005</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_NoSuspicion" name="End (No Specialist Pathway)">
      <bpmn:incoming>Flow_005</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="UserTask_ReferSpecialist" name="Refer Patient to Specialist Care">
      <bpmn:incoming>Flow_004</bpmn:incoming>
      <bpmn:outgoing>Flow_006</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="UserTask_PsychiatricAssessment" name="Conduct Psychiatric Diagnostic Assessment">
      <bpmn:incoming>Flow_006</bpmn:incoming>
      <bpmn:outgoing>Flow_007</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:businessRuleTask id="BusinessRule_SomaticNeed" name="Assess Need for Physical Examination and Somatic Tests">
