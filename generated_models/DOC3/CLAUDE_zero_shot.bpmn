<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  id="Definitions_Agorafobia"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
                  exporter="Camunda Modeler"
                  exporterVersion="5.33.1"
                  modeler:executionPlatform="Camunda Platform"
                  modeler:executionPlatformVersion="7.22.0">

  <!-- ═══════════════════════════════════════════════════════════
       POOL
  ═══════════════════════════════════════════════════════════ -->
  <bpmn:collaboration id="Collab_Agorafobia">
    <bpmn:participant id="Pool_Agorafobia" name="Manažment Agorafóbie (ŠDTP)" processRef="Process_Agorafobia"/>
  </bpmn:collaboration>

  <!-- ═══════════════════════════════════════════════════════════
       PROCESS
  ═══════════════════════════════════════════════════════════ -->
  <bpmn:process id="Process_Agorafobia" name="Agorafóbia – diagnostika, prevencia a liečba" isExecutable="true">

    <!-- ─── LANES ─── -->
    <bpmn:laneSet id="LaneSet_1">

      <bpmn:lane id="Lane_VseobecnyLekar" name="Všeobecný lekár / Primárna starostlivosť">
        <bpmn:flowNodeRef>StartEvent_Pacient</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Skrining</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_PodozrenieNaPoruchu</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InfoPacientovi</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OdeslanieKSpecialistovi</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Specialist" name="Psychiater / Klinický psychológ (Specialist)">
        <bpmn:flowNodeRef>Task_KomplexneVysetrenie</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Diagnostika</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DifDiagnostika</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_PotvrdenaAgorafobia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InaDiagnoza</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TvorbaLiecebnehoPlanu</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ZavaznostSymptomov</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Krok1Svojpomoc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Krok2Psychoterapia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_TypPsychoterapie</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_KBT</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SvojpomocSPodporou</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AplikovanaRelaxacia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Krok3Farmakoterapia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Krok4PodporneSkupiny</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_KomorbidityDepresiaAlkohol</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LiecbaKomorbidity</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Join_Kroky</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MonitorovanieEfektu</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_EfektLiecby</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpravaPlanualeboKombinacia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PreveniaRelapsu</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_SuicidalneRiziko</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_KrizIntervencia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Ukoncenie</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_InaPorucha</bpmn:flowNodeRef>
      </bpmn:lane>

    </bpmn:laneSet>

    <!-- ═══════════════════════════════════════
         START
    ═══════════════════════════════════════ -->
    <bpmn:startEvent id="StartEvent_Pacient" name="Pacient vyhľadá pomoc / podozrenie na úzkostnú poruchu">
      <bpmn:outgoing>SF_Start_Skrining</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ═══════════════════════════════════════
         PRIMÁRNA STAROSTLIVOSŤ
    ═══════════════════════════════════════ -->
    <bpmn:task id="Task_Skrining" name="Skríning úzkostných symptómov&#10;(4 skríningové otázky za posledné 2 týždne)">
      <bpmn:incoming>SF_Start_Skrining</bpmn:incoming>
      <bpmn:outgoing>SF_Skrining_GW1</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="GW_PodozrenieNaPoruchu" name="Podozrenie na psychickú poruchu?">
      <bpmn:incoming>SF_Skrining_GW1</bpmn:incoming>
      <bpmn:outgoing>SF_GW1_Info</bpmn:outgoing>
      <bpmn:outgoing>SF_GW1_Sledovanie</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_InfoPacientovi" name="Poskytnúť pacientovi písomné informácie&#10;(kam ísť, čoho sa neobávať)">
      <bpmn:incoming>SF_GW1_Info</bpmn:incoming>
      <bpmn:outgoing>SF_Info_Odeslanie</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_OdeslanieKSpecialistovi" name="Odoslanie k špecialistovi&#10;(psychiater / klinický psychológ)">
      <bpmn:incoming>SF_Info_Odeslanie</bpmn:incoming>
      <bpmn:outgoing>SF_Odeslanie_Vysetrenie</bpmn:outgoing>
    </bpmn:task>

    <!-- mierne symptómy – sledovanie bez odoslania -->
    <bpmn:endEvent id="EndEvent_InaPorucha" name="Sledovanie / psychoedukácia&#10;bez ďalšej intervencie">
      <bpmn:incoming>SF_GW1_Sledovanie</bpmn:incoming>
      <bpmn:incoming>SF_InaDiagnoza_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ═══════════════════════════════════════
         DIAGNOSTIKA
    ═══════════════════════════════════════ -->
    <bpmn:task id="Task_KomplexneVysetrenie" name="Komplexné psychiatrické / psychologické vyšetrenie&#10;(anamnéza, somatické vyšetrenie, EKG, EEG, krv, moč)">
      <bpmn:incoming>SF_Odeslanie_Vysetrenie</bpmn:incoming>
      <bpmn:outgoing>SF_Vysetrenie_Diagnostika</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Diagnostika" name="Stanovenie diagnózy podľa MKCH-10 / DSM-5&#10;(psychometrické nástroje: dotazník strachu, SCL-90,&#10;PHQ-9, GAD-7, dotazník mobility)">
      <bpmn:incoming>SF_Vysetrenie_Diagnostika</bpmn:incoming>
      <bpmn:outgoing>SF_Diagnostika_DifDiag</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_DifDiagnostika" name="Diferenciálna diagnostika&#10;(vylúčiť: somatické ochorenia, iné úzkostné poruchy,&#10;OCD, PTSD, GAD, sociálna fóbia, afektívne poruchy)">
      <bpmn:incoming>SF_Diagnostika_DifDiag</bpmn:incoming>
      <bpmn:outgoing>SF_DifDiag_GW2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="GW_PotvrdenaAgorafobia" name="Potvrdená agorafóbia (F40.0)?">
      <bpmn:incoming>SF_DifDiag_GW2</bpmn:incoming>
      <bpmn:outgoing>SF_GW2_LiecebnyPlan</bpmn:outgoing>
      <bpmn:outgoing>SF_GW2_InaDiagnoza</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_InaDiagnoza" name="Odporučiť príslušný ŠDTP&#10;pre inú diagnostickú jednotku">
      <bpmn:incoming>SF_GW2_InaDiagnoza</bpmn:incoming>
      <bpmn:outgoing>SF_InaDiagnoza_End</bpmn:outgoing>
    </bpmn:task>

    <!-- ═══════════════════════════════════════
         SUICIDÁLNE RIZIKO (paralelne)
    ═══════════════════════════════════════ -->
    <bpmn:exclusiveGateway id="GW_SuicidalneRiziko" name="Suicidálne myšlienky / riziko sebapoškodenia?">
      <bpmn:incoming>SF_GW2_LiecebnyPlan</bpmn:incoming>
      <bpmn:outgoing>SF_Suicid_Kriza</bpmn:outgoing>
      <bpmn:outgoing>SF_Suicid_Pokracuj</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_KrizIntervencia" name="Krízová intervencia / postup podľa ŠOP&#10;pre sebapoškodzovanie / samovraždu">
      <bpmn:incoming>SF_Suicid_Kriza</bpmn:incoming>
      <bpmn:outgoing>SF_Kriza_LiecebnyPlan</bpmn:outgoing>
    </bpmn:task>

    <!-- ═══════════════════════════════════════
         LIEČEBNÝ PLÁN
    ═══════════════════════════════════════ -->
    <bpmn:task id="Task_TvorbaLiecebnehoPlanu" name="Tvorba individuálneho liečebného plánu&#10;(zohľadniť: závažnosť, komorbiditý, preferencie pacienta,&#10;dostupnosť terapie, EBM postupy)">
      <bpmn:incoming>SF_Suicid_Pokracuj</bpmn:incoming>
      <bpmn:incoming>SF_Kriza_LiecebnyPlan</bpmn:incoming>
      <bpmn:outgoing>SF_LiecebnyPlan_GWZavaznost</bpmn:outgoing>
    </bpmn:task>

    <!-- ═══════════════════════════════════════
         VETVENIE PODĽA ZÁVAŽNOSTI
    ═══════════════════════════════════════ -->
    <bpmn:exclusiveGateway id="GW_ZavaznostSymptomov" name="Stupeň závažnosti / vhodný krok liečby?">
      <bpmn:incoming>SF_LiecebnyPlan_GWZavaznost</bpmn:incoming>
      <bpmn:outgoing>SF_GWZav_Krok1</bpmn:outgoing>
      <bpmn:outgoing>SF_GWZav_Krok2</bpmn:outgoing>
      <bpmn:outgoing>SF_GWZav_Krok3</bpmn:outgoing>
      <bpmn:outgoing>SF_GWZav_Krok4</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- KROK 1 -->
    <bpmn:task id="Task_Krok1Svojpomoc" name="Krok 1: Svojpomocné techniky&#10;(edukácia, zvládanie paniky, zmena životného štýlu,&#10;mobilné aplikácie, všímavosť)">
      <bpmn:incoming>SF_GWZav_Krok1</bpmn:incoming>
      <bpmn:outgoing>SF_Krok1_Join</bpmn:outgoing>
    </bpmn:task>

    <!-- KROK 2 -->
    <bpmn:task id="Task_Krok2Psychoterapia" name="Krok 2: Psychologické terapie&#10;(výber konkrétneho prístupu)">
      <bpmn:incoming>SF_GWZav_Krok2</bpmn:incoming>
      <bpmn:outgoing>SF_Krok2_TypGW</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="GW_TypPsychoterapie" name="Typ psychoterapie?">
      <bpmn:incoming>SF_Krok2_TypGW</bpmn:incoming>
      <bpmn:outgoing>SF_Typ_KBT</bpmn:outgoing>
      <bpmn:outgoing>SF_Typ_Svojpomoc</bpmn:outgoing>
      <bpmn:outgoing>SF_Typ_Relaxacia</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_KBT" name="Kognitívno-behaviorálna terapia (KBT)&#10;12–15 hodinových sedení&#10;(expozícia, kognitívna reštrukturalizácia,&#10;prevencia relapsu)">
      <bpmn:incoming>SF_Typ_KBT</bpmn:incoming>
      <bpmn:outgoing>SF_KBT_Join</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_SvojpomocSPodporou" name="Svojpomocná terapia s podporou terapeuta&#10;(KBT kniha / pracovný zošit +&#10;krátky terapeutický kontakt)">
      <bpmn:incoming>SF_Typ_Svojpomoc</bpmn:incoming>
      <bpmn:outgoing>SF_Svojpomoc_Join</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_AplikovanaRelaxacia" name="Aplikovaná relaxácia&#10;12–15 hodinových sedení&#10;(Jacobsonova relaxácia, riadené dýchanie)">
      <bpmn:incoming>SF_Typ_Relaxacia</bpmn:incoming>
      <bpmn:outgoing>SF_Relaxacia_Join</bpmn:outgoing>
    </bpmn:task>

    <!-- KROK 3 -->
    <bpmn:task id="Task_Krok3Farmakoterapia" name="Krok 3: Farmakoterapia&#10;(SSRI, podľa príslušného ŠDTP – v kompetencii psychiatra)">
      <bpmn:incoming>SF_GWZav_Krok3</bpmn:incoming>
      <bpmn:outgoing>SF_Krok3_Join</bpmn:outgoing>
    </bpmn:task>

    <!-- KROK 4 -->
    <bpmn:task id="Task_Krok4PodporneSkupiny" name="Krok 4: Podporné skupiny&#10;(svojpomocné skupiny, rodinná psychoedukácia,&#10;rehabilitačné a zamestnanecké programy)">
      <bpmn:incoming>SF_GWZav_Krok4</bpmn:incoming>
      <bpmn:outgoing>SF_Krok4_Join</bpmn:outgoing>
    </bpmn:task>

    <!-- JOIN po krokoch -->
    <bpmn:exclusiveGateway id="GW_Join_Kroky" name="Zjednotenie po kroku liečby">
      <bpmn:incoming>SF_Krok1_Join</bpmn:incoming>
      <bpmn:incoming>SF_KBT_Join</bpmn:incoming>
      <bpmn:incoming>SF_Svojpomoc_Join</bpmn:incoming>
      <bpmn:incoming>SF_Relaxacia_Join</bpmn:incoming>
      <bpmn:incoming>SF_Krok3_Join</bpmn:incoming>
      <bpmn:incoming>SF_Krok4_Join</bpmn:incoming>
      <bpmn:incoming>SF_Komorbidita_Join</bpmn:incoming>
      <bpmn:outgoing>SF_Join_Monitoring</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ═══════════════════════════════════════
         KOMORBIDITÝ
    ═══════════════════════════════════════ -->
    <bpmn:exclusiveGateway id="GW_KomorbidityDepresiaAlkohol" name="Prítomné komorbiditý&#10;(depresia / závislosť od alkoholu)?">
      <bpmn:incoming>SF_LiecebnyPlan_GWKomorbidity</bpmn:incoming>
      <bpmn:outgoing>SF_Komorbidita_Liecba</bpmn:outgoing>
      <bpmn:outgoing>SF_Komorbidita_Nie</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_LiecbaKomorbidity" name="Liečba komorbiditý ako priorita&#10;(depresia → ŠDTP pre depresiu;&#10;závislosť od alkoholu → liečba závislosti)">
      <bpmn:incoming>SF_Komorbidita_Liecba</bpmn:incoming>
      <bpmn:outgoing>SF_Komorbidita_Join</bpmn:outgoing>
    </bpmn:task>

    <!-- ═══════════════════════════════════════
         MONITOROVANIE A HODNOTENIE EFEKTU
    ═══════════════════════════════════════ -->
    <bpmn:task id="Task_MonitorovanieEfektu" name="Monitorovanie efektu terapie&#10;(PHQ-9, GAD-7, dotazník mobility –&#10;na začiatku, priebežne a na konci liečby)">
      <bpmn:incoming>SF_Join_Monitoring</bpmn:incoming>
      <bpmn:outgoing>SF_Monitoring_GWEfekt</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="GW_EfektLiecby" name="Efekt liečby dostatočný?">
      <bpmn:incoming>SF_Monitoring_GWEfekt</bpmn:incoming>
      <bpmn:outgoing>SF_Efekt_Prevencia</bpmn:outgoing>
      <bpmn:outgoing>SF_Efekt_Uprava</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_UpravaPlanualeboKombinacia" name="Úprava liečebného plánu&#10;(kombinácia KBT + farmakoterapia,&#10;zmena psychoterapeutického prístupu,&#10;zvážiť hospitalizáciu pri ťažkých stavoch)">
      <bpmn:incoming>SF_Efekt_Uprava</bpmn:incoming>
      <bpmn:outgoing>SF_Uprava_LiecebnyPlan</bpmn:outgoing>
    </bpmn:task>

    <!-- ═══════════════════════════════════════
         PREVENCIA RELAPSU A UKONČENIE
    ═══════════════════════════════════════ -->
    <bpmn:task id="Task_PreveniaRelapsu" name="Prevencia relapsu a ukončenie liečby&#10;(príprava na samostatný život,&#10;plán zvládania príznakov, sledovanie)">
      <bpmn:incoming>SF_Efekt_Prevencia</bpmn:incoming>
      <bpmn:outgoing>SF_Prevencia_End</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_Ukoncenie" name="Liečba ukončená / pacient v remisii&#10;(ďalší audit po 5 rokoch)">
      <bpmn:incoming>SF_Prevencia_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ═══════════════════════════════════════
         SEQUENCE FLOWS
    ═══════════════════════════════════════ -->
    <bpmn:sequenceFlow id="SF_Start_Skrining"             sourceRef="StartEvent_Pacient"          targetRef="Task_Skrining"/>
    <bpmn:sequenceFlow id="SF_Skrining_GW1"               sourceRef="Task_Skrining"               targetRef="GW_PodozrenieNaPoruchu"/>
    <bpmn:sequenceFlow id="SF_GW1_Info"                   name="Áno" sourceRef="GW_PodozrenieNaPoruchu"    targetRef="Task_InfoPacientovi"/>
    <bpmn:sequenceFlow id="SF_GW1_Sledovanie"             name="Nie (mierne / bez podozrenia)" sourceRef="GW_PodozrenieNaPoruchu"    targetRef="EndEvent_InaPorucha"/>
    <bpmn:sequenceFlow id="SF_Info_Odeslanie"             sourceRef="Task_InfoPacientovi"         targetRef="Task_OdeslanieKSpecialistovi"/>
    <bpmn:sequenceFlow id="SF_Odeslanie_Vysetrenie"       sourceRef="Task_OdeslanieKSpecialistovi" targetRef="Task_KomplexneVysetrenie"/>
    <bpmn:sequenceFlow id="SF_Vysetrenie_Diagnostika"     sourceRef="Task_KomplexneVysetrenie"    targetRef="Task_Diagnostika"/>
    <bpmn:sequenceFlow id="SF_Diagnostika_DifDiag"        sourceRef="Task_Diagnostika"            targetRef="Task_DifDiagnostika"/>
    <bpmn:sequenceFlow id="SF_DifDiag_GW2"                sourceRef="Task_DifDiagnostika"         targetRef="GW_PotvrdenaAgorafobia"/>
    <bpmn:sequenceFlow id="SF_GW2_LiecebnyPlan"           name="Áno – agorafóbia F40.0" sourceRef="GW_PotvrdenaAgorafobia"      targetRef="GW_SuicidalneRiziko"/>
    <bpmn:sequenceFlow id="SF_GW2_InaDiagnoza"            name="Nie – iná porucha" sourceRef="GW_PotvrdenaAgorafobia"      targetRef="Task_InaDiagnoza"/>
    <bpmn:sequenceFlow id="SF_InaDiagnoza_End"            sourceRef="Task_InaDiagnoza"            targetRef="EndEvent_InaPorucha"/>
    <bpmn:sequenceFlow id="SF_Suicid_Kriza"               name="Áno – suicidálne riziko" sourceRef="GW_SuicidalneRiziko"         targetRef="Task_KrizIntervencia"/>
    <bpmn:sequenceFlow id="SF_Suicid_Pokracuj"            name="Nie" sourceRef="GW_SuicidalneRiziko"         targetRef="Task_TvorbaLiecebnehoPlanu"/>
    <bpmn:sequenceFlow id="SF_Kriza_LiecebnyPlan"         sourceRef="Task_KrizIntervencia"        targetRef="Task_TvorbaLiecebnehoPlanu"/>
    <bpmn:sequenceFlow id="SF_LiecebnyPlan_GWZavaznost"   sourceRef="Task_TvorbaLiecebnehoPlanu"  targetRef="GW_ZavaznostSymptomov"/>
    <!-- komorbiditý – vetva z liečebného plánu cez gateway -->
    <bpmn:sequenceFlow id="SF_LiecebnyPlan_GWKomorbidity" sourceRef="Task_TvorbaLiecebnehoPlanu"  targetRef="GW_KomorbidityDepresiaAlkohol"/>
    <bpmn:sequenceFlow id="SF_Komorbidita_Liecba"         name="Áno" sourceRef="GW_KomorbidityDepresiaAlkohol" targetRef="Task_LiecbaKomorbidity"/>
    <bpmn:sequenceFlow id="SF_Komorbidita_Nie"            name="Nie" sourceRef="GW_KomorbidityDepresiaAlkohol" targetRef="GW_Join_Kroky"/>
    <bpmn:sequenceFlow id="SF_Komorbidita_Join"           sourceRef="Task_LiecbaKomorbidity"      targetRef="GW_Join_Kroky"/>
    <bpmn:sequenceFlow id="SF_GWZav_Krok1"               name="Mierne – Krok 1" sourceRef="GW_ZavaznostSymptomov"       targetRef="Task_Krok1Svojpomoc"/>
    <bpmn:sequenceFlow id="SF_GWZav_Krok2"               name="Stredné – Krok 2" sourceRef="GW_ZavaznostSymptomov"       targetRef="Task_Krok2Psychoterapia"/>
    <bpmn:sequenceFlow id="SF_GWZav_Krok3"               name="Závažné – Krok 3" sourceRef="GW_ZavaznostSymptomov"       targetRef="Task_Krok3Farmakoterapia"/>
    <bpmn:sequenceFlow id="SF_GWZav_Krok4"               name="Podpora – Krok 4" sourceRef="GW_ZavaznostSymptomov"       targetRef="Task_Krok4PodporneSkupiny"/>
    <bpmn:sequenceFlow id="SF_Krok1_Join"                 sourceRef="Task_Krok1Svojpomoc"         targetRef="GW_Join_Kroky"/>
    <bpmn:sequenceFlow id="SF_Krok2_TypGW"                sourceRef="Task_Krok2Psychoterapia"     targetRef="GW_TypPsychoterapie"/>
    <bpmn:sequenceFlow id="SF_Typ_KBT"                    name="KBT" sourceRef="GW_TypPsychoterapie"          targetRef="Task_KBT"/>
    <bpmn:sequenceFlow id="SF_Typ_Svojpomoc"              name="Svojpomoc s podporou" sourceRef="GW_TypPsychoterapie"          targetRef="Task_SvojpomocSPodporou"/>
    <bpmn:sequenceFlow id="SF_Typ_Relaxacia"              name="Aplikovaná relaxácia" sourceRef="GW_TypPsychoterapie"          targetRef="Task_AplikovanaRelaxacia"/>
    <bpmn:sequenceFlow id="SF_KBT_Join"                   sourceRef="Task_KBT"                    targetRef="GW_Join_Kroky"/>
    <bpmn:sequenceFlow id="SF_Svojpomoc_Join"             sourceRef="Task_SvojpomocSPodporou"     targetRef="GW_Join_Kroky"/>
