  <bpmn:process id="Process_0mxms9h" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Patient Presentation">
      <bpmn:outgoing>Flow_Start</bpmn:outgoing>
    </bpmn:startEvent>
    
    <bpmn:userTask id="Activity_Screening" name="Perform Primary Screening">
      <bpmn:incoming>Flow_Start</bpmn:incoming>
      <bpmn:outgoing>Flow_Screening</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:exclusiveGateway id="Gateway_Screening" name="Screening Outcome">
      <bpmn:incoming>Flow_Screening</bpmn:incoming>
      <bpmn:outgoing>Flow_Screening_Neg</bpmn:outgoing>
      <bpmn:outgoing>Flow_Screening_Pos</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:endEvent id="Event_Dismissed" name="Suspicion Dismissed">
      <bpmn:incoming>Flow_Screening_Neg</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:businessRuleTask id="Activity_CheckReferral" name="Referral Source Verification">
      <bpmn:incoming>Flow_Screening_Pos</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckReferral</bpmn:outgoing>
    </bpmn:businessRuleTask>
    
    <bpmn:exclusiveGateway id="Gateway_Referral" name="Referral Source Verified?">
      <bpmn:incoming>Flow_CheckReferral</bpmn:incoming>
      <bpmn:outgoing>Flow_Ref_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_Ref_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:serviceTask id="Activity_InformGP" name="Inform General Practitioner">
      <bpmn:incoming>Flow_Ref_No</bpmn:incoming>
      <bpmn:outgoing>Flow_Inform_Refer</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:serviceTask id="Activity_Refer" name="Refer to Specialist">
      <bpmn:incoming>Flow_Ref_Yes</bpmn:incoming>
      <bpmn:incoming>Flow_Inform_Refer</bpmn:incoming>
      <bpmn:outgoing>Flow_Refer_Exam</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:userTask id="Activity_PsychExam" name="Conduct Psychiatric Examination">
      <bpmn:incoming>Flow_Refer_Exam</bpmn:incoming>
      <bpmn:outgoing>Flow_Exam_Diag</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:userTask id="Activity_PsychoDiag" name="Perform Psychodiagnostic Evaluation">
      <bpmn:incoming>Flow_Exam_Diag</bpmn:incoming>
      <bpmn:outgoing>Flow_Diag_Inst</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:userTask id="Activity_ApplyInst" name="Apply Psychometric Instruments">
      <bpmn:incoming>Flow_Diag_Inst</bpmn:incoming>
      <bpmn:outgoing>Flow_Inst_Logic</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:businessRuleTask id="Activity_DiffDiagLogic" name="Differential Diagnostic Evaluation">
      <bpmn:incoming>Flow_Inst_Logic</bpmn:incoming>
      <bpmn:outgoing>Flow_Logic_DiagGW</bpmn:outgoing>
    </bpmn:businessRuleTask>
    
    <bpmn:exclusiveGateway id="Gateway_Diagnosis" name="Diagnosis Confirmed?">
      <bpmn:incoming>Flow_Logic_DiagGW</bpmn:incoming>
      <bpmn:outgoing>Flow_Diag_Other</bpmn:outgoing>
      <bpmn:outgoing>Flow_Diag_F40</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:endEvent id="Event_OtherCondition" name="Diverted to Other Standard">
      <bpmn:incoming>Flow_Diag_Other</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:userTask id="Activity_PatientEd" name="Provide Patient Education">
      <bpmn:incoming>Flow_Diag_F40</bpmn:incoming>
      <bpmn:outgoing>Flow_Ed_Plan</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:userTask id="Activity_DevPlan" name="Develop Individual Therapeutic Plan">
      <bpmn:incoming>Flow_Ed_Plan</bpmn:incoming>
      <bpmn:outgoing>Flow_Plan_Comorb</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:businessRuleTask id="Activity_EvalComorb" name="Assess Comorbidity">
      <bpmn:incoming>Flow_Plan_Comorb</bpmn:incoming>
      <bpmn:outgoing>Flow_Comorb_GW</bpmn:outgoing>
    </bpmn:businessRuleTask>
    
    <bpmn:exclusiveGateway id="Gateway_Comorb" name="Comorbidity with Panic Disorder?">
      <bpmn:incoming>Flow_Comorb_GW</bpmn:incoming>
      <bpmn:outgoing>Flow_Comorb_Panic</bpmn:outgoing>
      <bpmn:outgoing>Flow_Comorb_Ago</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:endEvent id="Event_Panic" name="Trigger Panic Disorder Standard">
      <bpmn:incoming>Flow_Comorb_Panic</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:businessRuleTask id="Activity_AssessDev" name="Assess Standard Deviation">
      <bpmn:incoming>Flow_Comorb_Ago</bpmn:incoming>
      <bpmn:outgoing>Flow_Dev_GW</bpmn:outgoing>
    </bpmn:businessRuleTask>
    
    <bpmn:exclusiveGateway id="Gateway_Deviation" name="Deviation Required?">
      <bpmn:incoming>Flow_Dev_GW</bpmn:incoming>
      <bpmn:outgoing>Flow_Dev_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Dev_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:endEvent id="Event_Alternative" name="Proceed to Alternative Procedure">
      <bpmn:incoming>Flow_Dev_Yes</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:businessRuleTask id="Activity_CheckAccess" name="Evaluate Patient Accessibility">
      <bpmn:incoming>Flow_Dev_No</bpmn:incoming>
      <bpmn:outgoing>Flow_Access_GW</bpmn:outgoing>
    </bpmn:businessRuleTask>
    
    <bpmn:exclusiveGateway id="Gateway_Access" name="Can Patient Attend?">
      <bpmn:incoming>Flow_Access_GW</bpmn:incoming>
      <bpmn:outgoing>Flow_Acc_Remote</bpmn:outgoing>
      <bpmn:outgoing>Flow_Acc_Attend</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:userTask id="Activity_Step1" name="Administer Step 1 (Self-Help)">
      <bpmn:incoming>Flow_Acc_Remote</bpmn:incoming>
      <bpmn:outgoing>Flow_Step1_Mon</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:exclusiveGateway id="Gateway_Therapist" name="Therapist Qualification">
      <bpmn:incoming>Flow_Acc_Attend</bpmn:incoming>
      <bpmn:outgoing>Flow_Ther_Cert</bpmn:outgoing>
      <bpmn:outgoing>Flow_Ther_Gen</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:userTask id="Activity_Step2" name="Administer Step 2 (Psychotherapy)">
      <bpmn:incoming>Flow_Ther_Cert</bpmn:incoming>
      <bpmn:outgoing>Flow_Step2_Mon</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:userTask id="Activity_Step3" name="Manage Pharmacotherapy (Step 3)">
      <bpmn:incoming>Flow_Ther_Gen</bpmn:incoming>
      <bpmn:outgoing>Flow_Step3_Mon</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:userTask id="Activity_Monitor" name="Monitor Therapeutic Effect">
      <bpmn:incoming>Flow_Step1_Mon</bpmn:incoming>
      <bpmn:incoming>Flow_Step2_Mon</bpmn:incoming>
      <bpmn:incoming>Flow_Step3_Mon</bpmn:incoming>
      <bpmn:outgoing>Flow_Mon_End</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:endEvent id="Event_Complete" name="Therapy Completed">
      <bpmn:incoming>Flow_Mon_End</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:sequenceFlow id="Flow_Start" sourceRef="StartEvent_1" targetRef="Activity_Screening" />
    <bpmn:sequenceFlow id="Flow_Screening" sourceRef="Activity_Screening" targetRef="Gateway_Screening" />
